# .env.prod.example — Variables d'environnement PRODUCTION
#
# ⚠️  Ce fichier est un MODÈLE. Sur le serveur, copie-le en .env.local :
#       cp .env.prod.example .env.local
#    puis remplis chaque valeur (ne jamais committer .env.local !)
#
# Sur le serveur : /root/bazaart-plateforme/.env.local

# ── Symfony ────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_SECRET=GENERE_UNE_CLE_ALEATOIRE_ICI   # Ex: php -r "echo bin2hex(random_bytes(16));"

# ── Base de données PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=bazaart
POSTGRES_USER=bazaart_user
POSTGRES_PASSWORD=MOT_DE_PASSE_FORT_ICI

# Doctrine construit cette URL depuis les variables ci-dessus
DATABASE_URL=postgresql://bazaart_user:MOT_DE_PASSE_FORT_ICI@postgres:5432/bazaart?serverVersion=16&charset=utf8

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Emails (Brevo ou Resend en prod) ──────────────────────────────────────
# Brevo : smtp+tls://login:mot_de_passe@smtp-relay.brevo.com:587
# Resend : smtp://resend:API_KEY@smtp.resend.com:465
MAILER_DSN=smtp+tls://TON_LOGIN:TON_MOT_DE_PASSE@smtp-relay.brevo.com:587

# ── Bunny Stream (vidéo formations) ────────────────────────────────────────
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

# ── Services optionnels ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
N8N_WEBHOOK_BASE_URL=
SENTRY_DSN=
