{% extends 'base_app.html.twig' %}

{#
 # resource/index.html.twig — Catalogue des ressources / opportunités
 #
 # Thème : Street (app connectée)
 # Polices : Archivo Black (--display) pour les titres, Space Grotesk (--body) pour le reste
 # Palette : fond var(--bg) sable, accent var(--accent) lime, contours var(--ink) quasi-noir
 # Design : bords francs (radius 0), grille editoriale, barre de filtres façon tableau de bord
 #
 # Variables Twig disponibles :
 #   resources           — tableau de Resource (uniquement la page courante, 12 max)
 #   types               — tableau de ResourceType pour le select
 #   disciplines         — tableau de Discipline pour le select
 #   currentSearch       — string (filtre texte actif)
 #   currentTypeId       — int|null (filtre type actif)
 #   currentDisciplineId — int|null (filtre discipline actif)
 #   currentPage         — int (page courante, 1-based)
 #   totalPages          — int (nombre total de pages)
 #   total               — int (nombre total de résultats tous filtres confondus)
 #}

{% block title %}Ressources — Bazaart{% endblock %}
{% block page_title %}Ressources{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ═══════════════════════════════════════════════════════════════════════
       CATALOGUE RESSOURCES — styles thème Street
       Toutes les valeurs passent par des variables CSS du design-tokens.css.
       Aucune couleur ou police en dur : on utilise var(--...) pour que
       le design system puisse évoluer sans toucher aux templates.
    ═══════════════════════════════════════════════════════════════════════ */

    /* ── En-tête de section ────────────────────────────────────────────── */

    /* Bande supérieure : titre géant + compteur de résultats + bouton CTA */
    .opp-header {
        padding: var(--space-xl) 0 var(--space-lg);
        border-bottom: 1px solid var(--ink);
        margin-bottom: 0;
    }

    /* Ligne flex : titre à gauche, bouton soumettre à droite */
    .opp-header__row {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: var(--space-lg);
        flex-wrap: wrap;
    }

    /* Sur-titre mono (style "eyebrow" du prototype) :
       point carré accent + texte uppercase → identité graphique forte */
    .opp-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        font-family: var(--mono);
        font-size: var(--eyebrow-font-size);
        font-weight: var(--eyebrow-font-weight);
        letter-spacing: var(--eyebrow-letter-spacing);
        text-transform: uppercase;
        color: var(--ink-mute);
        margin-bottom: var(--space-sm);
    }

    /* Le petit carré vert = signal graphique "c'est actif / c'est ici" */
    .opp-eyebrow::before {
        content: '';
        display: inline-block;
        width: var(--eyebrow-dot-size);
        height: var(--eyebrow-dot-size);
        background: var(--accent);
        flex-shrink: 0;
    }

    /* Titre principal : très grand, uppercase, Archivo Black
       clamp() = fluid typography : 40px min, 9vw idéal, 80px max */
    .opp-title {
        font-family: var(--display);
        font-size: clamp(40px, 7vw, 80px);
        line-height: 0.92;
        text-transform: uppercase;
        color: var(--ink);
        margin: 0;
    }

    /* ── Barre de filtres ──────────────────────────────────────────────── */

    /* Fond légèrement plus foncé que la page = zone fonctionnelle distincte */
    .filter-bar {
        background: var(--bg-alt);
        border-bottom: 1px solid var(--ink);
        display: flex;
        flex-wrap: wrap;
        align-items: stretch;
        gap: 0;
        margin-bottom: var(--space-xl);
    }

    /* Chaque groupe filtre = colonne verticale label + champ */
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding: var(--space-sm) var(--space-md);
        border-right: 1px solid var(--ink);
        flex: 1;
        min-width: 160px;
    }

    /* Champ de recherche pleine largeur */
    .filter-group--search {
        flex: 2;
        min-width: 220px;
    }

    /* Label au-dessus des champs : mono très petit, uppercase = ton éditorial */
    .filter-label {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    /* Inputs et selects : bords francs, transparent sur fond bg-alt */
    .filter-input,
    .filter-select {
        background: transparent;
        border: none;
        border-bottom: 1px solid transparent;
        padding: var(--space-xs) 0;
        font-family: var(--body);
        font-size: 13px;
        font-weight: 500;
        color: var(--ink);
        outline: none;
        width: 100%;
        transition: border-color var(--transition-fast);
        cursor: text;
    }
    .filter-select { cursor: pointer; }
    .filter-input:focus,
    .filter-select:focus {
        border-bottom-color: var(--accent);
    }

    /* Zone boutons filtrer / réinitialiser */
    .filter-actions {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: var(--space-sm) var(--space-md);
    }

    /* Bouton "Filtrer" : style primaire Street = fond ink, texte accent au hover */
    .btn-filter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: var(--btn-padding-sm);
        background: var(--ink);
        color: var(--bg);
        border: 2px solid var(--ink);
        font-family: var(--body);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        cursor: pointer;
        border-radius: var(--btn-radius);
        transition: background var(--transition-fast), color var(--transition-fast);
        white-space: nowrap;
    }
    .btn-filter:hover {
        background: var(--accent);
        color: var(--ink);
        border-color: var(--ink);
    }

    /* Bouton "Réinitialiser" : style ghost transparent */
    .btn-reset-filter {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: var(--btn-padding-sm);
        background: transparent;
        color: var(--ink-mute);
        border: 1px solid var(--line-soft);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        border-radius: var(--btn-radius);
        transition: color var(--transition-fast), border-color var(--transition-fast);
        white-space: nowrap;
    }
    .btn-reset-filter:hover {
        color: var(--ink);
        border-color: var(--ink);
    }

    /* ── Compteur de résultats ─────────────────────────────────────────── */
    .results-count {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .08em;
        color: var(--ink-mute);
        text-transform: uppercase;
        margin-bottom: var(--space-md);
    }

    /* ── Bouton soumettre (coin haut droit de l'en-tête) ──────────────── */

    /* Style primaire accent lime */
    .btn-submit-resource {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: var(--btn-padding);
        background: var(--accent);
        color: var(--ink);
        border: 2px solid var(--ink);
        font-family: var(--body);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        border-radius: var(--btn-radius);
        transition: background var(--transition-fast), color var(--transition-fast);
    }
    .btn-submit-resource:hover {
        background: var(--ink);
        color: var(--accent);
    }

    /* ── Grille de cartes ──────────────────────────────────────────────── */

    /* Grille 3 colonnes desktop, 2 tablet, 1 mobile
       Les cartes se touchent (gap:0) avec bordures partagées = style éditorial */
    .resource-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        border: 1px solid var(--ink);
    }

    @media (min-width: 640px) {
        .resource-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (min-width: 1024px) {
        .resource-grid { grid-template-columns: 1fr 1fr 1fr; }
    }

    /* ── Carte ressource ───────────────────────────────────────────────── */

    /* Chaque carte est un lien complet (clic sur toute la surface).
       Bords francs, pas d'ombre, bordure partagée avec les voisines. */
    .resource-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding: var(--space-xl) var(--space-lg);
        background: var(--bg);
        border-right: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
        position: relative;
        text-decoration: none;
        color: inherit;
        transition: background var(--transition-fast);
        min-height: 260px;
    }

    /* Survol : fond lime = signal interactif fort (style affiche) */
    .resource-card:hover {
        background: var(--accent);
    }

    /* ── Ligne du haut : badge type + déadline ── */
    .resource-card__top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-sm);
        flex-wrap: wrap;
    }

    /* Badge type = chip style Street : fond accent, bords francs, mono uppercase */
    .resource-badge-type {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: var(--chip-padding);
        background: var(--ink);
        color: var(--bg);
        font-family: var(--mono);
        font-size: var(--chip-font-size);
        font-weight: var(--chip-font-weight);
        letter-spacing: var(--chip-letter-spacing);
        text-transform: uppercase;
        border-radius: var(--chip-radius);
        flex-shrink: 0;
    }

    /* Sur fond vert au hover, le badge type s'inverse */
    .resource-card:hover .resource-badge-type {
        background: var(--ink);
        color: var(--accent);
    }

    /* Badge deadline urgent (< 14 jours) : accent secondaire orange */
    .resource-badge-deadline {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 600;
        color: var(--ink-mute);
        white-space: nowrap;
    }

    /* Moins de 14 jours : passage à l'orange pour signaler l'urgence */
    .resource-badge-deadline--urgent {
        color: var(--accent-2);
        font-weight: 700;
    }

    /* ── Titre de la carte ── */
    .resource-card__title {
        font-family: var(--display);
        font-size: 20px;
        line-height: 1.05;
        color: var(--ink);
        text-decoration: none;
        /* Limiter à 3 lignes avec ellipse — évite les cartes inégales */
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* ── Méta (organisation) ── */
    .resource-card__meta {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        letter-spacing: .04em;
    }

    /* ── Description courte ── */
    .resource-card__desc {
        font-family: var(--body);
        font-size: 13px;
        color: var(--ink-mute);
        line-height: 1.5;
        /* 2 lignes max */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    /* ── Pied de carte : disciplines + flèche ── */
    .resource-card__footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-sm);
        padding-top: var(--space-sm);
        border-top: 1px solid var(--line-soft);
        margin-top: auto;
    }

    /* Disciplines en petit chip gris */
    .resource-disc-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 7px;
        background: var(--bg-alt);
        border: 1px solid var(--line-soft);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: .04em;
        color: var(--ink-mute);
        border-radius: var(--chip-radius);
    }

    /* Zone disciplines flex wrap */
    .resource-disc-list {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    /* Flèche "Voir" = indicateur interactif */
    .resource-card__arrow {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .06em;
        color: var(--ink);
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* ── État vide ─────────────────────────────────────────────────────── */

    /* L'état vide emprunte le style d'encadré éditoriale du prototype :
       fond bg, bordure ink, centré, avec CTA accent */
    .empty-state {
        border: 1px solid var(--ink);
        padding: var(--space-3xl) var(--space-2xl);
        text-align: center;
        background: var(--bg);
    }

    /* Grand numéro décoratif style "§00" du prototype */
    .empty-state__icon {
        font-family: var(--display);
        font-size: 80px;
        color: var(--ink-mute);
        opacity: .2;
        line-height: 1;
        margin-bottom: var(--space-md);
    }

    .empty-state__title {
        font-family: var(--display);
        font-size: 24px;
        text-transform: uppercase;
        color: var(--ink);
        margin-bottom: var(--space-sm);
    }

    .empty-state__text {
        font-family: var(--body);
        font-size: 14px;
        color: var(--ink-mute);
        line-height: 1.6;
        margin-bottom: var(--space-lg);
    }

    /* Lien CTA dans l'état vide : bouton accent plein */
    .empty-state__cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: var(--btn-padding);
        background: var(--accent);
        color: var(--ink);
        border: 2px solid var(--ink);
        font-family: var(--body);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        text-decoration: none;
        border-radius: var(--btn-radius);
        transition: background var(--transition-fast), color var(--transition-fast);
    }
    .empty-state__cta:hover {
        background: var(--ink);
        color: var(--accent);
    }

    /* ── Pagination ────────────────────────────────────────────────────── */

    /* On surcharge le style par défaut de KnpPaginatorBundle pour le thème Street */
    .pagination-wrap {
        margin-top: var(--space-xl);
        display: flex;
        justify-content: center;
    }

    .pagination-wrap .pagination {
        display: inline-flex;
        border: 1px solid var(--ink);
        list-style: none;
        margin: 0;
        padding: 0;
        gap: 0;
    }

    .pagination-wrap .page-item .page-link {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 40px;
        padding: 0 var(--space-sm);
        border-right: 1px solid var(--ink);
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 700;
        color: var(--ink);
        text-decoration: none;
        background: transparent;
        transition: background var(--transition-fast), color var(--transition-fast);
    }

    .pagination-wrap .page-item:last-child .page-link {
        border-right: none;
    }

    .pagination-wrap .page-item.active .page-link {
        background: var(--ink);
        color: var(--accent);
    }

    .pagination-wrap .page-item .page-link:hover {
        background: var(--accent);
        color: var(--ink);
    }

    .pagination-wrap .page-item.disabled .page-link {
        opacity: .35;
        pointer-events: none;
    }
</style>
{% endblock %}

{% block content %}

{# ── En-tête de page ──────────────────────────────────────────────────────── #}
{#
   L'en-tête reprend le style "section header" du prototype screens-opps.jsx :
   sur-titre eyebrow (point carré + compteur), titre géant, CTA soumettre à droite.
#}
<div class="opp-header">
    <div class="opp-header__row">
        <div>
            <div class="opp-eyebrow">
                Opportunités
                {#
                    On affiche le nombre TOTAL de résultats (variable `total` fournie par le controller),
                    pas juste le nombre sur la page courante.
                    Exemple avec pagination : "24 actives" même si on n'en affiche que 12.
                #}
                {% if total is defined and total > 0 %}
                    · {{ total }} active{{ total > 1 ? 's' : '' }}
                {% endif %}
            </div>
            <h1 class="opp-title">Ce qui est<br>ouvert.</h1>
        </div>

        {# Bouton soumettre : visible à droite du titre #}
        <a href="{{ path('app_resource_submit') }}"
           class="btn-submit-resource"
           title="Proposer une ressource à la communauté">
            {# Signe plus dessiné manuellement en SVG pour cohérence avec les icônes du prototype #}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14"/>
            </svg>
            Soumettre une ressource
        </a>
    </div>
</div>

{# ── Barre de filtres ─────────────────────────────────────────────────────── #}
{#
   Formulaire GET (pas POST) car les filtres doivent être dans l'URL
   pour permettre le partage de lien et la navigation avec le bouton retour.
   Pas de token CSRF nécessaire ici (lecture seule).
#}
<form method="get" action="{{ path('app_resource_index') }}" class="filter-bar" role="search">

    {#
        Champ caché qui force le retour à la page 1 à chaque soumission du formulaire.
        Sans ce champ, si l'utilisateur est sur la page 5 et change un filtre, le
        paramètre "page=5" resterait dans l'URL soumise (via le comportement GET
        qui conserve les champs du formulaire). Le résultat serait souvent vide
        car la page 5 n'existe peut-être pas pour les nouveaux critères.
        En forçant page=1, on repart toujours du début de la liste filtrée.
    #}
    <input type="hidden" name="page" value="1">

    {# Champ recherche textuelle — flex 2x pour prendre plus de place #}
    <div class="filter-group filter-group--search">
        <label class="filter-label" for="q">Recherche</label>
        <input class="filter-input"
               type="text"
               id="q"
               name="q"
               value="{{ currentSearch }}"
               placeholder="Titre, mot-clé, organisateur…"
               autocomplete="off">
    </div>

    {# Select type de ressource #}
    <div class="filter-group">
        <label class="filter-label" for="type">Type</label>
        <select class="filter-select" id="type" name="type">
            <option value="">Tous les types</option>
            {% for type in types %}
                <option value="{{ type.id }}"
                        {{ currentTypeId == type.id ? 'selected' : '' }}>
                    {{ type.icon ? type.icon ~ ' ' : '' }}{{ type.name }}
                </option>
            {% endfor %}
        </select>
    </div>

    {# Select discipline artistique #}
    <div class="filter-group">
        <label class="filter-label" for="discipline">Discipline</label>
        <select class="filter-select" id="discipline" name="discipline">
            <option value="">Toutes les disciplines</option>
            {% for discipline in disciplines %}
                <option value="{{ discipline.id }}"
                        {{ currentDisciplineId == discipline.id ? 'selected' : '' }}>
                    {{ discipline.icon ? discipline.icon ~ ' ' : '' }}{{ discipline.name }}
                </option>
            {% endfor %}
        </select>
    </div>

    {# Boutons action : filtrer + réinitialiser si filtres actifs #}
    <div class="filter-actions">
        <button type="submit" class="btn-filter">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M3 5h18M6 12h12M10 19h4"/>
            </svg>
            Filtrer
        </button>
        {# Lien réinitialiser : visible uniquement quand au moins un filtre est actif #}
        {% if currentSearch or currentTypeId or currentDisciplineId %}
            <a href="{{ path('app_resource_index') }}"
               class="btn-reset-filter"
               title="Effacer tous les filtres">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                    <path d="M6 6l12 12M18 6L6 18"/>
                </svg>
                Effacer
            </a>
        {% endif %}
    </div>

</form>

{# ── Résultats ────────────────────────────────────────────────────────────── #}
{% if resources is empty %}

    {# ── État vide ── #}
    {# Deux cas : filtre sans résultat, ou catalogue vide #}
    <div class="empty-state">
        {# Numéro décoratif style éditorial = esthétique caractéristique du thème Street #}
        <div class="empty-state__icon">00</div>

        {% if currentSearch or currentTypeId or currentDisciplineId %}
            <div class="empty-state__title">Aucun résultat</div>
            <p class="empty-state__text">
                Aucune ressource ne correspond à vos critères de recherche.<br>
                Essayez avec des mots-clés différents ou élargissez les filtres.
            </p>
            <a href="{{ path('app_resource_index') }}" class="empty-state__cta">
                Voir toutes les ressources
            </a>
        {% else %}
            <div class="empty-state__title">Pas encore de ressources</div>
            <p class="empty-state__text">
                Le catalogue est vide pour l'instant.<br>
                Soyez le premier à partager une opportunité avec la communauté.
            </p>
            <a href="{{ path('app_resource_submit') }}" class="empty-state__cta">
                Soumettre une ressource
            </a>
        {% endif %}
    </div>

{% else %}

    {#
        Compteur de résultats sous les filtres (mono uppercase = logique éditorial).
        On affiche le total global (pas juste les 12 de la page courante)
        + l'indication de pagination si on n'est pas sur la page 1.
    #}
    <p class="results-count">
        → {{ total }} résultat{{ total > 1 ? 's' : '' }}
        {# Indication des filtres textuels actifs #}
        {% if currentSearch %} · "{{ currentSearch }}"{% endif %}
        {# Indication de la page courante si on est en pagination (plus d'une page) #}
        {% if totalPages > 1 %} · page {{ currentPage }}/{{ totalPages }}{% endif %}
    </p>

    {# ── Grille de cartes ── #}
    <div class="resource-grid">
        {% for resource in resources %}
            <a href="{{ path('app_resource_show', {id: resource.id}) }}"
               class="resource-card"
               aria-label="Voir {{ resource.title }}">

                {# ── Ligne badge type + deadline ── #}
                <div class="resource-card__top">

                    {# Badge type : fond encre foncé, texte crème = chip "dark" du design system #}
                    <span class="resource-badge-type">
                        {{ resource.resourceType.icon ? resource.resourceType.icon ~ ' ' : '' }}{{ resource.resourceType.name }}
                    </span>

                    {# Deadline : affiché en compact si disponible #}
                    {% if resource.deadline %}
                        {% set daysLeft = (resource.deadline.timestamp - "now"|date('U')) // 86400 %}
                        {% if daysLeft >= 0 %}
                            <span class="resource-badge-deadline {{ daysLeft < 14 ? 'resource-badge-deadline--urgent' : '' }}">
                                {# Icône sablier SVG — plus propre qu'un emoji #}
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                                    <path d="M5 3h14M5 21h14M7 3v4l5 5-5 5v4M17 3v4l-5 5 5 5v4"/>
                                </svg>
                                {% if daysLeft == 0 %}
                                    Aujourd'hui !
                                {% elseif daysLeft == 1 %}
                                    J-1
                                {% else %}
                                    J-{{ daysLeft }}
                                {% endif %}
                            </span>
                        {% endif %}
                    {% endif %}
                </div>

                {# Organisation soumettrice (si disponible) #}
                {% if resource.organization %}
                    <div class="resource-card__meta">
                        {{ resource.organization.name }}
                    </div>
                {% endif %}

                {# Titre de la ressource : display, 3 lignes max #}
                <h2 class="resource-card__title">{{ resource.title }}</h2>

                {# Description tronquée à 150 caractères environ (clip CSS) #}
                <p class="resource-card__desc">
                    {{ resource.description|slice(0, 160) }}{{ resource.description|length > 160 ? '…' : '' }}
                </p>

                {# Pied de carte : disciplines + flèche Voir #}
                <div class="resource-card__footer">
                    <div class="resource-disc-list">
                        {% for discipline in resource.disciplines|slice(0, 2) %}
                            <span class="resource-disc-chip">
                                {{ discipline.icon ? discipline.icon ~ ' ' : '' }}{{ discipline.name }}
                            </span>
                        {% endfor %}
                        {# Si plus de 2 disciplines : indicateur "+N" #}
                        {% if resource.disciplines|length > 2 %}
                            <span class="resource-disc-chip">+{{ resource.disciplines|length - 2 }}</span>
                        {% endif %}
                    </div>
                    {# Flèche indicateur de navigation #}
                    <span class="resource-card__arrow" aria-hidden="true">Voir →</span>
                </div>

            </a>
        {% endfor %}
    </div>

    {#
        ── Bloc de pagination ──────────────────────────────────────────────────────
        Affiché uniquement quand il y a plus d'une page (totalPages > 1).
        Chaque lien PRÉSERVE les filtres actifs (type, discipline, q) pour que
        naviguer entre les pages ne réinitialise pas la recherche.

        Architecture des URL générées (exemple avec filtres) :
          /resources?type=2&discipline=4&q=musique&page=3

        Si un filtre est null ou vide, on ne l'inclut pas dans le path() pour éviter
        les paramètres vides (?type=&discipline=) qui polluent l'URL.

        Fenêtre de pages affichées :
          On affiche au maximum 5 numéros de page autour de la page courante.
          Cela évite d'afficher 50 boutons si le catalogue est très grand.
          Algorithme : fenêtre de 2 avant + 2 après = 5 pages au total, bornée entre 1 et totalPages.

        Styles : on réutilise les classes .pagination-wrap / .pagination / .page-item / .page-link
        déjà définies dans le bloc <style> ci-dessus — aucune nouvelle règle CSS nécessaire.
    #}
    {% if totalPages > 1 %}

        {#
            Calcul de la fenêtre de pagination (pages visibles autour de la courante).
            max() et min() sont des filtres Twig natifs — pas de dépendance supplémentaire.
            windowStart = première page de la fenêtre (au moins 1)
            windowEnd   = dernière page de la fenêtre (au plus totalPages)
        #}
        {% set windowStart = max(1, currentPage - 2) %}
        {% set windowEnd   = min(totalPages, currentPage + 2) %}

        {#
            Construction du tableau de paramètres de base (filtres actifs).
            On inclut un paramètre seulement s'il a une valeur non-vide,
            pour garder des URLs propres : /resources?page=2 et non /resources?type=&discipline=&q=&page=2
        #}
        {% set baseParams = {} %}
        {% if currentTypeId %}
            {% set baseParams = baseParams|merge({ type: currentTypeId }) %}
        {% endif %}
        {% if currentDisciplineId %}
            {% set baseParams = baseParams|merge({ discipline: currentDisciplineId }) %}
        {% endif %}
        {% if currentSearch %}
            {% set baseParams = baseParams|merge({ q: currentSearch }) %}
        {% endif %}

        <nav class="pagination-wrap" aria-label="Navigation entre les pages de ressources">
            <ul class="pagination">

                {# ── Lien "Précédent" ────────────────────────────────────────── #}
                {# Désactivé sur la page 1 (attribut aria-disabled + classe CSS disabled) #}
                <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                    {% if currentPage > 1 %}
                        {# On fusionne les filtres de base avec la page précédente #}
                        <a class="page-link"
                           href="{{ path('app_resource_index', baseParams|merge({ page: currentPage - 1 })) }}"
                           aria-label="Page précédente">
                            ← Préc.
                        </a>
                    {% else %}
                        {# Span non-cliquable sur la page 1 (pas de lien vers page 0) #}
                        <span class="page-link" aria-hidden="true">← Préc.</span>
                    {% endif %}
                </li>

                {# ── Points de suspension au début si la fenêtre ne commence pas à 1 ── #}
                {# Exemple : si on est sur la page 8, la fenêtre commence à 6 → on affiche 1 … 6 7 8 9 10 #}
                {% if windowStart > 1 %}
                    <li class="page-item">
                        <a class="page-link"
                           href="{{ path('app_resource_index', baseParams|merge({ page: 1 })) }}"
                           aria-label="Page 1">
                            1
                        </a>
                    </li>
                    {% if windowStart > 2 %}
                        {# "…" non-cliquable pour indiquer qu'il y a des pages cachées #}
                        <li class="page-item disabled" aria-hidden="true">
                            <span class="page-link">…</span>
                        </li>
                    {% endif %}
                {% endif %}

                {# ── Numéros de page dans la fenêtre ────────────────────────── #}
                {% for p in windowStart..windowEnd %}
                    <li class="page-item {% if p == currentPage %}active{% endif %}">
                        {% if p == currentPage %}
                            {# Page courante : non-cliquable, mise en valeur visuellement #}
                            {# aria-current="page" = information d'accessibilité pour les lecteurs d'écran #}
                            <span class="page-link" aria-current="page">{{ p }}</span>
                        {% else %}
                            <a class="page-link"
                               href="{{ path('app_resource_index', baseParams|merge({ page: p })) }}"
                               aria-label="Page {{ p }}">
                                {{ p }}
                            </a>
                        {% endif %}
                    </li>
                {% endfor %}

                {# ── Points de suspension à la fin si la fenêtre ne finit pas à totalPages ── #}
                {% if windowEnd < totalPages %}
                    {% if windowEnd < totalPages - 1 %}
                        <li class="page-item disabled" aria-hidden="true">
                            <span class="page-link">…</span>
                        </li>
                    {% endif %}
                    <li class="page-item">
                        <a class="page-link"
                           href="{{ path('app_resource_index', baseParams|merge({ page: totalPages })) }}"
                           aria-label="Page {{ totalPages }}">
                            {{ totalPages }}
                        </a>
                    </li>
                {% endif %}

                {# ── Lien "Suivant" ──────────────────────────────────────────── #}
                {# Désactivé sur la dernière page #}
                <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                    {% if currentPage < totalPages %}
                        <a class="page-link"
                           href="{{ path('app_resource_index', baseParams|merge({ page: currentPage + 1 })) }}"
                           aria-label="Page suivante">
                            Suiv. →
                        </a>
                    {% else %}
                        <span class="page-link" aria-hidden="true">Suiv. →</span>
                    {% endif %}
                </li>

            </ul>
        </nav>

    {% endif %}
    {# ── Fin bloc pagination ─────────────────────────────────────────────────── #}

{% endif %}

{% endblock %}
