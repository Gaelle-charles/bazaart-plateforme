{% extends 'base_app.html.twig' %}

{#
 # resource/alerts.html.twig — Préférences d'alertes email
 #
 # Thème : Street (app connectée)
 # Layout : centré max 640px, formulaire en sections
 # Référence : patterns de formulaire du prototype (style guides ui.jsx) +
 #             sections de paramètres du dashboard artiste (screens-dash.jsx)
 #
 # Variables Twig disponibles :
 #   disciplines — tableau de Discipline (pour les checkboxes)
 #   types       — tableau de ResourceType (pour les checkboxes)
 #   alert       — entité ResourceAlert|null (null = pas encore de préférences enregistrées)
 #}

{% block title %}Alertes ressources — Bazaart{% endblock %}
{% block page_title %}Alertes ressources{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ═══════════════════════════════════════════════════════════════════════
       ALERTES RESSOURCES — styles thème Street
       Formulaire de préférences centré, max 640px.
       Sections avec en-tête encre + corps crème — pattern identique à submit.html.twig.
    ═══════════════════════════════════════════════════════════════════════ */

    /* ── Conteneur centré ──────────────────────────────────────────────── */

    /* Largeur plus étroite que submit (formulaire moins dense = 640px) */
    .alerts-wrap {
        max-width: 640px;
    }

    /* ── En-tête de page ──────────────────────────────────────────────── */

    .alerts-header {
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 1px solid var(--ink);
    }

    /* Eyebrow au-dessus du titre */
    .alerts-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--ink-mute);
        margin-bottom: var(--space-xs);
    }
    .alerts-eyebrow::before {
        content: '';
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--accent);
    }

    /* Titre de page */
    .alerts-title {
        font-family: var(--display);
        font-size: clamp(28px, 4vw, 48px);
        text-transform: uppercase;
        line-height: .92;
        color: var(--ink);
        margin: 0 0 var(--space-sm);
    }

    /* Chapeau explicatif sous le titre */
    .alerts-desc {
        font-family: var(--serif);
        font-style: italic;
        font-size: 15px;
        color: var(--ink-mute);
        line-height: 1.55;
        border-left: 3px solid var(--accent);
        padding-left: var(--space-md);
        margin: var(--space-md) 0 0;
    }

    /* ── Bannière "alerte déjà configurée" ─────────────────────────────── */

    /* Encadré vert discret indiquant que des alertes sont actives.
       Fond bg-alt + bordure accent = confirmation positive */
    .alert-active-banner {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        background: var(--bg-alt);
        border: 1px solid var(--ink);
        border-left: 4px solid var(--accent);
        margin-bottom: var(--space-xl);
        font-family: var(--body);
        font-size: 13px;
        color: var(--ink);
    }

    /* Icône cloche dans la bannière */
    .alert-active-banner__icon {
        color: var(--accent-2);
        flex-shrink: 0;
    }

    /* ── Sections de formulaire ────────────────────────────────────────── */

    /* Identiques à submit.html.twig : bordure ink, en-tête encre, corps crème */
    .form-section {
        border: 1px solid var(--ink);
        margin-bottom: var(--space-md);
        background: var(--bg);
    }

    .form-section__header {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: var(--space-sm) var(--space-lg);
        background: var(--ink);
        color: var(--accent);
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
    }

    .form-section__num {
        font-family: var(--display);
        font-size: 18px;
        color: rgba(198, 242, 78, .4);
        margin-right: 2px;
    }

    .form-section__body {
        padding: var(--space-xl);
    }

    /* ── Toggle "Activer les alertes" ──────────────────────────────────── */

    /* Rangée avec la grande checkbox et son texte explicatif.
       Style "toggle-row" inspiré du dashboard artiste (mode privé/public). */
    .toggle-row {
        display: flex;
        align-items: flex-start;
        gap: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        background: var(--bg-alt);
        border: 1px solid var(--line-soft);
        cursor: pointer;
        transition: border-color var(--transition-fast);
    }
    .toggle-row:hover { border-color: var(--ink); }
    .toggle-row:has(input:checked) {
        border-color: var(--accent);
        border-left: 4px solid var(--accent);
        background: var(--bg);
    }

    /* La checkbox native est agrandie mais on garde son apparence native
       pour l'accessibilité (accent-color) */
    .toggle-row input[type="checkbox"] {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        margin-top: 2px;
        cursor: pointer;
        accent-color: var(--accent);
    }

    .toggle-text__title {
        font-family: var(--body);
        font-size: 14px;
        font-weight: 700;
        color: var(--ink);
        cursor: pointer;
    }

    .toggle-text__desc {
        font-family: var(--body);
        font-size: 12px;
        color: var(--ink-mute);
        line-height: 1.5;
        margin-top: 3px;
    }

    /* ── Select de fréquence ───────────────────────────────────────────── */

    /* Label section */
    .field-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--ink-mute);
        display: block;
        margin-bottom: var(--space-sm);
    }

    /* Select pleine largeur, bords francs */
    .field-select {
        width: 100%;
        padding: var(--input-padding);
        background: var(--input-bg);
        border: var(--input-border);
        border-radius: var(--input-radius);
        font-family: var(--body);
        font-size: var(--input-font-size);
        color: var(--ink);
        outline: none;
        transition: border var(--transition-fast);
        cursor: pointer;
        box-sizing: border-box;
    }
    .field-select:focus { border: var(--input-border-focus); }

    {#
       Alternative "radio buttons" sous forme de pills :
       plus tactile et lisible que un select déroulant pour 3 options.
       On reprend le pattern toggle de la topbar du dashboard (vue privée/publique).
    #}

    /* Groupe de radio-boutons style segmented control */
    .radio-group {
        display: flex;
        border: 1px solid var(--ink);
        gap: 0;
    }

    .radio-option {
        flex: 1;
        position: relative;
    }

    /* Input radio caché — l'aspect visuel vient du label */
    .radio-option input[type="radio"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    /* Label comme bouton */
    .radio-option label {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        padding: var(--space-md) var(--space-sm);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--ink-mute);
        cursor: pointer;
        border-right: 1px solid var(--ink);
        background: transparent;
        transition: background var(--transition-fast), color var(--transition-fast);
        text-align: center;
        line-height: 1.3;
    }
    .radio-option:last-child label { border-right: none; }

    /* Option sélectionnée : fond encre, texte accent */
    .radio-option input[type="radio"]:checked + label {
        background: var(--ink);
        color: var(--accent);
    }

    .radio-option label:hover {
        background: var(--bg-alt);
        color: var(--ink);
    }

    /* Sous-texte dans le radio (description de la fréquence) */
    .radio-desc {
        font-weight: 400;
        font-size: 9px;
        letter-spacing: .02em;
        opacity: .7;
        text-transform: none;
        margin-top: 2px;
    }

    /* ── Grille de checkboxes (disciplines / types) ─────────────────────── */

    /* Identique à submit.html.twig */
    .checkboxes-grid {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .checkbox-chip {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        padding: 6px 12px;
        border: 1px solid var(--line-soft);
        background: var(--bg);
        color: var(--ink-mute);
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .04em;
        cursor: pointer;
        transition: all var(--transition-fast);
        user-select: none;
    }

    .checkbox-chip:hover {
        border-color: var(--ink);
        color: var(--ink);
    }

    /* Coché = fond accent vert */
    .checkbox-chip:has(input:checked) {
        background: var(--accent);
        border-color: var(--ink);
        color: var(--ink);
        font-weight: 700;
    }

    /* Checkbox native masquée */
    .checkbox-chip input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    /* Indication "tous cochés = aucun filtre" */
    .field-hint {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--ink-mute);
        letter-spacing: .04em;
        margin-bottom: var(--space-md);
        display: block;
    }

    /* ── Bouton sauvegarder ────────────────────────────────────────────── */

    /* Bouton plein accent, pleine largeur */
    .btn-save {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-sm);
        width: 100%;
        padding: 16px var(--space-xl);
        background: var(--accent);
        color: var(--ink);
        border: 2px solid var(--ink);
        font-family: var(--body);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: var(--btn-radius);
        transition: background var(--transition-fast), color var(--transition-fast);
    }
    .btn-save:hover {
        background: var(--ink);
        color: var(--accent);
    }

    /* Mention "dernière alerte envoyée" sous le bouton */
    .last-sent {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        letter-spacing: .04em;
        text-align: center;
        margin-top: var(--space-md);
    }
</style>
{% endblock %}

{% block content %}
<div class="alerts-wrap">

    {# ── En-tête ── #}
    <div class="alerts-header">
        <div class="alerts-eyebrow">Mon espace</div>
        <h1 class="alerts-title">Alertes ressources</h1>
        <p class="alerts-desc">
            Reçois les nouvelles opportunités par email, filtrées selon tes préférences artistiques.
        </p>
    </div>

    {# ── Bannière "alertes actives" ── #}
    {#
       Si l'utilisateur a déjà configuré des alertes, on lui montre un récap.
       Cela évite de devoir ouvrir le formulaire pour savoir si les alertes sont actives.
    #}
    {% if alert is not null and alert.notifyOnNewResource %}
        <div class="alert-active-banner">
            {# Icône cloche SVG #}
            <div class="alert-active-banner__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M6 8a6 6 0 1 1 12 0c0 5 2 6 2 6H4s2-1 2-6"/>
                    <path d="M10 18a2 2 0 0 0 4 0"/>
                </svg>
            </div>
            <div>
                <strong>Alertes activées</strong> ·
                {# Affichage de la fréquence actuelle en texte clair.
                   Les trois cas sont tous explicites : plus facile à maintenir et à déboguer. #}
                {% if alert.frequency.value == 'immediate' %}
                    dès qu'une nouvelle opportunité est publiée
                {% elseif alert.frequency.value == 'daily' %}
                    récapitulatif chaque matin
                {% elseif alert.frequency.value == 'weekly' %}
                    récapitulatif chaque lundi
                {% else %}
                    {# Valeur d'enum inconnue — ne devrait pas arriver, mais on affiche la valeur brute par sécurité #}
                    fréquence : {{ alert.frequency.value }}
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# ── Formulaire de préférences ── #}
    {#
       Action POST vers la même route (pattern PRG).
       Token CSRF pour la sécurité (attaques cross-site).
    #}
    <form method="post" action="{{ path('app_resource_alerts') }}" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('resource_alerts') }}">

        {# ── SECTION 1 : Activation des alertes ── #}
        <div class="form-section">
            <div class="form-section__header">
                <span class="form-section__num">01</span>
                Activation
            </div>
            <div class="form-section__body">
                {#
                   Toggle "Activer / désactiver" les alertes.
                   Par défaut activé si l'entité alert n'existe pas encore.
                   Quand la checkbox est cochée, le label change visuellement (border-left accent).
                #}
                <label class="toggle-row" for="notifyOnNewResource">
                    <input type="checkbox"
                           id="notifyOnNewResource"
                           name="notifyOnNewResource"
                           value="1"
                           {{ (alert is null or alert.notifyOnNewResource) ? 'checked' : '' }}>
                    <div>
                        <div class="toggle-text__title">Recevoir des alertes par email</div>
                        <div class="toggle-text__desc">
                            Tu seras notifié·e selon la fréquence choisie ci-dessous.
                            Décoche pour mettre en pause sans perdre tes préférences.
                        </div>
                    </div>
                </label>
            </div>
        </div>

        {# ── SECTION 2 : Fréquence d'envoi ── #}
        <div class="form-section">
            <div class="form-section__header">
                <span class="form-section__num">02</span>
                Fréquence
            </div>
            <div class="form-section__body">
                {#
                   3 options de fréquence sous forme de segmented control.
                   Les valeurs correspondent à l'enum AlertFrequency côté PHP.
                   On liste les 3 valeurs en dur car les enums changent rarement
                   et ne sont pas accessibles directement en Twig sans extension.

                   currentFrequency : valeur string backed de l'enum ('immediate'|'daily'|'weekly')
                #}
                {% set currentFrequency = alert is not null ? alert.frequency.value : 'daily' %}

                <div class="radio-group" role="radiogroup" aria-label="Fréquence des alertes">

                    {# Option Immédiate #}
                    <div class="radio-option">
                        <input type="radio"
                               id="freq_immediate"
                               name="frequency"
                               value="immediate"
                               {{ currentFrequency == 'immediate' ? 'checked' : '' }}>
                        <label for="freq_immediate">
                            Immédiate
                            <span class="radio-desc">Dès la publication</span>
                        </label>
                    </div>

                    {# Option Quotidienne (défaut) #}
                    <div class="radio-option">
                        <input type="radio"
                               id="freq_daily"
                               name="frequency"
                               value="daily"
                               {{ currentFrequency == 'daily' ? 'checked' : '' }}>
                        <label for="freq_daily">
                            Quotidienne
                            <span class="radio-desc">Résumé le matin</span>
                        </label>
                    </div>

                    {# Option Hebdomadaire #}
                    <div class="radio-option">
                        <input type="radio"
                               id="freq_weekly"
                               name="frequency"
                               value="weekly"
                               {{ currentFrequency == 'weekly' ? 'checked' : '' }}>
                        <label for="freq_weekly">
                            Hebdomadaire
                            <span class="radio-desc">Résumé le lundi</span>
                        </label>
                    </div>

                </div>

            </div>
        </div>

        {# ── SECTION 3 : Filtrer par discipline ── #}
        <div class="form-section">
            <div class="form-section__header">
                <span class="form-section__num">03</span>
                Disciplines (optionnel)
            </div>
            <div class="form-section__body">

                <span class="field-hint">
                    Laisse tout décoché pour recevoir des alertes toutes disciplines confondues.
                </span>

                {% if disciplines is empty %}
                    {# Cas rare : aucune discipline en base — message discret #}
                    <p style="font-family:var(--body); font-size:13px; color:var(--ink-mute);">
                        Aucune discipline disponible pour l'instant.
                    </p>
                {% else %}
                    <div class="checkboxes-grid">
                        {% for discipline in disciplines %}
                            {#
                               On vérifie si cette discipline est dans les filtres de l'alerte.
                               alert.filterDisciplines retourne une Collection Doctrine
                               → on utilise .contains() qui compare par identité d'entité.
                            #}
                            {% set isChecked = alert is not null and alert.filterDisciplines.contains(discipline) %}
                            <label class="checkbox-chip"
                                   for="disc_{{ discipline.id }}"
                                   title="{{ discipline.name }}">
                                <input type="checkbox"
                                       id="disc_{{ discipline.id }}"
                                       name="filterDisciplines[]"
                                       value="{{ discipline.id }}"
                                       {{ isChecked ? 'checked' : '' }}>
                                {{ discipline.icon ? discipline.icon ~ ' ' : '' }}{{ discipline.name }}
                            </label>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>

        {# ── SECTION 4 : Filtrer par type de ressource ── #}
        <div class="form-section">
            <div class="form-section__header">
                <span class="form-section__num">04</span>
                Types de ressources (optionnel)
            </div>
            <div class="form-section__body">

                <span class="field-hint">
                    Laisse tout décoché pour être alerté·e de tous les types d'opportunités.
                </span>

                {% if types is empty %}
                    <p style="font-family:var(--body); font-size:13px; color:var(--ink-mute);">
                        Aucun type de ressource disponible pour l'instant.
                    </p>
                {% else %}
                    <div class="checkboxes-grid">
                        {% for type in types %}
                            {#
                               Même logique que pour les disciplines :
                               alert.filterResourceTypes.contains() teste la présence de l'entité.
                            #}
                            {% set isChecked = alert is not null and alert.filterResourceTypes.contains(type) %}
                            <label class="checkbox-chip"
                                   for="type_{{ type.id }}"
                                   title="{{ type.name }}">
                                <input type="checkbox"
                                       id="type_{{ type.id }}"
                                       name="filterResourceTypes[]"
                                       value="{{ type.id }}"
                                       {{ isChecked ? 'checked' : '' }}>
                                {{ type.icon ? type.icon ~ ' ' : '' }}{{ type.name }}
                            </label>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>

        {# ── Bouton sauvegarder ── #}
        {#
           Pleine largeur + font grande = action principale de la page.
           Feedback immédiat : fond lime, hover encre. Pas de doute sur l'action.
        #}
        <div style="margin-top: var(--space-lg);">
            <button type="submit" class="btn-save">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                    <path d="m5 12 5 5L20 7"/>
                </svg>
                Enregistrer mes préférences
            </button>

            {# ── Date de dernière mise à jour ── #}
            {#
               Affiché uniquement si l'entité alert existe (préférences déjà enregistrées).
               updatedAt peut être un DateTimeInterface — on le formate avec le filtre date().
            #}
            {% if alert is not null %}
                <p class="last-sent">
                    Dernière mise à jour : {{ alert.updatedAt|date('d/m/Y à H:i') }}
                </p>
            {% endif %}
        </div>

    </form>

</div>
{% endblock %}
