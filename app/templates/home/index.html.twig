{% extends 'base.html.twig' %}

{#
 # home/index.html.twig — Page d'accueil publique de BazaArt
 #
 # Accessible sans être connecté.
 # Structure :
 #  1. Navbar publique (logo + liens + boutons connexion/inscription)
 #  2. Section hero (titre, description, boutons CTA, cartes flottantes)
 #  3. Section chiffres (stats)
 #  4. Section fonctionnalités (3 cartes)
 #  5. Footer
 #}

{% block title %}BazaArt — La plateforme des artistes francophones{% endblock %}

{% block stylesheets %}
<style>
    /* ── Page d'accueil : fond beige global ── */
    body { background: var(--color-bg); }

    /* ════════════════════════════════════════
     * NAVBAR
     * ════════════════════════════════════════ */
    .navbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--color-white);
        border-bottom: 1px solid var(--color-border);
        height: 68px;
        display: flex;
        align-items: center;
        padding: 0 60px;
        gap: 40px;
    }

    .navbar__brand {
        font-family: var(--font-heading);
        font-size: 22px;
        font-weight: 700;
        color: var(--color-green);
        text-decoration: none;
        margin-right: 20px;
    }

    /* Liens de navigation du milieu */
    .navbar__links {
        display: flex;
        gap: 36px;
        flex: 1;
    }
    .navbar__links a {
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.15s;
    }
    .navbar__links a:hover { color: var(--color-text); }

    /* Boutons à droite */
    .navbar__actions {
        display: flex;
        gap: 12px;
        margin-left: auto;
    }

    /* ════════════════════════════════════════
     * SECTION HERO
     * ════════════════════════════════════════ */
    .hero {
        background: var(--color-bg);
        padding: 60px 60px 0;
        min-height: 428px;
        display: flex;
        align-items: flex-start;
        position: relative;
        overflow: hidden;
    }

    /* Colonne gauche : texte */
    .hero__left { max-width: 580px; }

    /* Badge "Plateforme des artistes francophones" */
    .hero__badge {
        display: inline-flex;
        align-items: center;
        height: 28px;
        padding: 0 13px;
        background: var(--color-red-light);
        border: 1px solid var(--color-orange);
        border-radius: var(--radius-full);
        font-size: 10px;
        font-weight: 600;
        color: var(--color-red);
        margin-bottom: 24px;
    }

    /* Titre principal */
    .hero__title {
        font-family: var(--font-heading);
        font-size: 46px;
        font-weight: 700;
        color: var(--color-green);
        line-height: 1.15;
        margin-bottom: 20px;
    }

    /* Sous-titre */
    .hero__desc {
        font-size: 14px;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: 28px;
        max-width: 500px;
    }

    /* Boutons CTA */
    .hero__actions {
        display: flex;
        gap: 14px;
        margin-bottom: 36px;
    }

    /* Colonne droite : aperçu de cartes flottantes */
    .hero__cards {
        position: absolute;
        right: 60px;
        top: 36px;
        width: 580px;
        height: 360px;
    }

    /* Chaque carte aperçu */
    .preview-card {
        position: absolute;
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-card);
        padding: 15px;
    }

    .preview-card__badge {
        display: inline-flex;
        align-items: center;
        height: 22px;
        padding: 0 8px;
        border-radius: var(--radius-full);
        font-size: 10px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .preview-card__title {
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 4px;
    }

    .preview-card__meta {
        font-size: 11px;
        color: var(--color-text-light);
        margin-bottom: 2px;
    }

    .preview-card__separator {
        height: 1px;
        background: var(--color-border);
        margin: 12px 0 8px;
    }

    .preview-card__disciplines {
        font-size: 10px;
        color: var(--color-text-light);
    }

    /* ════════════════════════════════════════
     * SECTION STATISTIQUES
     * ════════════════════════════════════════ */
    .stats {
        background: var(--color-bg);
        border-top: 1px solid var(--color-border);
        padding: 28px 60px;
        display: flex;
        gap: 0;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        padding-right: 40px;
        margin-right: 40px;
        border-right: 1px solid var(--color-border);
    }
    .stat-item:last-child {
        border-right: none;
        margin-right: 0;
        padding-right: 0;
    }

    .stat-item__number {
        font-size: 22px;
        font-weight: 700;
        color: var(--color-text);
    }
    .stat-item__label {
        font-size: 11px;
        color: var(--color-text-light);
        margin-top: 2px;
    }

    /* ════════════════════════════════════════
     * SECTION FONCTIONNALITÉS
     * ════════════════════════════════════════ */
    .features {
        background: var(--color-white);
        border-top: 1px solid var(--color-border);
        padding: 50px 60px;
    }

    .features__title {
        font-family: var(--font-heading);
        font-size: 26px;
        font-weight: 700;
        color: var(--color-text);
        text-align: center;
        margin-bottom: 32px;
    }

    .features__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .feature-card {
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-card);
        padding: 19px;
    }

    /* Icône colorée en haut de la carte */
    .feature-card__icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        margin-bottom: 18px;
    }

    .feature-card__category {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .feature-card__title {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 8px;
    }

    .feature-card__desc {
        font-size: 12px;
        color: var(--color-text-muted);
        line-height: 1.5;
    }

    /* ════════════════════════════════════════
     * FOOTER
     * ════════════════════════════════════════ */
    .footer {
        background: var(--color-green);
        padding: 30px 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .footer__brand {
        font-family: var(--font-heading);
        font-size: 18px;
        font-weight: 700;
        color: var(--color-white);
        margin-bottom: 6px;
    }

    .footer__tagline {
        font-size: 11px;
        color: var(--color-text-green);
    }

    .footer__copy {
        font-size: 10px;
        color: var(--color-text-green);
        margin-top: 4px;
    }

    .footer__links {
        display: flex;
        gap: 24px;
    }
    .footer__links a {
        font-size: 11px;
        color: var(--color-text-green);
        text-decoration: none;
        transition: color 0.15s;
    }
    .footer__links a:hover { color: var(--color-white); }
</style>
{% endblock %}

{% block body %}

{# ── NAVBAR ──────────────────────────────────────────────────────────────── #}
<nav class="navbar">
    <a href="{{ path('app_home') }}" class="navbar__brand">BazaArt</a>

    <div class="navbar__links">
        <a href="{{ path('app_resource_index') }}">Ressources</a>
        <a href="#">Événements</a>
        <a href="{{ path('app_post_feed') }}">Communauté</a>
        <a href="{{ path('app_article_index') }}">Articles</a>
    </div>

    <div class="navbar__actions">
        <a href="{{ path('app_login') }}" class="btn btn-outline">Se connecter</a>
        <a href="{{ path('app_register') }}" class="btn btn-primary">Rejoindre</a>
    </div>
</nav>

{# ── HERO ────────────────────────────────────────────────────────────────── #}
<section class="hero">

    {# Texte principal #}
    <div class="hero__left">
        <div class="hero__badge">Plateforme des artistes francophones</div>

        <h1 class="hero__title">
            Trouvez vos financements,<br>
            résidences et opportunités
        </h1>

        <p class="hero__desc">
            BazaArt centralise les ressources, appels à projets,<br>
            événements et réseau pour les artistes francophones.
        </p>

        <div class="hero__actions">
            <a href="{{ path('app_register') }}" class="btn btn-primary">Commencer gratuitement</a>
            <a href="{{ path('app_resource_index') }}" class="btn btn-outline">Voir les ressources</a>
        </div>
    </div>

    {# Cartes flottantes — aperçu des ressources disponibles #}
    <div class="hero__cards">
        {# Carte Bourse #}
        <div class="preview-card" style="width: 320px; left: 0; top: 0;">
            <div class="preview-card__badge" style="background: var(--color-red-light); color: var(--color-red);">
                Bourse
            </div>
            <div class="preview-card__title">Bourse de création — DRAC</div>
            <div class="preview-card__meta">Jusqu'au 15 avril 2026</div>
            <div class="preview-card__meta">Île-de-France</div>
            <div class="preview-card__separator"></div>
            <div class="preview-card__disciplines">Arts visuels · Pluridisciplinaire</div>
        </div>

        {# Carte Résidence #}
        <div class="preview-card" style="width: 320px; right: 0; top: 46px;">
            <div class="preview-card__badge" style="background: var(--color-green-light); color: var(--color-green);">
                Résidence
            </div>
            <div class="preview-card__title">Résidence Villa Médicis — Rome</div>
            <div class="preview-card__meta">Jusqu'au 30 mars 2026</div>
            <div class="preview-card__meta">International</div>
            <div class="preview-card__separator"></div>
            <div class="preview-card__disciplines">Littérature · Arts visuels</div>
        </div>

        {# Carte Appel à projets #}
        <div class="preview-card" style="width: 364px; left: 40px; top: 168px;">
            <div class="preview-card__badge" style="background: var(--color-orange-light); color: var(--color-orange);">
                Appel à projets
            </div>
            <div class="preview-card__title">Appel à projets — Ville de Lyon</div>
            <div class="preview-card__meta">Clôture le 28 février 2026 · Lyon</div>
            <div class="preview-card__separator" style="margin-bottom: 6px;"></div>
            <div class="preview-card__disciplines">Théâtre · Danse · Musique</div>
        </div>

        {# Notification nouveau membre #}
        <div class="preview-card" style="width: 288px; right: 0; top: 216px; padding: 11px 15px;">
            <div style="font-size: 10px; color: var(--color-text-light); margin-bottom: 4px;">Nouveau membre</div>
            <div style="font-size: 12px; font-weight: 600; color: var(--color-text); margin-bottom: 6px;">
                Marie C. a rejoint la communauté
            </div>
            <div style="font-size: 10px; color: var(--color-text-light);">Il y a 2 minutes</div>
        </div>
    </div>

</section>

{# ── STATISTIQUES ────────────────────────────────────────────────────────── #}
<div class="stats">
    <div class="stat-item">
        <span class="stat-item__number">247</span>
        <span class="stat-item__label">ressources</span>
    </div>
    <div class="stat-item">
        <span class="stat-item__number">1 842</span>
        <span class="stat-item__label">artistes</span>
    </div>
    <div class="stat-item">
        <span class="stat-item__number">93</span>
        <span class="stat-item__label">articles</span>
    </div>
</div>

{# ── FONCTIONNALITÉS ─────────────────────────────────────────────────────── #}
<section class="features">
    <h2 class="features__title">Tout ce dont vous avez besoin</h2>

    <div class="features__grid">

        {# Carte Ressources #}
        <div class="feature-card">
            <div class="feature-card__icon" style="background: var(--color-red-light);"></div>
            <div class="feature-card__category" style="color: var(--color-red);">Ressources</div>
            <div class="feature-card__title">Financements &amp; résidences</div>
            <p class="feature-card__desc">
                Bourses, appels à projets, résidences artistiques — tout centralisé en un seul endroit.
            </p>
        </div>

        {# Carte Communauté #}
        <div class="feature-card">
            <div class="feature-card__icon" style="background: var(--color-green-light);"></div>
            <div class="feature-card__category" style="color: var(--color-green);">Communauté</div>
            <div class="feature-card__title">Réseau &amp; communauté</div>
            <p class="feature-card__desc">
                Rencontrez des artistes, partagez vos projets, échangez et lisez des articles de fond.
            </p>
        </div>

        {# Carte Événements #}
        <div class="feature-card">
            <div class="feature-card__icon" style="background: #f2f0eb;"></div>
            <div class="feature-card__category" style="color: var(--color-text-muted);">Événements</div>
            <div class="feature-card__title">Agenda culturel</div>
            <p class="feature-card__desc">
                Concerts, expositions, festivals, ateliers — ne ratez plus aucune occasion de vous exprimer.
            </p>
        </div>

    </div>
</section>

{# ── FOOTER ──────────────────────────────────────────────────────────────── #}
<footer class="footer">
    <div>
        <div class="footer__brand">BazaArt</div>
        <div class="footer__tagline">La plateforme des artistes francophones</div>
        <div class="footer__copy">2026 — BazaArt. Tous droits réservés.</div>
    </div>

    <div class="footer__links">
        <a href="#">À propos</a>
        <a href="#">Conditions</a>
        <a href="#">Contact</a>
        <a href="#">API</a>
    </div>
</footer>

{% endblock %}
