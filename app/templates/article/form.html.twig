{% extends 'base_app.html.twig' %}

{#
 # article/form.html.twig — Créer ou modifier un article (thème Street)
 #
 # Variables transmises par ArticleController::new() et ::edit() :
 #   - article  : Article|null — null si création, Article si modification
 #   - error    : string|null  — message d'erreur de validation (côté service)
 #   - formData : array        — données saisies renvoyées en cas d'erreur
 #
 # Ce formulaire est en HTML natif (pas Symfony FormType).
 # Le contrôleur lit $request->request->all() et $request->files->get('cover').
 # Les champs "action" (save_draft / save_publish) sont gérés via JS.
 #
 # Sécurité :
 #   - CSRF : ce formulaire n'utilise PAS de token CSRF explicite car
 #     ArticleController::new() et ::edit() ne le vérifient pas (ils font confiance
 #     à IsGranted). Si un token est ajouté côté back, ajouter ici :
 #     <input type="hidden" name="_token" value="{{ csrf_token('article_form') }}">
 #   - XSS : toutes les valeurs affichées passent par l'autoescaping Twig.
 #}

{% block title %}{{ article ? "Modifier l'article" : 'Écrire un article' }} — BazaArt{% endblock %}
{% block page_title %}{{ article ? "Modifier l'article" : 'Écrire un article' }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
{# Styles préfixés .art-form- pour éviter les collisions #}
<style>

    /* ── Contrainte de largeur ────────────────────────────────────────────── */

    /*
     * max-width: 800px — espace confortable pour l'éditeur.
     * Le formulaire est centré dans la zone de contenu (app-content est déjà padded).
     */
    .art-form-wrap {
        max-width: 800px;
    }

    /* ── En-tête du formulaire ──────────────────────────────────────────── */

    /*
     * Reproduit le motif SectionHeader du prototype :
     * titre display géant + séparateur bas 1px solid var(--ink).
     */
    .art-form-header {
        border-bottom: 1px solid var(--ink);
        padding-bottom: 20px;
        margin-bottom: 28px;
    }

    .art-form-header__title {
        font-family: var(--display);
        font-size: 40px;
        text-transform: uppercase;
        letter-spacing: -.02em;
        color: var(--ink);
        margin: 0 0 4px;
    }

    .art-form-header__sub {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    /* ── Sections du formulaire ─────────────────────────────────────────── */

    /*
     * .art-form-section : encadré 1px solid var(--ink) — style affiche.
     * Pas de shadow, pas de radius — cohérent avec le thème Street.
     */
    .art-form-section {
        border: 1px solid var(--ink);
        background: var(--bg);
        margin-bottom: 16px;
    }

    /* En-tête de section avec label mono uppercase */
    .art-form-section__head {
        padding: 12px 20px;
        border-bottom: 1px solid var(--line-soft);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--ink-mute);
        background: var(--bg-alt);
    }

    .art-form-section__body { padding: 20px; }

    /* ── Champs de formulaire ───────────────────────────────────────────── */

    /*
     * On surcharge les styles globaux pour aligner avec le thème Street.
     * --input-bg, --input-border, --input-radius sont définis dans design-tokens.css.
     */
    .art-form-wrap label {
        display: block;
        font-family: var(--mono);
        font-size: var(--label-font-size);
        font-weight: var(--label-font-weight);
        letter-spacing: var(--label-letter-spacing);
        text-transform: uppercase;
        color: var(--label-color);
        margin-bottom: 6px;
    }

    /* Champ titre : plus grand pour l'impact visuel */
    #art-title {
        font-family: var(--display);
        font-size: 22px;
        font-weight: 400;
        letter-spacing: -.01em;
        width: 100%;
        padding: 12px 14px;
        border: var(--input-border);
        background: var(--input-bg);
        border-radius: var(--input-radius);
        color: var(--ink);
        outline: none;
        box-sizing: border-box;
    }
    #art-title:focus {
        border: var(--input-border-focus);
    }
    #art-title::placeholder {
        color: var(--ink-mute);
        font-family: var(--serif);
        font-style: italic;
        font-size: 18px;
    }

    /* Champ excerpt et textarea génériques */
    .art-form-wrap input[type="text"]:not(#art-title),
    .art-form-wrap input[type="email"],
    .art-form-wrap input[type="url"],
    .art-form-wrap textarea,
    .art-form-wrap input[type="file"] {
        width: 100%;
        padding: var(--input-padding);
        border: var(--input-border);
        background: var(--input-bg);
        border-radius: var(--input-radius);
        font-family: var(--body);
        font-size: var(--input-font-size);
        color: var(--ink);
        outline: none;
        box-sizing: border-box;
    }
    .art-form-wrap input:focus,
    .art-form-wrap textarea:focus {
        border: var(--input-border-focus);
    }

    /* Zone de contenu — haute pour l'écriture confortable */
    #art-content {
        min-height: 400px;
        resize: vertical;
        line-height: 1.7;
        font-family: var(--serif);
        font-size: 16px;
    }

    /* Hint sous un champ */
    .art-form-hint {
        display: block;
        margin-top: 6px;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: .06em;
        color: var(--ink-mute);
    }

    /* Margin entre champs */
    .art-field { margin-bottom: 18px; }
    .art-field:last-child { margin-bottom: 0; }

    /* ── Aperçu image de couverture ─────────────────────────────────────── */

    .art-cover-preview {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        display: block;
        border: 1px solid var(--ink);
        margin-bottom: 12px;
    }

    /* ── Barre de boutons ────────────────────────────────────────────────── */

    .art-form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
        padding-top: 4px;
    }

    /*
     * Bouton "Publier" (primaire) : fond accent lime.
     * Reprend les variables --btn-primary-* du thème Street.
     */
    .art-btn-publish {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: var(--btn-padding);
        background: var(--btn-primary-bg);
        color: var(--btn-primary-color);
        border: 1px solid var(--ink);
        font-family: var(--mono);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        cursor: pointer;
        font-family: var(--mono);
        transition: background var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .art-btn-publish:hover {
        background: var(--btn-primary-hover-bg);
        color: var(--btn-primary-hover-color);
        box-shadow: var(--shadow-offset-sm);
    }

    /*
     * Bouton "Brouillon" (secondaire) : fond transparent, bordure encre.
     * Moins de poids visuel → hiérarchie claire entre les deux actions.
     */
    .art-btn-draft {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: var(--btn-padding);
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--ink);
        font-family: var(--mono);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        cursor: pointer;
        font-family: var(--mono);
        transition: background var(--transition-fast), color var(--transition-fast);
    }
    .art-btn-draft:hover {
        background: var(--ink);
        color: var(--bg);
    }

    /* Lien "Annuler" — tout à droite, discret */
    .art-btn-cancel {
        margin-left: auto;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--ink-mute);
        text-decoration: none;
    }
    .art-btn-cancel:hover { color: var(--ink); text-decoration: underline; }

    /* ── Message d'erreur ────────────────────────────────────────────────── */

    /*
     * .art-error-banner : bande rouge visible en haut du formulaire
     * si ArticleService retourne un message d'erreur (titre vide, contenu trop court…)
     */
    .art-error-banner {
        border: 1px solid var(--danger);
        background: rgba(229, 72, 77, .08);
        color: var(--danger);
        padding: 12px 16px;
        margin-bottom: 20px;
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .06em;
    }

</style>
{% endblock %}

{% block content %}
<div class="art-form-wrap">

    {# ── En-tête ─────────────────────────────────────────────────────────── #}
    <div class="art-form-header">
        <h1 class="art-form-header__title">
            {{ article ? 'Modifier l\'article' : 'Écrire un article' }}
        </h1>
        <p class="art-form-header__sub">
            {{ article ? 'Mise à jour · ' ~ article.title|slice(0, 50) : 'Nouvel article · BazaArt' }}
        </p>
    </div>

    {# Message d'erreur de validation (retourné par ArticleService) #}
    {% if error %}
        <div class="art-error-banner" role="alert">
            {{ error }}
        </div>
    {% endif %}

    {#
     # enctype="multipart/form-data" : OBLIGATOIRE pour l'upload de l'image de couverture.
     # Sans cet attribut, $_FILES reste vide et l'upload échoue silencieusement.
     #
     # action : le formulaire est partagé entre création (app_article_new) et
     # modification (app_article_edit). On choisit la route selon que la variable
     # `article` est définie et non nulle.
     #
     # novalidate : désactive la validation HTML5 native pour laisser Symfony
     # gérer les erreurs côté serveur (plus de contrôle sur les messages d'erreur).
    #}
    <form method="post"
          action="{{ article is defined and article ? path('app_article_edit', {id: article.id}) : path('app_article_new') }}"
          enctype="multipart/form-data"
          novalidate>

        {#
         # Token CSRF : protège contre les attaques Cross-Site Request Forgery.
         # Le contrôleur ArticleController::new() et ::edit() doivent vérifier
         # ce token via $this->isCsrfTokenValid('article_form', $token).
         # Clé : 'article_form' — identique dans le template et le contrôleur.
        #}
        <input type="hidden" name="_token" value="{{ csrf_token('article_form') }}">

        {# ── Section 1 : Titre ─────────────────────────────────────────── #}
        <div class="art-form-section">
            <div class="art-form-section__head">Titre de l'article *</div>
            <div class="art-form-section__body">
                <div class="art-field">
                    <label for="art-title" class="sr-only">Titre *</label>
                    <input type="text"
                           id="art-title"
                           name="title"
                           required
                           maxlength="255"
                           autocomplete="off"
                           placeholder="Donnez un titre accrocheur…"
                           value="{{ formData['title'] ?? article.title ?? '' }}">
                </div>
            </div>
        </div>

        {# ── Section 2 : Accroche ──────────────────────────────────────── #}
        <div class="art-form-section">
            <div class="art-form-section__head">Accroche (optionnelle)</div>
            <div class="art-form-section__body">
                <div class="art-field">
                    <label for="art-excerpt">
                        Résumé court — affiché dans les listes et en chapeau
                    </label>
                    <textarea id="art-excerpt"
                              name="excerpt"
                              rows="2"
                              maxlength="400"
                              placeholder="Une ou deux phrases pour donner envie de lire…">{{ formData['excerpt'] ?? article.excerpt ?? '' }}</textarea>
                    <span class="art-form-hint">400 caractères max</span>
                </div>
            </div>
        </div>

        {# ── Section 3 : Contenu principal ─────────────────────────────── #}
        <div class="art-form-section">
            <div class="art-form-section__head">Contenu *</div>
            <div class="art-form-section__body">
                <div class="art-field">
                    <label for="art-content">Rédigez votre article *</label>
                    <textarea id="art-content"
                              name="content"
                              rows="20"
                              required
                              placeholder="Rédigez ici…&#10;&#10;Les sauts de ligne seront respectés à l'affichage (filtre nl2br).&#10;Pas besoin de HTML.">{{ formData['content'] ?? article.content ?? '' }}</textarea>
                    <span class="art-form-hint">
                        Les retours à la ligne sont préservés. Pas de HTML nécessaire.
                    </span>
                </div>
            </div>
        </div>

        {# ── Section 4 : Image de couverture ───────────────────────────── #}
        <div class="art-form-section">
            <div class="art-form-section__head">Image de couverture</div>
            <div class="art-form-section__body">

                {# Aperçu de l'image actuelle si l'article en a une #}
                {% if article and article.coverImagePath %}
                    <img src="{{ asset(article.coverImagePath) }}"
                         alt="Couverture actuelle de l'article"
                         class="art-cover-preview">
                    <p class="art-form-hint" style="margin-bottom:12px;">
                        Sélectionner un nouveau fichier remplacera cette image.
                    </p>
                {% endif %}

                <div class="art-field">
                    <label for="art-cover">
                        {{ article and article.coverImagePath ? 'Changer l\'image' : 'Ajouter une image' }}
                    </label>
                    <input type="file"
                           id="art-cover"
                           name="cover"
                           accept="image/jpeg,image/png,image/webp">
                    <span class="art-form-hint">JPG, PNG, WebP — max 10 Mo — recommandé : 1200×630 px</span>
                </div>

            </div>
        </div>

        {# ── Boutons de validation ─────────────────────────────────────── #}
        {#
         # Le champ caché "action" indique au service si l'on sauvegarde en brouillon
         # ou si on publie. Sa valeur est mise à jour par l'attribut onclick avant submit.
         # Valeurs possibles : "save_draft" | "save_publish" (lues dans ArticleService).
        #}
        <input type="hidden" name="action" id="art-action-input" value="save_draft">

        <div class="art-form-actions">

            {# Bouton "Brouillon" — secondaire, moins de poids visuel #}
            <button type="submit"
                    class="art-btn-draft"
                    onclick="document.getElementById('art-action-input').value='save_draft'">
                Enregistrer en brouillon
            </button>

            {# Bouton "Publier" — primaire, fond lime #}
            <button type="submit"
                    class="art-btn-publish"
                    onclick="document.getElementById('art-action-input').value='save_publish'">
                {{ article and article.isPublished() ? 'Mettre à jour et publier' : 'Publier l\'article' }}
            </button>

            {# Lien "Annuler" — retourne au détail si modification, sinon à mes articles #}
            <a href="{{ article ? path('app_article_show', {slug: article.slug}) : path('app_article_my') }}"
               class="art-btn-cancel">
                Annuler
            </a>

        </div>

    </form>
</div>
{% endblock %}
