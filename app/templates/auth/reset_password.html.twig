{% extends 'base.html.twig' %}

{#
 # auth/reset_password.html.twig — Formulaire de nouveau mot de passe
 #
 # Mise en page split-screen 50/50 cohérente avec login/register/forgot_password.
 #
 # Variables injectées par ForgotPasswordController::resetPassword() :
 #   - tokenValid : bool   — false si le token est invalide ou expiré
 #   - token      : string — le token en clair de l'URL (pour le champ caché du POST)
 #   - error      : string|null — erreur de validation (mot de passe faible, confirmations différentes…)
 #
 # Deux états :
 #   1. tokenValid = false → affiche le message d'erreur + lien pour redemander
 #   2. tokenValid = true  → affiche le formulaire de nouveau mot de passe
 #}

{% block title %}Nouveau mot de passe — BazaArt{% endblock %}

{% block stylesheets %}
{{ parent() }}
{# Sécurité : empêche le navigateur d'envoyer l'URL (qui contient le token de reset)
 # dans l'en-tête Referer vers d'éventuelles ressources tierces. Pratique standard
 # pour toute page dont l'URL contient un secret. #}
<meta name="referrer" content="no-referrer">
<style>

    html, body {
        height: 100%;
        overflow: hidden;
    }

    /* ══════════════════════════════════════════════════════════════
     * LAYOUT — identique aux autres pages auth
     * ══════════════════════════════════════════════════════════════ */
    .auth-layout {
        display: flex;
        height: 100vh;
        background: var(--bg);
    }

    .auth-left {
        flex: 0 0 50%;
        background: var(--ink);
        color: var(--bg);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 56px 64px;
        position: relative;
        overflow: hidden;
    }

    .auth-left__top {
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .auth-left__logo {
        font-family: var(--display);
        font-size: 72px;
        line-height: 1;
        letter-spacing: -.02em;
        color: var(--bg);
    }

    .auth-left__logo span {
        color: var(--accent);
    }

    .auth-left__tagline {
        font-family: var(--serif);
        font-style: italic;
        font-size: 22px;
        line-height: 1.4;
        color: rgba(242, 239, 230, .75);
        max-width: 400px;
    }

    .auth-left__tagline::before {
        content: '"';
        font-size: 48px;
        line-height: 0;
        vertical-align: -.35em;
        display: inline-block;
        margin-right: 4px;
        color: var(--accent);
        font-style: normal;
    }

    .auth-left__bottom {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .auth-left__label {
        font-family: var(--mono);
        font-size: var(--eyebrow-font-size);
        font-weight: 700;
        letter-spacing: var(--eyebrow-letter-spacing);
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    .auth-left__chips {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .auth-chip {
        font-family: var(--mono);
        font-size: var(--chip-font-size);
        font-weight: var(--chip-font-weight);
        letter-spacing: var(--chip-letter-spacing);
        text-transform: uppercase;
        padding: var(--chip-padding);
        border: 1px solid rgba(242, 239, 230, .25);
        color: var(--bg);
        border-radius: var(--radius-none);
    }

    .auth-right {
        flex: 1;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: var(--space-2xl) var(--space-xl);
        overflow-y: auto;
    }

    .auth-form-wrapper {
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .auth-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .auth-title {
        font-family: var(--display);
        font-size: 36px;
        line-height: 1;
        letter-spacing: -.01em;
        color: var(--ink);
    }

    .auth-subtitle {
        font-family: var(--body);
        font-size: 14px;
        color: var(--ink-mute);
        line-height: 1.5;
    }

    .auth-subtitle a {
        color: var(--accent-2);
        font-weight: 600;
        text-decoration: none;
    }
    .auth-subtitle a:hover {
        text-decoration: underline;
    }

    /* ── Bloc d'erreur (validation DTO ou CSRF) ── */
    .auth-error {
        border: 2px solid var(--accent-2);
        background: rgba(255, 107, 44, .08);
        padding: var(--space-md);
        font-family: var(--body);
        font-size: 13px;
        color: var(--ink);
    }

    /* ── Bloc d'erreur token expiré/invalide ── */
    .auth-token-error {
        border: 2px solid var(--accent-2);
        background: rgba(255, 107, 44, .08);
        padding: var(--space-lg);
        font-family: var(--body);
        font-size: 14px;
        color: var(--ink);
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .auth-token-error strong {
        font-family: var(--display);
        font-size: 18px;
        display: block;
    }

    /* ── Bouton CTA pour redemander un lien ── */
    .auth-btn-cta {
        display: inline-block;
        padding: 12px var(--space-lg);
        font-family: var(--display);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        color: var(--ink);
        background: var(--accent);
        border: 2px solid var(--ink);
        border-radius: var(--radius-none);
        text-decoration: none;
        transition: background var(--transition-fast), box-shadow var(--transition-fast);
    }
    .auth-btn-cta:hover {
        background: var(--ink);
        color: var(--accent);
        box-shadow: var(--shadow-offset-sm);
    }

    /* ── Champs formulaire ── */
    .auth-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: var(--space-md);
    }

    .auth-label {
        font-family: var(--mono);
        font-size: var(--label-font-size);
        font-weight: var(--label-font-weight);
        letter-spacing: var(--label-letter-spacing);
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    .auth-input {
        width: 100%;
        padding: var(--input-padding);
        font-family: var(--body);
        font-size: var(--input-font-size);
        color: var(--ink);
        background: white;
        border: 2px solid var(--ink);
        border-radius: var(--radius-none);
        outline: none;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .auth-input:focus {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }
    .auth-input::placeholder {
        color: var(--ink-mute);
        opacity: .5;
    }

    /* Règles de complexité sous le champ mot de passe */
    .auth-input-hint {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        line-height: 1.4;
    }

    /* ── Bouton submit ── */
    .auth-btn-submit {
        width: 100%;
        padding: 14px var(--space-lg);
        font-family: var(--display);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        color: var(--ink);
        background: var(--accent);
        border: 2px solid var(--ink);
        border-radius: var(--radius-none);
        cursor: pointer;
        transition: background var(--transition-fast), box-shadow var(--transition-fast);
    }
    .auth-btn-submit:hover {
        background: var(--ink);
        color: var(--accent);
        box-shadow: var(--shadow-offset-sm);
    }

    /* ── Lien de retour ── */
    .auth-back-link {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--ink-mute);
        text-decoration: none;
        text-align: center;
        display: block;
    }
    .auth-back-link:hover {
        color: var(--ink);
        text-decoration: underline;
    }

    /* ══════════════════════════════════════════════════════════════
     * RESPONSIVE
     * ══════════════════════════════════════════════════════════════ */
    @media (max-width: 768px) {
        html, body {
            height: auto;
            overflow: auto;
        }

        .auth-layout {
            flex-direction: column;
            height: auto;
            min-height: 100vh;
        }

        .auth-left {
            flex: none;
            padding: var(--space-xl) var(--space-lg);
            justify-content: flex-start;
            gap: var(--space-md);
        }

        .auth-left__bottom {
            display: none;
        }

        .auth-left__logo {
            font-size: 48px;
        }

        .auth-left__tagline {
            font-size: 16px;
        }

        .auth-right {
            padding: var(--space-xl) var(--space-md);
        }

        .auth-form-wrapper {
            max-width: 100%;
        }
    }

</style>
{% endblock %}

{% block body %}
<div class="auth-layout" role="main">

    {# ══════════════════════════════════════════════════════════════════════════
     # COLONNE GAUCHE — Panneau décoratif
     # ════════════════════════════════════════════════════════════════════════ #}
    <aside class="auth-left" aria-hidden="true">

        <div class="auth-left__top">
            <div class="auth-left__logo">
                Baza<span>Art</span>
            </div>
            <p class="auth-left__tagline">
                Choisissez un mot de passe fort<br>
                pour protéger votre compte.
            </p>
        </div>

        <div class="auth-left__bottom">
            <span class="auth-left__label">Disciplines</span>
            <div class="auth-left__chips">
                <span class="auth-chip">Musique</span>
                <span class="auth-chip">Arts visuels</span>
                <span class="auth-chip">Cinéma</span>
                <span class="auth-chip">Danse</span>
                <span class="auth-chip">Littérature</span>
                <span class="auth-chip">Théâtre</span>
            </div>
        </div>

    </aside>

    {# ══════════════════════════════════════════════════════════════════════════
     # COLONNE DROITE — Contenu principal (formulaire ou erreur token)
     # ════════════════════════════════════════════════════════════════════════ #}
    <div class="auth-right">
        <div class="auth-form-wrapper">

            {% if not tokenValid %}
                {# ══════════════════════════════════════════════════════════════
                 # CAS 1 : Token invalide ou expiré
                 #
                 # Ce cas se produit si :
                 #   - Le lien a plus d'1 heure
                 #   - Le token a déjà été utilisé (invalidé après reset)
                 #   - L'URL a été altérée
                 # ════════════════════════════════════════════════════════════ #}
                <header class="auth-header">
                    <h1 class="auth-title">Lien expiré</h1>
                </header>

                <div class="auth-token-error" role="alert">
                    <strong>Ce lien n'est plus valide.</strong>
                    <p>
                        Le lien de réinitialisation est valable <strong>1 heure</strong>
                        et ne peut être utilisé qu'une seule fois.
                        Il semble que ce lien ait expiré ou ait déjà été utilisé.
                    </p>
                    <p>
                        Fais une nouvelle demande de réinitialisation pour recevoir
                        un nouveau lien.
                    </p>
                    <a href="{{ path('app_forgot_password') }}" class="auth-btn-cta">
                        Faire une nouvelle demande →
                    </a>
                </div>

                <a href="{{ path('app_login') }}" class="auth-back-link">
                    ← Retour à la connexion
                </a>

            {% else %}
                {# ══════════════════════════════════════════════════════════════
                 # CAS 2 : Token valide — afficher le formulaire
                 # ════════════════════════════════════════════════════════════ #}

                <header class="auth-header">
                    <h1 class="auth-title">Nouveau mot de passe</h1>
                    <p class="auth-subtitle">
                        Choisis un mot de passe sécurisé pour ton compte Bazaart.
                    </p>
                </header>

                {# ── Erreur de validation DTO (mot de passe faible, confirmations différentes) ──
                 # Injectée directement par le contrôleur (pas via flash, pour éviter la
                 # redirection POST/Redirect/GET qui perdrait le contexte du formulaire).
                 # ────────────────────────────────────────────────────────────────────────── #}
                {% if error %}
                    <div class="auth-error" role="alert" aria-live="assertive">
                        {{ error }}
                    </div>
                {% endif %}

                <form method="post"
                      action="{{ path('app_reset_password', {token: token}) }}"
                      novalidate>
                    {# novalidate : validation HTML5 désactivée — Symfony valide côté serveur #}

                    {# ── Nouveau mot de passe ── #}
                    <div class="auth-field">
                        <label class="auth-label" for="reset-password">
                            Nouveau mot de passe
                        </label>
                        <input
                            class="auth-input"
                            type="password"
                            id="reset-password"
                            name="password"
                            placeholder="••••••••••"
                            autocomplete="new-password"
                            required
                            minlength="10"
                            aria-describedby="reset-password-hint">
                        {# Règles de complexité conformes au CDC §9 #}
                        <span class="auth-input-hint" id="reset-password-hint">
                            10 caractères minimum, 1 lettre majuscule, 1 chiffre
                        </span>
                    </div>

                    {# ── Confirmation du mot de passe ── #}
                    <div class="auth-field">
                        <label class="auth-label" for="reset-confirm-password">
                            Confirmer le mot de passe
                        </label>
                        <input
                            class="auth-input"
                            type="password"
                            id="reset-confirm-password"
                            name="confirm_password"
                            placeholder="••••••••••"
                            autocomplete="new-password"
                            required
                            minlength="10">
                    </div>

                    {# ── Token CSRF ──────────────────────────────────────────────
                     # Protège contre les attaques CSRF.
                     # ForgotPasswordController valide ce token via isCsrfTokenValid()
                     # avec l'intention 'reset_password' avant tout traitement du POST.
                     # ──────────────────────────────────────────────────────────── #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

                    {# Bouton submit #}
                    <button type="submit" class="auth-btn-submit">
                        Enregistrer le nouveau mot de passe →
                    </button>

                </form>

            {% endif %}

        </div>
    </div>{# fin .auth-right #}

</div>{# fin .auth-layout #}
{% endblock %}
