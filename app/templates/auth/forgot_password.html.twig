{% extends 'base.html.twig' %}

{#
 # auth/forgot_password.html.twig — Page "Mot de passe oublié"
 #
 # Mise en page split-screen 50/50 cohérente avec login.html.twig et register.html.twig.
 #
 # Variables injectées par ForgotPasswordController::forgotPassword() :
 #   - messageSent : bool — true après soumission (affiche le message neutre anti-énumération)
 #   - error       : string|null — erreur CSRF ou autre, null si aucune
 #
 # Sécurité :
 #   - CSRF token avec l'intention 'forgot_password'
 #   - Même message affiché qu'un compte existe ou non (anti-énumération)
 #}

{% block title %}Mot de passe oublié — BazaArt{% endblock %}

{% block stylesheets %}
{{ parent() }}
{# ── CSS partagé avec login.html.twig — même tokens visuels Street ── #}
<style>

    /* ── Reset hauteur pour le full-screen ── */
    html, body {
        height: 100%;
        overflow: hidden;
    }

    /* ══════════════════════════════════════════════════════════════
     * LAYOUT — deux colonnes 50/50 pleine hauteur (identique login)
     * ══════════════════════════════════════════════════════════════ */
    .auth-layout {
        display: flex;
        height: 100vh;
        background: var(--bg);
    }

    /* ── Colonne gauche : panneau décoratif ── */
    .auth-left {
        flex: 0 0 50%;
        background: var(--ink);
        color: var(--bg);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 56px 64px;
        position: relative;
        overflow: hidden;
    }

    .auth-left__top {
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .auth-left__logo {
        font-family: var(--display);
        font-size: 72px;
        line-height: 1;
        letter-spacing: -.02em;
        color: var(--bg);
    }

    .auth-left__logo span {
        color: var(--accent);
    }

    .auth-left__tagline {
        font-family: var(--serif);
        font-style: italic;
        font-size: 22px;
        line-height: 1.4;
        color: rgba(242, 239, 230, .75);
        max-width: 400px;
    }

    .auth-left__tagline::before {
        content: '"';
        font-size: 48px;
        line-height: 0;
        vertical-align: -.35em;
        display: inline-block;
        margin-right: 4px;
        color: var(--accent);
        font-style: normal;
    }

    .auth-left__bottom {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .auth-left__label {
        font-family: var(--mono);
        font-size: var(--eyebrow-font-size);
        font-weight: 700;
        letter-spacing: var(--eyebrow-letter-spacing);
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    .auth-left__chips {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .auth-chip {
        font-family: var(--mono);
        font-size: var(--chip-font-size);
        font-weight: var(--chip-font-weight);
        letter-spacing: var(--chip-letter-spacing);
        text-transform: uppercase;
        padding: var(--chip-padding);
        border: 1px solid rgba(242, 239, 230, .25);
        color: var(--bg);
        border-radius: var(--radius-none);
    }

    /* ── Colonne droite : formulaire ── */
    .auth-right {
        flex: 1;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: var(--space-2xl) var(--space-xl);
        overflow-y: auto;
    }

    .auth-form-wrapper {
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .auth-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .auth-title {
        font-family: var(--display);
        font-size: 36px;
        line-height: 1;
        letter-spacing: -.01em;
        color: var(--ink);
    }

    .auth-subtitle {
        font-family: var(--body);
        font-size: 14px;
        color: var(--ink-mute);
        line-height: 1.5;
    }

    .auth-subtitle a {
        color: var(--accent-2);
        font-weight: 600;
        text-decoration: none;
    }
    .auth-subtitle a:hover {
        text-decoration: underline;
    }

    /* ── Bloc d'erreur ── */
    .auth-error {
        border: 2px solid var(--accent-2);
        background: rgba(255, 107, 44, .08);
        padding: var(--space-md);
        font-family: var(--body);
        font-size: 13px;
        color: var(--ink);
    }

    /* ── Bloc de confirmation (message neutre anti-énumération) ── */
    .auth-success {
        border: 2px solid var(--ok, #1F8A5B);
        background: rgba(31, 138, 91, .08);
        padding: var(--space-md);
        font-family: var(--body);
        font-size: 14px;
        color: var(--ink);
        line-height: 1.6;
    }

    /* Titre du bloc de confirmation */
    .auth-success strong {
        display: block;
        font-family: var(--display);
        font-size: 16px;
        margin-bottom: var(--space-xs);
    }

    /* ── Champs formulaire ── */
    .auth-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .auth-label {
        font-family: var(--mono);
        font-size: var(--label-font-size);
        font-weight: var(--label-font-weight);
        letter-spacing: var(--label-letter-spacing);
        text-transform: uppercase;
        color: var(--ink-mute);
    }

    .auth-input {
        width: 100%;
        padding: var(--input-padding);
        font-family: var(--body);
        font-size: var(--input-font-size);
        color: var(--ink);
        background: white;
        border: 2px solid var(--ink);
        border-radius: var(--radius-none);
        outline: none;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .auth-input:focus {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }
    .auth-input::placeholder {
        color: var(--ink-mute);
        opacity: .5;
    }

    /* ── Hint sous le champ email ── */
    .auth-input-hint {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        line-height: 1.4;
    }

    /* ── Bouton principal ── */
    .auth-btn-submit {
        width: 100%;
        padding: 14px var(--space-lg);
        font-family: var(--display);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        letter-spacing: var(--btn-letter-spacing);
        text-transform: uppercase;
        color: var(--ink);
        background: var(--accent);
        border: 2px solid var(--ink);
        border-radius: var(--radius-none);
        cursor: pointer;
        transition: background var(--transition-fast), box-shadow var(--transition-fast);
    }
    .auth-btn-submit:hover {
        background: var(--ink);
        color: var(--accent);
        box-shadow: var(--shadow-offset-sm);
    }

    /* ── Lien de retour ── */
    .auth-back-link {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--ink-mute);
        text-decoration: none;
        text-align: center;
        display: block;
    }
    .auth-back-link:hover {
        color: var(--ink);
        text-decoration: underline;
    }

    /* ══════════════════════════════════════════════════════════════
     * RESPONSIVE — mobile-first
     * ══════════════════════════════════════════════════════════════ */
    @media (max-width: 768px) {
        html, body {
            height: auto;
            overflow: auto;
        }

        .auth-layout {
            flex-direction: column;
            height: auto;
            min-height: 100vh;
        }

        .auth-left {
            flex: none;
            padding: var(--space-xl) var(--space-lg);
            justify-content: flex-start;
            gap: var(--space-md);
        }

        .auth-left__bottom {
            display: none;
        }

        .auth-left__logo {
            font-size: 48px;
        }

        .auth-left__tagline {
            font-size: 16px;
        }

        .auth-right {
            padding: var(--space-xl) var(--space-md);
        }

        .auth-form-wrapper {
            max-width: 100%;
        }
    }

</style>
{% endblock %}

{% block body %}
<div class="auth-layout" role="main">

    {# ══════════════════════════════════════════════════════════════════════════
     # COLONNE GAUCHE — Panneau décoratif (aria-hidden : purement décoratif)
     # ════════════════════════════════════════════════════════════════════════ #}
    <aside class="auth-left" aria-hidden="true">

        <div class="auth-left__top">
            <div class="auth-left__logo">
                Baza<span>Art</span>
            </div>
            <p class="auth-left__tagline">
                Pas de panique — on t'envoie<br>
                un lien pour récupérer ton accès.
            </p>
        </div>

        <div class="auth-left__bottom">
            <span class="auth-left__label">Disciplines</span>
            <div class="auth-left__chips">
                <span class="auth-chip">Musique</span>
                <span class="auth-chip">Arts visuels</span>
                <span class="auth-chip">Cinéma</span>
                <span class="auth-chip">Danse</span>
                <span class="auth-chip">Littérature</span>
                <span class="auth-chip">Théâtre</span>
            </div>
        </div>

    </aside>

    {# ══════════════════════════════════════════════════════════════════════════
     # COLONNE DROITE — Formulaire ou message de confirmation
     # ════════════════════════════════════════════════════════════════════════ #}
    <div class="auth-right">
        <div class="auth-form-wrapper">

            {# ── En-tête ── #}
            <header class="auth-header">
                <h1 class="auth-title">Mot de passe oublié</h1>
                <p class="auth-subtitle">
                    Saisis ton adresse e-mail et nous t'enverrons un lien
                    pour réinitialiser ton mot de passe.
                </p>
            </header>

            {# ── Flash messages de rate limiting ─────────────────────────────
             # ForgotPasswordController ajoute un flash 'error' si le rate limiter
             # est déclenché (5 tentatives / 15 min / IP).
             # ────────────────────────────────────────────────────────────────── #}
            {% for message in app.flashes('error') %}
                <div class="auth-error" role="alert" aria-live="assertive">
                    {{ message }}
                </div>
            {% endfor %}

            {# ── Erreur CSRF ──────────────────────────────────────────────────
             # Injectée directement par le contrôleur (pas via flash car on
             # re-render le template sans redirection pour un token CSRF invalide).
             # ────────────────────────────────────────────────────────────────── #}
            {% if error %}
                <div class="auth-error" role="alert" aria-live="assertive">
                    {{ error }}
                </div>
            {% endif %}

            {% if messageSent %}
                {# ── Message neutre de confirmation ────────────────────────────
                 # Affiché après soumission QUEL QUE SOIT le résultat.
                 # C'est la mesure anti-énumération : un attaquant ne peut pas savoir
                 # si un email est inscrit sur la plateforme en testant ce formulaire.
                 # ──────────────────────────────────────────────────────────────── #}
                <div class="auth-success" role="status" aria-live="polite">
                    <strong>Email envoyé !</strong>
                    Si un compte existe pour cette adresse, tu recevras un email avec
                    un lien de réinitialisation valable <strong>1 heure</strong>.
                    Pense à vérifier tes spams.
                </div>

                {# Lien de retour vers la connexion après confirmation #}
                <a href="{{ path('app_login') }}" class="auth-back-link">
                    ← Retour à la connexion
                </a>

            {% else %}
                {# ── Formulaire email ──────────────────────────────────────────
                 # Ce formulaire est affiché tant que messageSent est false.
                 # Après soumission, le contrôleur repasse messageSent à true
                 # et on affiche le message de confirmation ci-dessus.
                 # ──────────────────────────────────────────────────────────────── #}
                <form method="post" action="{{ path('app_forgot_password') }}" novalidate>
                    {# novalidate : validation HTML5 désactivée — on délègue à Symfony côté serveur #}

                    {# Champ email #}
                    <div class="auth-field" style="margin-bottom: var(--space-md);">
                        <label class="auth-label" for="forgot-email">
                            Adresse e-mail
                        </label>
                        <input
                            class="auth-input"
                            type="email"
                            id="forgot-email"
                            name="email"
                            placeholder="toi@exemple.com"
                            autocomplete="email"
                            required
                            autofocus>
                        {# Hint discret pour rassurer l'utilisateur #}
                        <span class="auth-input-hint" id="forgot-email-hint">
                            L'adresse e-mail avec laquelle tu t'es inscrit(e).
                        </span>
                    </div>

                    {# ── Token CSRF ──────────────────────────────────────────────
                     # Protection contre les attaques Cross-Site Request Forgery.
                     # ForgotPasswordController valide ce token via isCsrfTokenValid()
                     # avec l'intention 'forgot_password' avant tout traitement.
                     # ──────────────────────────────────────────────────────────── #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

                    {# Bouton submit #}
                    <button type="submit" class="auth-btn-submit" style="margin-bottom: var(--space-md);">
                        Envoyer le lien de réinitialisation →
                    </button>

                </form>

                {# Lien retour connexion — en dehors du <form> pour ne pas être soumis #}
                <a href="{{ path('app_login') }}" class="auth-back-link">
                    ← Retour à la connexion
                </a>

            {% endif %}

        </div>
    </div>{# fin .auth-right #}

</div>{# fin .auth-layout #}
{% endblock %}
