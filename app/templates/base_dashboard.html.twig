{% extends 'base.html.twig' %}

{#
 # base_dashboard.html.twig — Layout partagé pour les dashboards artiste et structure
 #
 # Ce layout remplace base_app.html.twig pour les pages de tableau de bord connectées.
 # Il fournit :
 #   - Une sidebar fixe sur fond --ink (noir) avec navigation latérale
 #   - Une zone principale (.sd-main) avec topbar sticky et zone de contenu
 #   - La gestion des flash messages (success / error / info)
 #   - Le toggle hamburger mobile (JS inline)
 #
 # UTILISATION (template enfant) :
 #
 #   {% extends 'base_dashboard.html.twig' %}
 #
 #   {% block page_title %}Tableau de bord{% endblock %}
 #
 #   block sidebar
 #     ... contenu de la sidebar : logo, nav, utilisateur ...
 #   endblock
 #
 #   block content
 #     ... contenu principal de la page ...
 #   endblock
 #
 # CONVENTION CSS : toutes les classes sont préfixées ".sd-" (sidebar-dashboard)
 # pour éviter les conflits avec le reste du projet.
 #
 # DESIGN TOKENS (design-tokens.css) :
 #   --bg (#F2EFE6)    --bg-alt (#EAE6D9)
 #   --ink (#0D0D0D)   --ink-mute (#5b584f)
 #   --accent (#C6F24E) — vert acide, couleur artiste
 #   --accent-2 (#FF6B2C) — orange, couleur structure
 #   --display (Archivo Black)  --body (Space Grotesk)  --mono (JetBrains Mono)
 #   --transition-fast (.12s ease)
 #}

{#
    On vide le bloc navbar car la sidebar remplace intégralement
    la barre de navigation publique de base.html.twig.
    Les utilisateurs connectés n'ont pas besoin de la nav vitrine.
#}
{% block navbar %}{% endblock %}

{% block stylesheets %}
{{ parent() }}
{#
    CSS du layout sidebar — commun aux dashboards artiste et structure.
    Injecté ici plutôt que dans un fichier externe pour simplifier
    le déploiement (pas de requête HTTP supplémentaire, inline critique).
#}
<style>

/* ── Layout principal : flex row sidebar + contenu ──────────────────────── */
/*
 * .sd-app : conteneur racine en flex row.
 * La sidebar est positionnée en fixed (sort du flux normal),
 * la zone .sd-main compense avec margin-left: 220px.
 */
.sd-app {
    display: flex;
    min-height: 100vh;
    background: var(--bg);
    position: relative;
}

/* ── Sidebar Street ──────────────────────────────────────────────────────── */
/*
 * Fond ink (#0D0D0D) — contraste maximal, identité Street forte.
 * Largeur fixe 220px, position fixed pour rester visible au scroll.
 * overflow-y: auto → scroll interne si la nav déborde verticalement.
 */
.sd-side {
    width: 220px;
    min-height: 100vh;
    background: var(--ink);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 200;
    overflow-y: auto;
    overflow-x: hidden;
    transition: transform var(--transition-fast);
}

/* ── Lien du logo (wordmark) ─────────────────────────────────────────────── */
/*
 * .sd-wordmark-link : supprime l'underline du <a> qui enveloppe le wordmark.
 * display: block assure que le lien occupe tout l'espace du span,
 * sans créer de saut de ligne parasite.
 * Défini ici plutôt que dans chaque template enfant car c'est une règle
 * commune à tous les sidebars (artiste, structure, admin).
 */
.sd-wordmark-link {
    text-decoration: none;
    display: block;
}
/* Légère opacité au survol — signal visuel subtil */
.sd-wordmark-link:hover .sd-wordmark {
    opacity: .8;
}

/* ── Logo / wordmark ─────────────────────────────────────────────────────── */
/*
 * Zone en haut du sidebar : nom "BAZAART" en Archivo Black vert acide
 * + pill de rôle (ARTISTE, STRUCT., ADMIN).
 * Bordure basse discrète (rgba 10%) pour séparer du reste de la nav.
 */
.sd-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid rgba(242,239,230,.1);
    flex-shrink: 0;
}

/* "BAZAART" en Archivo Black, vert acide */
.sd-wordmark {
    font-family: var(--display);
    font-size: 17px;
    color: var(--accent);
    letter-spacing: -.01em;
    text-transform: uppercase;
}

/*
 * Pill de rôle — carré strict (Street, pas d'arrondi), taille micro.
 * Couleur par défaut : vert acide = artiste
 * Variantes : --struct (orange) et --admin (sable)
 */
.sd-role-pill {
    font-family: var(--mono);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 3px 6px;
    background: var(--accent);
    color: var(--ink);
    border: 1px solid var(--accent);
    white-space: nowrap;
}

/* Variante structure — fond orange */
.sd-role-pill--struct {
    background: var(--accent-2);
    border-color: var(--accent-2);
    color: var(--ink);
}

/* Variante admin — fond sable (inverse par rapport au sidebar sombre) */
.sd-role-pill--admin {
    background: var(--bg);
    color: var(--ink);
    border-color: var(--bg);
}

/* ── Sections de navigation ─────────────────────────────────────────────── */
/*
 * Labels de section (ex: "MON ESPACE", "EXPLORER") :
 * mono uppercase très petit, couleur très atténuée (rgba .35)
 * pour ne pas concurrencer les liens eux-mêmes.
 */
.sd-section {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(242,239,230,.35);
    padding: 16px 20px 5px;
    flex-shrink: 0;
}

/* Conteneur flex vertical des liens de nav */
.sd-nav {
    display: flex;
    flex-direction: column;
}

/* ── Liens de navigation ─────────────────────────────────────────────────── */
/*
 * Chaque lien a un padding généreux pour faciliter le clic,
 * une bordure gauche de 2px qui sert d'indicateur d'état (active/hover).
 * Pas de border-radius — identité Street.
 */
.sd-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 20px;
    font: 500 13px/1.3 var(--body);
    color: rgba(242,239,230,.65);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    border-left: 2px solid transparent;
    position: relative;
}

/* Hover : fond très légèrement éclairci + bordure gauche vert semi-transparent */
.sd-link:hover {
    background: rgba(242,239,230,.05);
    color: var(--bg);
    border-left-color: rgba(198,242,78,.5);
}

/* Lien actif : vert acide + fond légèrement teinté */
.sd-link--active {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: rgba(198,242,78,.07);
}

.sd-link--active:hover {
    background: rgba(198,242,78,.10);
}

/* ── Icône SVG dans les liens ────────────────────────────────────────────── */
/*
 * Classe utilitaire partagée pour toutes les icônes SVG inline du sidebar.
 * Dimensions fixes 16×16, stroke (pas fill) pour le style ligne.
 */
.sd-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
}

/* ── Badges (compteurs, alertes) ────────────────────────────────────────── */
/*
 * Badges numériques alignés à droite dans les liens.
 * Fond discret (rgba 12%) par défaut, orange vif pour les alertes.
 */
.sd-badge {
    margin-left: auto;
    font: 700 9px/1 var(--mono);
    letter-spacing: .04em;
    padding: 2px 6px;
    background: rgba(242,239,230,.12);
    color: rgba(242,239,230,.8);
    border: 1px solid rgba(242,239,230,.15);
    white-space: nowrap;
}

/* Badge d'alerte — orange vif, lecture prioritaire */
.sd-badge--warn {
    background: var(--accent-2);
    color: var(--ink);
    border-color: var(--accent-2);
}

/* ── Utilisateur en bas du sidebar ──────────────────────────────────────── */
/*
 * Bloc utilisateur collé en bas du sidebar (margin-top: auto).
 * Affiche avatar (initiales), nom (email), rôle et lien de déconnexion.
 */
.sd-user {
    margin-top: auto;
    padding: 14px 16px;
    border-top: 1px solid rgba(242,239,230,.08);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
}

/* Avatar carré avec initiales — vert acide par défaut */
.sd-avatar {
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font: 700 11px var(--mono);
    letter-spacing: .04em;
    border: 1px solid rgba(198,242,78,.5);
    flex-shrink: 0;
    /* Street = carré, border-radius: 0 implicite */
}

/* Nom de l'utilisateur — tronqué si trop long */
.sd-user__name {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--bg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Rôle en mono très petit */
.sd-user__role {
    display: block;
    font: 600 9px var(--mono);
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(242,239,230,.4);
    margin-top: 1px;
}

/* Icône de déconnexion — discrète, rouge au hover */
.sd-logout {
    margin-left: auto;
    display: flex;
    align-items: center;
    color: rgba(242,239,230,.35);
    text-decoration: none;
    transition: color var(--transition-fast);
    flex-shrink: 0;
}

.sd-logout:hover { color: var(--accent-2); }

/* ── Zone principale (à droite du sidebar) ──────────────────────────────── */
/*
 * margin-left: 220px compense la largeur du sidebar fixed.
 * Sur mobile, margin-left: 0 est appliqué (sidebar caché par défaut).
 */
.sd-main {
    margin-left: 220px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: var(--bg);
}

/* ── Topbar de la zone principale ───────────────────────────────────────── */
/*
 * Barre sticky (reste visible au scroll) : titre de la page + hamburger mobile.
 * Hauteur 56px comme la topbar admin pour cohérence.
 * Bordure basse --ink (1px) séparateur Street.
 */
.sd-topbar {
    height: 56px;
    background: var(--bg);
    border-bottom: 1px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    position: sticky;
    top: 0;
    z-index: 50;
    flex-shrink: 0;
}

/* Titre de la page courante en Archivo Black */
.sd-topbar__title {
    font-family: var(--display);
    font-size: 16px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -.01em;
}

/*
 * Bouton hamburger — visible UNIQUEMENT sur mobile (display: none par défaut).
 * Affiche/masque le sidebar via JS.
 * Pas de border-radius — Street.
 */
.sd-topbar__hamburger {
    display: none;
    background: none;
    border: 1px solid var(--ink);
    padding: 6px;
    cursor: pointer;
    line-height: 0;
}

.sd-topbar__hamburger:hover { background: var(--bg-alt); }

/* ── Zone de contenu scrollable ─────────────────────────────────────────── */
/*
 * padding: 28px 32px — identique à base_app.html.twig pour ne pas
 * casser les templates existants qui utilisent les classes .db-banner etc.
 * Le margin négatif de .db-banner (-28px -32px) compense ces valeurs.
 */
.sd-content {
    flex: 1;
    padding: 28px 32px;
}

/* ── Flash messages ──────────────────────────────────────────────────────── */
/*
 * Affichés entre la topbar et le contenu principal.
 * Pas de border-radius — Street.
 * Couleurs sémantiques standard (vert / rouge / bleu-gris).
 */
.sd-flash {
    margin: 12px 32px 0;
    padding: 12px 16px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--ink);
}

.sd-flash--success { background: #d4edda; color: #155724; }
.sd-flash--error   { background: #f8d7da; color: #721c24; }
.sd-flash--info    { background: #d1ecf1; color: #0c5460; }

/* ── Overlay mobile ──────────────────────────────────────────────────────── */
/*
 * Fond semi-transparent affiché derrière le sidebar ouvert sur mobile.
 * z-index 199 : sous le sidebar (200), au-dessus du contenu.
 * Cliquer dessus ferme le sidebar (géré en JS).
 */
.sd-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(13,13,13,.6);
    z-index: 199;
}

.sd-overlay--visible { display: block; }

/* ── Responsive mobile (< 768px) ────────────────────────────────────────── */
/*
 * Sur mobile :
 * - Sidebar masqué hors écran (translateX(-100%)), glisse via JS
 * - Zone principale prend 100% de largeur (margin-left: 0)
 * - Hamburger visible
 * - Padding réduit dans la topbar et le contenu
 */
@media (max-width: 767px) {

    /* Sidebar masqué, glisse de la gauche */
    .sd-side {
        transform: translateX(-100%);
    }

    /* Sidebar ouvert via JS (classe ajoutée par le script hamburger) */
    .sd-side--open {
        transform: translateX(0);
    }

    /* La zone principale prend toute la largeur (pas d'offset sidebar) */
    .sd-main {
        margin-left: 0;
    }

    /* Hamburger visible sur mobile */
    .sd-topbar__hamburger {
        display: flex;
    }

    /* Paddings réduits sur mobile */
    .sd-topbar { padding: 0 16px; }
    .sd-content { padding: 16px; }
    .sd-flash   { margin: 8px 16px 0; }
}

</style>
{% endblock %}

{% block body %}
<div class="sd-app">

    {#
        Sidebar — chaque dashboard enfant définit son propre contenu ici :
        logo, pills de rôle, sections de navigation, utilisateur en bas.
        La structure attendue est détaillée dans les templates artiste et structure.
    #}
    <aside class="sd-side" aria-label="Navigation principale">
        {% block sidebar %}{% endblock %}
    </aside>

    {# Zone principale : topbar + flash messages + contenu #}
    <div class="sd-main">

        {# Topbar sticky avec titre de la page courante #}
        <div class="sd-topbar">
            {#
                Le titre est défini par {% block page_title %} dans chaque template enfant.
                On utilise <h1> ici — c'est le seul H1 de la page (les bannières
                des dashboards utilisent <p class="..."> pour respecter la hiérarchie).
            #}
            <h1 class="sd-topbar__title">{% block page_title %}{% endblock %}</h1>

            {#
                Bouton hamburger mobile — toggle sidebar.
                aria-expanded reflète l'état ouvert/fermé (mis à jour par le JS).
                aria-label décrit l'action pour les lecteurs d'écran.
            #}
            <button class="sd-topbar__hamburger"
                    id="sd-hamburger"
                    aria-label="Menu"
                    aria-expanded="false"
                    type="button">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <line x1="2" y1="5"  x2="16" y2="5"  stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="square"/>
                    <line x1="2" y1="9"  x2="16" y2="9"  stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="square"/>
                    <line x1="2" y1="13" x2="16" y2="13" stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="square"/>
                </svg>
            </button>
        </div>

        {#
            Flash messages Symfony.
            Affichés après la topbar, avant le contenu.
            app.flashes() consomme les messages (ils disparaissent après affichage).
        #}
        {% for message in app.flashes('success') %}
            <div class="sd-flash sd-flash--success" role="alert">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="sd-flash sd-flash--error" role="alert">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="sd-flash sd-flash--info" role="alert">{{ message }}</div>
        {% endfor %}

        {# Contenu de la page — défini par chaque template enfant #}
        <div class="sd-content">
            {% block content %}{% endblock %}
        </div>

    </div>{# fin .sd-main #}

    {#
        Overlay mobile — fond semi-transparent derrière le sidebar ouvert.
        Cliquer dessus déclenche la fermeture du sidebar (géré en JS).
        aria-hidden: true car c'est un élément purement visuel / interactif JS.
    #}
    <div class="sd-overlay" id="sd-overlay" aria-hidden="true"></div>

</div>{# fin .sd-app #}
{% endblock %}

{% block javascripts %}
{{ parent() }}
{#
    Script inline minimal pour le toggle sidebar mobile.
    Pas de dépendance externe — quelques lignes suffisent.

    Principe :
    - Le bouton hamburger (#sd-hamburger) ajoute/retire la classe "sd-side--open"
      sur le sidebar (.sd-side), ce qui déclenche la transition CSS translate.
    - L'overlay (#sd-overlay) reçoit la classe "sd-overlay--visible" pour s'afficher.
    - body.style.overflow = 'hidden' empêche le scroll du fond quand le sidebar est ouvert.
    - Cliquer sur l'overlay referme le sidebar.
    - L'attribut aria-expanded est mis à jour pour l'accessibilité.
#}
<script>
/* ── Toggle sidebar mobile ──────────────────────────────────────────────────
 * Portée IIFE (Immediately Invoked Function Expression) pour éviter de
 * polluer le scope global avec des variables locales.
 */
(function () {
    'use strict';

    var hamburger = document.getElementById('sd-hamburger');
    var side      = document.querySelector('.sd-side');
    var overlay   = document.getElementById('sd-overlay');

    /* Sécurité : on n'attache les événements que si les éléments existent */
    if (!hamburger || !side || !overlay) { return; }

    /* Ouvre le sidebar */
    function openSidebar() {
        side.classList.add('sd-side--open');
        overlay.classList.add('sd-overlay--visible');
        hamburger.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden'; /* bloque le scroll du fond */
    }

    /* Ferme le sidebar */
    function closeSidebar() {
        side.classList.remove('sd-side--open');
        overlay.classList.remove('sd-overlay--visible');
        hamburger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = ''; /* restaure le scroll normal */
    }

    /* Toggle au clic sur le hamburger */
    hamburger.addEventListener('click', function () {
        if (side.classList.contains('sd-side--open')) {
            closeSidebar();
        } else {
            openSidebar();
        }
    });

    /* Ferme au clic sur l'overlay (en dehors du sidebar) */
    overlay.addEventListener('click', closeSidebar);
}());
</script>

{#
    Script de polling pour le badge de notifications en temps réel.

    Principe :
      - À chaque appel (au chargement + toutes les 60 secondes), on interroge l'API
        "/api/notifications/unread-count" qui retourne {"count": N}.
      - Si count > 0 → on affiche le badge #notif-count avec le nombre (ou "99+").
      - Si count = 0 → on masque le badge (display: none).
      - Si l'API est indisponible (réseau, 401...) → comportement silencieux, on ne plante pas.

    Pourquoi 60 secondes ?
      → Bon équilibre entre réactivité et nombre de requêtes (1 req/min par utilisateur actif).
      → En V2, on pourra passer à WebSocket ou Mercure pour du temps réel vrai.

    Prérequis HTML :
      - Un élément avec id="notif-link" portant l'attribut data-api avec l'URL de l'endpoint.
      - Un élément avec id="notif-count" (présent même quand masqué, cf. sidebar_artiste.html.twig).

    Note : cette implémentation utilise du JS vanilla (pas de framework) pour rester
    cohérente avec l'approche minimaliste V1 (Stimulus non encore utilisé ici).
#}
<script>
/* ── Polling badge de notifications ─────────────────────────────────────────
 * IIFE pour ne pas exposer les variables dans le scope global.
 */
(function () {
    'use strict';

    /* Récupère les éléments du DOM */
    var link  = document.getElementById('notif-link');
    var badge = document.getElementById('notif-count');

    /* Si les éléments n'existent pas (page admin, page publique...) → on sort */
    if (!link || !badge) { return; }

    /* L'URL de l'API est passée via data-api sur le lien "Notifications" du sidebar.
     * On utilise un data-attribute plutôt qu'une URL en dur pour rester générique
     * (fonctionne même si le préfixe de route change). */
    var apiUrl = link.dataset.api;

    /* Sécurité : si data-api est absent, on ne fait rien (évite un fetch('undefined')) */
    if (!apiUrl) { return; }

    /**
     * Interroge l'API et met à jour le badge.
     * Erreurs absorbées silencieusement (réseau, 401, 500...) :
     * le polling des notifs est non-critique, on ne veut pas planter la page.
     */
    function poll() {
        fetch(apiUrl, {
            /* credentials: 'same-origin' envoie les cookies de session Symfony
             * → nécessaire pour que la route /api/notifications/unread-count
             *   reconnaisse l'utilisateur connecté. */
            credentials: 'same-origin'
        })
        .then(function (response) {
            /* On n'essaie de parser le JSON que si la réponse est OK (2xx) */
            return response.ok ? response.json() : null;
        })
        .then(function (data) {
            if (!data) { return; } /* Réponse d'erreur ou parsing raté → on ignore */

            var count = data.count || 0;

            if (count > 0) {
                /* Affiche le badge avec le nombre de notifications non lues.
                 * "99+" si plus de 99 pour éviter un badge trop large. */
                badge.textContent = count > 99 ? '99+' : String(count);
                badge.style.display = ''; /* annule le display:none */
                badge.setAttribute('aria-label', count + ' notification(s) non lue(s)');
                badge.removeAttribute('aria-hidden');
            } else {
                /* Masque le badge si plus aucune notification non lue */
                badge.style.display = 'none';
                badge.textContent   = '';
                badge.setAttribute('aria-hidden', 'true');
                badge.removeAttribute('aria-label');
            }
        })
        .catch(function () {
            /* Échec réseau ou autre erreur → comportement silencieux.
             * Le polling reprendra automatiquement à la prochaine itération. */
        });
    }

    /* Premier appel immédiat au chargement de la page (sans attendre 60s) */
    poll();

    /* Puis interrogation périodique toutes les 60 secondes */
    setInterval(poll, 60000);
}());
</script>
{% endblock %}
