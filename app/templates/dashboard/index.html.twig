{% extends 'base_dashboard.html.twig' %}

{#
 # dashboard/index.html.twig — Tableau de bord artiste (thème Street)
 #
 # Variables transmises par DashboardController::index() :
 #   - user            : App\Entity\User — l'utilisateur connecté
 #                       → user.artistProfile (OneToOne) : .displayName, .bio, .location, .websiteUrl
 #   - recent_resources: Resource[]     — 5 dernières ressources publiées
 #   - recent_posts    : Post[]         — 3 derniers posts du fil communauté
 #   - submissions     : int            — nombre total de soumissions de cet utilisateur
 #
 # Fonction Twig disponible : unread_notifications_count()
 #
 # Design : thème Street (v3 — fidèle au prototype "Dashboard Artiste (Street).html")
 #   fond --bg (#F2EFE6), encre --ink (#0D0D0D),
 #   accent vert acide --accent (#C6F24E), accent orange --accent-2 (#FF6B2C)
 #   Typographie : Archivo Black (--display), Space Grotesk (--body), JetBrains Mono (--mono)
 #   Instrument Serif (--serif) pour les accents italiques
 #   Bords FRANCS : border-radius: 0 partout (identité Street)
 #
 # Sections :
 #   1. Profile banner  — bandeau sombre avec avatar, nom, disciplines, lien profil
 #   2. Stats strip     — 4 colonnes colorées (soumissions, ressources, posts, notifs)
 #   3. Grille 2-col    — ressources + communauté | accès rapides + complétude + notifs
 #}

{% block title %}Tableau de bord — BazaArt{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{#
 # ── SIDEBAR ARTISTE ────────────────────────────────────────────────────────
 #
 # Injectée dans le bloc "sidebar" de base_dashboard.html.twig.
 # Structure : logo + pill rôle | sections Mon espace / Explorer / Compte | utilisateur.
 #
 # Détection du lien actif :
 #   app.request.attributes.get('_route') retourne le nom de la route courante.
 #   On compare avec le nom exact de la route pour les liens simples,
 #   ou on utilise "starts with" pour les préfixes (ex: toutes les routes app_forum_*).
 #
 # Routes vérifiées dans src/Controller/ :
 #   app_dashboard           → DashboardController (route exacte)
 #   app_artist_profile_show → ArtistProfileController#show (route "show" sur préfixe "app_artist_profile_")
 #   app_artist_profile_edit → ArtistProfileController#edit
 #   app_resource_my         → ResourceController#my
 #   app_resource_index      → ResourceController#index
 #   app_resource_submit     → ResourceController#submit
 #   app_messaging_index     → MessagingController#index
 #   app_forum_index         → ForumController#index
 #   app_article_index       → ArticleController#index
 #   app_notification_index  → NotificationController#index
 #   app_logout              → AuthController#logout
 #
 # ROUTE ABSENTE dans les controllers : "app_notifications_index" (du brief)
 #   → La vraie route est "app_notification_index" (sans "s"). Corrigé.
 #}
{% block sidebar %}
    {#
        On délègue entièrement le contenu de la sidebar au partial centralisé.
        Ainsi, toute modification de la nav s'applique automatiquement à TOUTES
        les pages du dashboard (candidatures, messages, notifications, etc.).
        Voir : templates/_partials/sidebar_artiste.html.twig
    #}
    {% include '_partials/sidebar_artiste.html.twig' %}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
{#
    Preload des polices utilisées dans le dashboard.
    Archivo Black = --display (titres géants), Space Grotesk = --body, JetBrains Mono = --mono.
    Instrument Serif = --serif (accents italiques dans le nom).
#}
{#
    Pas de <link rel="preload"> ici : base_app.html.twig preload déjà
    archivo-black-400.woff2 et space-grotesk-400.woff2 (via son bloc stylesheets).
    Dupliquer ces déclarations générerait des avertissements navigateur.
#}
<style>

/* ================================================================
   DASHBOARD ARTISTE — Thème Street V3
   Fidèle au prototype "Dashboard Artiste (Street).html"

   Convention de nommage : préfixe .db- pour toutes les classes.
   Tokens CSS : définis dans public/css/design-tokens.css
     --bg, --ink, --accent, --accent-2, --bg-alt, --ink-mute
     --display (Archivo Black), --body (Space Grotesk),
     --mono (JetBrains Mono), --serif (Instrument Serif)
================================================================ */


/* .sd-wordmark-link est défini dans base_dashboard.html.twig (commun à tous les dashboards) */


/* ── 1. PROFILE BANNER ──────────────────────────────────────────
   Bandeau sombre (fond --ink) pleine largeur.
   Reprend le "profile-banner" du prototype : avatar + nom géant
   en Archivo Black, disciplines, chips de rôles, lien profil.

   margin: 0 -32px : déborde du padding .app-content pour coller
   aux bords de la zone principale (symétrique avec padding 32px).
----------------------------------------------------------------- */
.db-banner {
    background: var(--ink);
    color: var(--bg);
    margin: -28px -32px 0;     /* colle en haut et sur les côtés */
    padding: 28px 32px 24px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(242, 239, 230, .10);
}

/* Trait décoratif vertical droit (motif "affiche" Street) */
.db-banner::after {
    content: '';
    position: absolute;
    right: 200px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(242, 239, 230, .08);
}

/* Avatar carré — initiales en Archivo Black */
.db-banner__avatar {
    width: 56px;
    height: 56px;
    background: var(--accent);
    color: var(--ink);
    font-family: var(--display);
    font-size: 20px;
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    /* Street = carré, pas de border-radius */
}

/* Zone centrale : greeting + sous-titre */
.db-banner__body {
    min-width: 0;
}

/* Eyebrow : date en mono discret */
.db-banner__eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .10em;
    text-transform: uppercase;
    color: rgba(242, 239, 230, .45);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Point vert avant la date (identité visuelle Street) */
.db-banner__eyebrow::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--accent);
    flex-shrink: 0;
}

/* Nom géant — "BONJOUR," en Archivo Black blanc + prénom en Instrument Serif italic */
.db-banner__greeting {
    font-family: var(--display);
    font-size: clamp(32px, 5vw, 56px);
    line-height: .9;
    color: var(--bg);
    text-transform: uppercase;
    letter-spacing: -.02em;
    margin: 0 0 12px;
}

/* Partie italique du nom (prénom) — Instrument Serif, non uppercase, orange */
.db-banner__greeting .it {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent-2);
    text-transform: none;
    letter-spacing: -.01em;
}

/* Sous-titre : disciplines / spécialité */
.db-banner__meta {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .10em;
    text-transform: uppercase;
    color: rgba(242, 239, 230, .55);
    margin-bottom: 12px;
}

/* Chips de rôles dans la bannière */
.db-banner__chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
}

/* Chip générique dans la bannière */
.db-bchip {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid rgba(242, 239, 230, .30);
    color: rgba(242, 239, 230, .75);
    border-radius: 0; /* Street */
}

/* Chip accent (lime) — rôle artiste */
.db-bchip--accent {
    background: var(--accent);
    color: var(--ink);
    border-color: var(--accent);
}

/* Chip orange — rôle structure */
.db-bchip--accent2 {
    background: var(--accent-2);
    color: var(--bg);
    border-color: var(--accent-2);
}

/* Zone droite : boîte "URL / profil" */
.db-banner__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    flex-shrink: 0;
}

/* Boîte URL publique */
.db-banner__url-box {
    background: var(--bg-alt);
    color: var(--ink);
    padding: 10px 14px;
    border: 1px solid rgba(242, 239, 230, .20);
    min-width: 160px;
}

.db-banner__url-label {
    display: block;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 4px;
}

.db-banner__url-value {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
}

/* Bouton "Voir mon profil" */
.db-btn-profile {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 8px 14px;
    background: var(--accent);
    color: var(--ink);
    border: 1px solid var(--accent);
    text-decoration: none;
    transition: background .12s, color .12s;
    white-space: nowrap;
    width: 100%;
    text-align: center;
    border-radius: 0;
}

.db-btn-profile:hover {
    background: var(--ink);
    color: var(--accent);
    border-color: var(--accent);
}


/* ── 2. STATS STRIP (4 colonnes colorées) ───────────────────────
   Reprend le "hero-strip" du prototype.
   Chaque colonne a son propre fond coloré, valeur en Archivo Black,
   label en mono uppercase.
   border sur le conteneur, pas de gap (bordures font la séparation).
----------------------------------------------------------------- */
.db-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin: 0 -32px 32px;     /* déborde sur les côtés, espace bas */
    border: 1px solid var(--ink);
    border-top: none;          /* banner du dessus est déjà un séparateur */
}

.db-stat {
    padding: 20px 24px;
    border-right: 1px solid var(--ink);
}

.db-stat:last-child {
    border-right: none;
}

/* Valeur chiffrée en Archivo Black */
.db-stat__value {
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 52px);
    line-height: .9;
    letter-spacing: -.02em;
    color: var(--ink);
}

/* Label sous la valeur */
.db-stat__label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .10em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: .65;
    margin-top: 10px;
}

/* Col 1 : vert acide — soumissions */
.db-stat--lime {
    background: var(--accent);
}

/* Col 2 : orange — ressources */
.db-stat--orange {
    background: var(--accent-2);
}
.db-stat--orange .db-stat__value,
.db-stat--orange .db-stat__label {
    color: var(--bg);
    opacity: 1;
}
.db-stat--orange .db-stat__label {
    opacity: .65;
}

/* Col 3 : fond sombre — posts récents */
.db-stat--dark {
    background: var(--ink);
}
.db-stat--dark .db-stat__value {
    color: var(--accent);
}
.db-stat--dark .db-stat__label {
    color: var(--bg);
}

/* Col 4 : fond sable alternatif — notifications */
.db-stat--alt {
    background: var(--bg-alt);
}


/* ── 3. GRILLE PRINCIPALE ───────────────────────────────────────
   2 colonnes (2fr / 1fr) séparées par une bordure --ink.
   Pas de gap : les bordures font la séparation visuelle (Street).
----------------------------------------------------------------- */
.db-widgets {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0;
    border: 1px solid var(--ink);
}

/* Widget générique */
.db-widget {
    border-right: 1px solid var(--ink);
}

.db-widget:last-child {
    border-right: none;
}

/* En-tête de widget */
.db-widget__head {
    padding: 14px 18px;
    border-bottom: 1px solid var(--ink);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
}

/* Titre en Archivo Black uppercase */
.db-widget__title {
    font-family: var(--display);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--ink);
}

/* Partie italique du titre (Instrument Serif) */
.db-widget__title .it {
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    font-weight: 400;
    letter-spacing: 0;
}

/* Lien "Tout voir →" à droite du titre */
.db-widget__link {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink-mute);
    text-decoration: none;
    white-space: nowrap;
    transition: color .12s;
}

.db-widget__link:hover {
    color: var(--ink);
}


/* ── Lignes de ressources ────────────────────────────────────── */
.db-resource-row {
    display: block;
    padding: 14px 18px;
    border-bottom: 1px solid var(--line-soft);
    text-decoration: none;
    color: var(--ink);
    transition: background .12s;
}

.db-resource-row:last-child {
    border-bottom: none;
}

.db-resource-row:hover {
    background: var(--bg-alt);
}

/* Type de ressource en mono */
.db-resource-row__type {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 4px;
}

/* Titre + flèche */
.db-resource-row__title {
    font-size: 13px;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
}

/* Deadline en mono */
.db-resource-row__meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-mute);
    margin-top: 4px;
}

/* Flèche → (flex-shrink pour qu'elle ne disparaisse pas) */
.db-resource-row__arrow {
    color: var(--ink-mute);
    flex-shrink: 0;
}


/* ── Lignes de posts (communauté) ────────────────────────────── */
.db-post-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--line-soft);
}

.db-post-row:last-child {
    border-bottom: none;
}

/* Avatar carré avec initiales (Street = carré) */
.db-avatar {
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    /* Pas de border-radius — Street */
}

.db-avatar--dark {
    background: var(--ink);
    color: var(--accent);
}

.db-avatar--orange {
    background: var(--accent-2);
    color: var(--bg);
}

.db-post-row__content {
    flex: 1;
    min-width: 0;
}

.db-post-row__name {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    display: inline;
}

.db-post-row__date {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-mute);
    display: inline;
    margin-left: 6px;
}

.db-post-row__text {
    font-size: 12px;
    color: var(--ink-mute);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}


/* ── Colonne droite (aside) ──────────────────────────────────── */
.db-aside {
    display: flex;
    flex-direction: column;
}

/* Grille 2×2 accès rapides */
.db-quicklinks {
    display: grid;
    grid-template-columns: 1fr 1fr;
}

/* Bouton d'accès rapide */
.db-quicklink {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 18px 12px;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    text-align: center;
    border-right: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
    transition: background .12s;
}

.db-quicklink:hover {
    background: var(--accent);
    color: var(--ink);
}

.db-quicklink svg {
    display: block;
    flex-shrink: 0;
}

/* Supprime la bordure droite sur les cellules en colonne 2 */
.db-quicklink:nth-child(2n) {
    border-right: none;
}

/* Supprime la bordure basse sur les deux dernières cellules */
.db-quicklink:nth-last-child(-n+2) {
    border-bottom: none;
}


/* ── Widget complétude du profil ─────────────────────────────── */
.db-complete {
    padding: 16px 18px;
    border-top: 1px solid var(--ink);
    flex: 1;
}

/* En-tête complétude */
.db-complete__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
}

.db-complete__label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink-mute);
}

/* Score en chiffre (ex: "75%") */
.db-complete__score {
    font-family: var(--display);
    font-size: 22px;
    letter-spacing: -.02em;
    color: var(--ink);
}

/* Barre de progression */
.db-complete__bar {
    height: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--line-soft);
    margin-bottom: 14px;
    position: relative;
}

.db-complete__bar-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--accent);
}

/* Liste de vérification */
.db-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.db-checklist li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--ink);
}

/* Case cochée */
.db-check {
    width: 16px;
    height: 16px;
    background: var(--accent);
    border: 1px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* Case non cochée */
.db-check--empty {
    background: var(--bg-alt);
    border-color: var(--line-soft);
}

/* Item non complété : texte atténué */
.db-checklist li.db-todo {
    color: var(--ink-mute);
}

.db-checklist li.db-todo strong {
    color: var(--ink);
    font-weight: 700;
}


/* ── Widget notifications ────────────────────────────────────── */
.db-notif-widget {
    padding: 14px 18px;
    background: var(--accent);
    border-top: 1px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.db-notif-widget__text {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--ink);
}

/* Bouton "Voir →" sombre */
.db-btn-dark {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 7px 14px;
    background: var(--ink);
    color: var(--accent);
    border: 1px solid var(--ink);
    text-decoration: none;
    transition: background .12s, color .12s;
    white-space: nowrap;
    border-radius: 0;
}

.db-btn-dark:hover {
    background: transparent;
    color: var(--ink);
}


/* ── Lien profil en bas de la sidebar ────────────────────────── */
.db-profile-link {
    padding: 14px 18px;
    border-top: 1px solid var(--line-soft);
    margin-top: auto;
}

.db-profile-link a {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color .12s;
}

.db-profile-link a:hover {
    color: var(--ink-mute);
}


/* ── État vide ──────────────────────────────────────────────────
   Affiché quand une liste (ressources, posts) est vide.
----------------------------------------------------------------- */
.db-empty {
    padding: 32px 18px;
    text-align: center;
}

.db-empty__text {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 12px;
}

/* CTA "Soumettre →" dans l'état vide */
.db-empty__link {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 7px 14px;
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    display: inline-block;
    transition: background .12s, color .12s;
    border-radius: 0;
}

.db-empty__link:hover {
    background: var(--accent);
    color: var(--ink);
}


/* ── Responsive mobile ──────────────────────────────────────────
   < 767px : tout passe en 1 colonne.
   margin négatif réduit car le padding mobile est 16px (vs 32px).
----------------------------------------------------------------- */
@media (max-width: 767px) {

    /* La bannière passe en colonne unique sur mobile */
    .db-banner {
        grid-template-columns: auto 1fr;
        margin: -28px -16px 0;
        padding: 20px 16px 16px;
    }

    /* La boîte URL disparaît sur mobile (trop petite) */
    .db-banner__cta {
        display: none;
    }

    /* Stats : 2×2 sur mobile (au lieu de 4 en ligne) */
    .db-stats {
        grid-template-columns: 1fr 1fr;
        margin: 0 -16px 24px;
    }

    /* La 3ème et 4ème stat s'ajustent */
    .db-stat:nth-child(2) {
        border-right: none;
    }
    .db-stat:nth-child(3) {
        border-top: 1px solid var(--ink);
    }
    .db-stat:nth-child(4) {
        border-top: 1px solid var(--ink);
        border-right: none;
    }

    /* Grille : 1 colonne sur mobile */
    .db-widgets {
        grid-template-columns: 1fr;
    }

    /* Widget colonne gauche : no border-right, border-bottom à la place */
    .db-widget {
        border-right: none;
        border-bottom: 1px solid var(--ink);
    }

    .db-widget:last-child {
        border-bottom: none;
    }

    /* Accès rapides : 2×2 conservé */
    .db-quicklinks {
        grid-template-columns: 1fr 1fr;
    }
}

</style>
{% endblock %}

{% block content %}

{#
 # ── Préparation des variables ─────────────────────────────────────────────────
 #
 # On calcule ici toutes les valeurs nécessaires AVANT de les utiliser dans le HTML.
 # Cela évite de mélanger logique et présentation dans le template.
 #}

{# Nombre de notifications non lues (via l'extension Twig NotificationExtension) #}
{% set notifCount = unread_notifications_count() %}

{# Nom d'affichage :
   priorité 1 — displayName du profil artiste
   priorité 2 — partie avant @ de l'email, en majuscules
#}
{% set displayName = (user.artistProfile is not null and user.artistProfile.displayName is not empty)
    ? user.artistProfile.displayName
    : (user.email|split('@')|first|upper) %}

{# Initiales pour l'avatar (2 premiers caractères du displayName) #}
{% set initials = displayName|slice(0, 2)|upper %}

{# Calcul du score de complétude du profil (sur 4 éléments) :
   1. Email vérifié (on considère que si l'utilisateur est connecté, son compte est actif)
   2. Profil artiste créé
   3. Bio renseignée
   4. Localisation renseignée
#}
{% set completenessItems = 4 %}
{% set completenessScore = 1 %} {# email vérifié — toujours acquis #}
{% if user.artistProfile is not null %}
    {% set completenessScore = completenessScore + 1 %}
    {% if user.artistProfile.bio is not null and user.artistProfile.bio is not empty %}
        {% set completenessScore = completenessScore + 1 %}
    {% endif %}
    {% if user.artistProfile.location is not null and user.artistProfile.location is not empty %}
        {% set completenessScore = completenessScore + 1 %}
    {% endif %}
{% endif %}
{% set completenessPercent = ((completenessScore / completenessItems) * 100)|round %}


{# ══════════════════════════════════════════════════════════════════════════════
   1. PROFILE BANNER — bandeau sombre pleine largeur
   Reprend le "profile-banner" du prototype Dashboard Artiste.
   Fond --ink, nom en Archivo Black géant + Instrument Serif italic.
══════════════════════════════════════════════════════════════════════════════ #}
<div class="db-banner">

    {# Avatar carré — initiales en Archivo Black #}
    <div class="db-banner__avatar" aria-hidden="true">
        {{ initials }}
    </div>

    {# Corps central : date + greeting + disciplines + chips rôles #}
    <div class="db-banner__body">

        {# Eyebrow : date du jour en mono discret avec point vert #}
        <div class="db-banner__eyebrow">
            {#
                |date utilise le format PHP (pas ICU).
                "d F Y" → ex : "24 mai 2026" mais la langue dépend de la locale PHP.
                On préfère "d/m/Y" plus sûr sans configuration de locale.
            #}
            {{ "now"|date("d/m/Y") }}
        </div>

        {#
            Greeting géant : "BONJOUR," en blanc + prénom en Instrument Serif italic orange.
            Utilise <p> et non <h1> car base_app.html.twig rend déjà "Tableau de bord"
            dans un <h1 class="topbar__title"> — une seule balise H1 par page (HTML5 + WCAG).
            Le styling est identique au prototype : Archivo Black, clamp 32–56px.
        #}
        <p class="db-banner__greeting">
            Bonjour,<br><span class="it">{{ displayName|e }}.</span>
        </p>

        {#
            Sous-titre : location si disponible, sinon rôle principal.
            Affiché en mono uppercase comme "VIDÉO · MARSEILLE" dans le proto.
            Convention du projet : pas d'emoji dans le code — SVG à la place.
        #}
        <div class="db-banner__meta">
            {% if user.artistProfile is not null and user.artistProfile.location is not null %}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"
                     aria-hidden="true" style="display:inline-block; vertical-align:middle; margin-right:4px; opacity:.7;">
                    <path d="M12 2C8.1 2 5 5.1 5 9c0 5.3 7 13 7 13s7-7.7 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5 14.5 7.6 14.5 9 13.4 11.5 12 11.5z"/>
                </svg>
                {{ user.artistProfile.location|e }}
            {% else %}
                BazaArt · Plateforme
            {% endif %}
        </div>

        {# Chips de rôles — limités aux rôles V1 #}
        <div class="db-banner__chips">
            {% if is_granted('ROLE_ARTIST') %}
                <span class="db-bchip db-bchip--accent">★ Artiste</span>
            {% endif %}
            {% if is_granted('ROLE_STRUCTURE') %}
                <span class="db-bchip db-bchip--accent2">Structure</span>
            {% endif %}
            {% if not is_granted('ROLE_ARTIST') and not is_granted('ROLE_STRUCTURE') %}
                <span class="db-bchip">Membre</span>
            {% endif %}
        </div>

    </div>

    {# Zone droite : URL du profil + bouton (masquée sur mobile) #}
    <div class="db-banner__cta">
        <div class="db-banner__url-box">
            <small class="db-banner__url-label">Profil public</small>
            <span class="db-banner__url-value">
                bazaart.fr/{{ displayName|lower|replace({' ': '-'})|e }}
            </span>
        </div>
        {% if is_granted('ROLE_ARTIST') %}
            <a href="{{ path('app_artist_profile_show') }}" class="db-btn-profile">
                ↗ Voir mon profil
            </a>
        {% elseif is_granted('ROLE_STRUCTURE') %}
            <a href="{{ path('app_structure_dashboard') }}" class="db-btn-profile">
                ↗ Espace Structure
            </a>
        {% else %}
            <a href="{{ path('app_org_profile_show') }}" class="db-btn-profile">
                ↗ Mon organisation
            </a>
        {% endif %}
    </div>

</div>


{# ══════════════════════════════════════════════════════════════════════════════
   2. STATS STRIP — 4 colonnes colorées (inspiré du "hero-strip" du prototype)
   Chaque colonne = 1 métrique clé, fond coloré distinctif.

   TODO V2 : remplacer les 4 stats par :
   Col 1 = candidatures actives | Col 2 = aides obtenues | Col 3 = cumul € | Col 4 = followers
══════════════════════════════════════════════════════════════════════════════ #}
<div class="db-stats" aria-label="Statistiques du tableau de bord">

    {# Stat 1 — vert acide : mes soumissions (données réelles) #}
    <div class="db-stat db-stat--lime">
        <strong class="db-stat__value">{{ submissions|default(0) }}</strong>
        <small class="db-stat__label">Mes soumissions</small>
    </div>

    {# Stat 2 — orange : ressources disponibles dans le feed #}
    <div class="db-stat db-stat--orange">
        <strong class="db-stat__value">{{ recent_resources|length }}</strong>
        <small class="db-stat__label">Ressources récentes</small>
    </div>

    {# Stat 3 — fond sombre : posts récents dans la communauté #}
    <div class="db-stat db-stat--dark">
        <strong class="db-stat__value">{{ recent_posts|length }}</strong>
        <small class="db-stat__label">Posts récents</small>
    </div>

    {# Stat 4 — fond sable alternatif : notifications non lues #}
    <div class="db-stat db-stat--alt">
        <strong class="db-stat__value">{{ notifCount|default(0) }}</strong>
        <small class="db-stat__label">Notifications</small>
    </div>

</div>


{# ══════════════════════════════════════════════════════════════════════════════
   3. GRILLE PRINCIPALE — 2 colonnes (2fr / 1fr)

   Colonne gauche  : Ressources récentes + Communauté (posts)
   Colonne droite  : Accès rapides + Complétude profil + Notifications
══════════════════════════════════════════════════════════════════════════════ #}
<div class="db-widgets">


    {# ── COLONNE GAUCHE ──────────────────────────────────────────────────────── #}
    <div class="db-widget">

        {# ┄┄ Widget A : Ressources récentes ┄┄ #}
        <div class="db-widget__head">
            <span class="db-widget__title">
                Ressources récentes <span class="it">pour toi</span>
            </span>
            <a href="{{ path('app_resource_index') }}" class="db-widget__link">
                Tout voir →
            </a>
        </div>

        {#
            Liste des ressources transmises par le contrôleur (5 dernières publiées).
            Chaque ressource est un lien cliquable vers sa page de détail.
        #}
        {% if recent_resources is defined and recent_resources|length > 0 %}

            {% for resource in recent_resources %}
                <a href="{{ path('app_resource_show', {id: resource.id}) }}" class="db-resource-row">

                    {# Type / catégorie de la ressource (ex: "RÉSIDENCE", "BOURSE") #}
                    <div class="db-resource-row__type">
                        {#
                            `resource.resourceType is not null` avant d'accéder à .name.
                            Twig lève une erreur si on appelle .name sur null.
                            `is not null` est la bonne façon de tester une propriété Doctrine
                            (contrairement à `is defined` qui teste une variable Twig).
                        #}
                        {{ resource.resourceType is not null ? resource.resourceType.name|upper|e : 'Ressource' }}
                    </div>

                    {# Titre de la ressource + flèche alignée à droite #}
                    <div class="db-resource-row__title">
                        <span>{{ resource.title|e }}</span>
                        <span class="db-resource-row__arrow">→</span>
                    </div>

                    {# Deadline si disponible (format : "J-21 · 12 juin") #}
                    {% if resource.deadline is not null %}
                        <div class="db-resource-row__meta">
                            Deadline : {{ resource.deadline|date('d M.') }}
                        </div>
                    {% endif %}

                </a>
            {% endfor %}

        {% else %}

            {# État vide : aucune ressource disponible #}
            <div class="db-empty">
                <div class="db-empty__text">Aucune ressource disponible</div>
                <a href="{{ path('app_resource_submit') }}" class="db-empty__link">
                    Soumettre une ressource →
                </a>
            </div>

        {% endif %}


        {# ┄┄ Widget B : Communauté — posts récents ┄┄ #}
        <div class="db-widget__head" style="border-top: 1px solid var(--ink);">
            <span class="db-widget__title">
                Communauté <span class="it">fil récent</span>
            </span>
            <a href="{{ path('app_post_feed') }}" class="db-widget__link">
                Voir le fil →
            </a>
        </div>

        {#
            Posts récents transmis par le contrôleur (max 3).
            Chaque post a un auteur, un contenu et une date de création.
        #}
        {% if recent_posts is defined and recent_posts|length > 0 %}

            {# Couleurs d'avatar en rotation (3 styles disponibles) #}
            {% set avatarStyles = ['', '--dark', '--orange'] %}

            {% for post in recent_posts %}
                <div class="db-post-row">

                    {# Avatar carré avec initiales (2 premiers chars de l'email de l'auteur) #}
                    <div class="db-avatar db-avatar{{ avatarStyles[loop.index0] }}"
                         aria-hidden="true">
                        {{ post.author.email|slice(0, 2)|upper }}
                    </div>

                    <div class="db-post-row__content">
                        <div>
                            {# Pseudo (partie avant @ de l'email) #}
                            <span class="db-post-row__name">
                                {{ post.author.email|split('@')|first|e }}
                            </span>
                            {# Date en format court #}
                            <span class="db-post-row__date">
                                · {{ post.createdAt|date('d/m') }}
                            </span>
                        </div>

                        {#
                            Extrait du post tronqué à 90 caractères.
                            |e pour l'échappement XSS — contenu utilisateur.
                            Note du reviewer : post.content|slice(0, 90) sans |e était
                            une faille XSS signalée dans l'audit précédent — corrigé ici.
                        #}
                        <div class="db-post-row__text">
                            {{ post.content|slice(0, 90)|e }}{% if post.content|length > 90 %}…{% endif %}
                        </div>
                    </div>

                </div>
            {% endfor %}

        {% else %}

            <div class="db-empty" style="padding: 20px 18px;">
                <div class="db-empty__text">Aucune publication récente</div>
            </div>

        {% endif %}

        {# TODO V2 : ajouter ici la section "Mes candidatures" avec barres de progression #}
        {# TODO V2 : ajouter le widget "Agenda / Cette semaine" (mini calendrier) #}

    </div>{# fin .db-widget colonne gauche #}


    {# ── COLONNE DROITE ──────────────────────────────────────────────────────── #}
    <div class="db-widget db-aside">

        {# ┄┄ Widget C : Accès rapides (grille 2×2) ┄┄ #}
        <div class="db-widget__head">
            <span class="db-widget__title">Accès rapides</span>
        </div>

        {#
            Grille 2×2 de liens d'action fréquents.
            Icônes SVG inline (pas de dépendance externe — choix V1).
            Hover : fond --accent (lime) pour l'affordance visuelle.
        #}
        <div class="db-quicklinks">

            {# 1. Explorer les ressources #}
            <a href="{{ path('app_resource_index') }}"
               class="db-quicklink"
               title="Explorer toutes les ressources">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.7"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
                </svg>
                Ressources
            </a>

            {# 2. Mes favoris #}
            <a href="{{ path('app_resource_favorites') }}"
               class="db-quicklink"
               title="Mes ressources favorites">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.7"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21s-7-4.5-9.5-9C.7 8 3 4 6.5 4 9 4 10.5 5.5 12 7.5 13.5 5.5 15 4 17.5 4 21 4 23.3 8 21.5 12 19 16.5 12 21 12 21z"/>
                </svg>
                Favoris
            </a>

            {# 3. Forum #}
            <a href="{{ path('app_forum_index') }}"
               class="db-quicklink"
               title="Aller au forum">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.7"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9 8.5 8.5 0 0 1 8.5 8.5z"/>
                </svg>
                Forum
            </a>

            {# 4. Messagerie privée #}
            <a href="{{ path('app_messaging_index') }}"
               class="db-quicklink"
               title="Messagerie privée">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.7"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="4" width="20" height="16"/>
                    <path d="m2 4 10 9 10-9"/>
                </svg>
                Messages
            </a>

        </div>{# fin .db-quicklinks #}


        {# ┄┄ Widget D : Notifications non lues ┄┄
           Affiché uniquement si notifCount > 0.
           Fond vert acide (--accent) pour attirer l'attention.
        #}
        {% if notifCount > 0 %}
            <div class="db-notif-widget">
                <span class="db-notif-widget__text">
                    {# Accords français : "1 notification" vs "X notifications" #}
                    {{ notifCount }} notification{{ notifCount > 1 ? 's' : '' }}
                    non lue{{ notifCount > 1 ? 's' : '' }}
                </span>
                <a href="{{ path('app_notification_index') }}" class="db-btn-dark">
                    Voir →
                </a>
            </div>
        {% endif %}


        {# ┄┄ Widget E : Complétude du profil ┄┄
           Checklist semi-statique : vérifie si les champs clés sont remplis.
           Score calculé dans la section Préparation en haut du template.
        #}
        <div class="db-complete">

            <div class="db-complete__head">
                <span class="db-complete__label">Mon profil</span>
                <span class="db-complete__score">{{ completenessPercent }}%</span>
            </div>

            {# Barre de progression proportionnelle au score #}
            <div class="db-complete__bar" role="progressbar"
                 aria-valuenow="{{ completenessPercent }}"
                 aria-valuemin="0" aria-valuemax="100"
                 aria-label="Complétude du profil : {{ completenessPercent }}%">
                <div class="db-complete__bar-fill" style="width: {{ completenessPercent }}%;"></div>
            </div>

            {# Checklist des éléments de complétude #}
            <ul class="db-checklist">

                {# Élément 1 : compte actif (toujours acquis si connecté) #}
                <li>
                    <span class="db-check" aria-hidden="true">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="3.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="m5 12 5 5L20 7"/>
                        </svg>
                    </span>
                    Compte actif
                </li>

                {# Élément 2 : profil artiste créé #}
                {% if user.artistProfile is not null %}
                    <li>
                        <span class="db-check" aria-hidden="true">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="3.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="m5 12 5 5L20 7"/>
                            </svg>
                        </span>
                        Profil artiste créé
                    </li>
                {% else %}
                    <li class="db-todo">
                        <span class="db-check db-check--empty" aria-hidden="true"></span>
                        <strong>Profil artiste</strong> · à créer
                    </li>
                {% endif %}

                {# Élément 3 : biographie renseignée #}
                {% if user.artistProfile is not null and user.artistProfile.bio is not null and user.artistProfile.bio is not empty %}
                    <li>
                        <span class="db-check" aria-hidden="true">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="3.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="m5 12 5 5L20 7"/>
                            </svg>
                        </span>
                        Biographie
                    </li>
                {% else %}
                    <li class="db-todo">
                        <span class="db-check db-check--empty" aria-hidden="true"></span>
                        <strong>Biographie</strong> · à rédiger
                    </li>
                {% endif %}

                {# Élément 4 : localisation renseignée #}
                {% if user.artistProfile is not null and user.artistProfile.location is not null and user.artistProfile.location is not empty %}
                    <li>
                        <span class="db-check" aria-hidden="true">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="3.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="m5 12 5 5L20 7"/>
                            </svg>
                        </span>
                        Ville / localisation
                    </li>
                {% else %}
                    <li class="db-todo">
                        <span class="db-check db-check--empty" aria-hidden="true"></span>
                        <strong>Localisation</strong> · à ajouter
                    </li>
                {% endif %}

            </ul>

            {# TODO V2 : ajouter vidéo de présentation, lien portfolio externe, disciplines #}

        </div>{# fin .db-complete #}


        {# ┄┄ Lien profil en bas de la sidebar ┄┄ #}
        <div class="db-profile-link">
            {% if is_granted('ROLE_ARTIST') %}
                <a href="{{ path('app_artist_profile_show') }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.7"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 21a8 8 0 0 1 16 0"/>
                    </svg>
                    Mon profil artiste →
                </a>
            {% elseif is_granted('ROLE_STRUCTURE') %}
                <a href="{{ path('app_structure_dashboard') }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.7"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 11 12 4l9 7v9h-6v-6h-6v6H3z"/>
                    </svg>
                    Espace Structure →
                </a>
            {% else %}
                <a href="{{ path('app_org_profile_show') }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.7"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 21a8 8 0 0 1 16 0"/>
                    </svg>
                    Mon organisation →
                </a>
            {% endif %}
        </div>

    </div>{# fin .db-widget.db-aside colonne droite #}

</div>{# fin .db-widgets #}

{% endblock %}
