{% extends 'base_dashboard.html.twig' %}

{#
 # live/index.html.twig — Calendrier des lives planifiés
 #
 # Affiche deux sections :
 #   1. Les prochains lives SCHEDULED (inscription possible)
 #   2. Les replays disponibles (lives ENDED avec replayUrl)
 #
 # Variables injectées par LiveController::index() :
 #   - upcomingLives : Live[] — les prochains lives planifiés
 #   - pastLives     : Live[] — les lives terminés avec replay
 #
 # Thème Street : border-radius 0, tokens --ink / --accent / --accent-2
 # Préfixe CSS : .lv- (live)
 #}

{% block title %}Lives — BazaArt{% endblock %}
{% block page_title %}Lives & Replays{% endblock %}

{% block sidebar %}
    {% include '_partials/sidebar_artiste.html.twig' %}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ── Styles spécifiques aux pages Lives — préfixe .lv- ────────────────────────
 * Design Street : border-radius: 0 partout, bordures ink 1px.
 * Tokens CSS utilisés :
 *   --bg (#F2EFE6)     --bg-alt (#EAE6D9)
 *   --ink (#0D0D0D)    --ink-mute (#5b584f)
 *   --accent (#C6F24E) — vert acide (SCHEDULED)
 *   --accent-2 (#FF6B2C) — orange (EN DIRECT / action)
 *   --display (Archivo Black)  --body (Space Grotesk)  --mono (JetBrains Mono)
 */

/* ── En-tête de section ────────────────────────────────────────────────────── */
.lv-section-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--ink);
}
.lv-section-title {
    font-family: var(--display);
    font-size: 18px;
    font-weight: 400;
    color: var(--ink);
    margin: 0;
}
.lv-section-count {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: .08em;
}

/* ── Grille de cartes ──────────────────────────────────────────────────────── */
.lv-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
}

/* ── Carte live ────────────────────────────────────────────────────────────── */
.lv-card {
    background: #fff;
    border: 1px solid var(--ink);
    /* border-radius: 0 — Street, pas d'arrondi */
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .12s ease, transform .12s ease;
}
.lv-card:hover {
    box-shadow: 3px 3px 0 var(--ink);
    transform: translate(-2px, -2px);
}

/* Image de couverture du live — optionnelle */
.lv-card__cover {
    width: 100%;
    height: 140px;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--ink);
}

/* Placeholder si pas d'image de couverture */
.lv-card__cover-placeholder {
    width: 100%;
    height: 140px;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--ink);
}
.lv-card__cover-placeholder-text {
    font-family: var(--display);
    font-size: 28px;
    color: var(--accent);
    letter-spacing: -.02em;
}

/* Corps de la carte */
.lv-card__body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

/* Badge de statut */
.lv-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid currentColor;
}
.lv-badge--scheduled { color: var(--accent); background: rgba(198,242,78,.12); border-color: var(--accent); }
.lv-badge--live      { color: var(--accent-2); background: rgba(255,107,44,.12); border-color: var(--accent-2); }
.lv-badge--ended     { color: var(--ink-mute); background: transparent; }
.lv-badge--cancelled { color: #999; background: transparent; text-decoration: line-through; }

/* Titre de la carte */
.lv-card__title {
    font-family: var(--display);
    font-size: 15px;
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    line-height: 1.3;
}

/* Date du live */
.lv-card__date {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-mute);
    display: flex;
    align-items: center;
    gap: 6px;
}
.lv-card__date-icon {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    flex-shrink: 0;
}

/* Hôte */
.lv-card__host {
    font-size: 12px;
    color: var(--ink-mute);
    font-family: var(--body);
}
.lv-card__host strong { color: var(--ink); }

/* Pied de carte — bouton ou lien replay */
.lv-card__footer {
    padding: 12px 16px;
    border-top: 1px solid rgba(13,13,13,.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

/* Bouton principal (s'inscrire / voir) */
.lv-btn {
    font-family: var(--body);
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    cursor: pointer;
    transition: background .12s ease, color .12s ease;
    white-space: nowrap;
}
.lv-btn:hover { background: var(--accent); color: var(--ink); border-color: var(--accent); }

/* Bouton secondaire */
.lv-btn--secondary {
    background: transparent;
    color: var(--ink);
    border-color: var(--ink);
}
.lv-btn--secondary:hover { background: var(--bg-alt); }

/* ── État vide ─────────────────────────────────────────────────────────────── */
.lv-empty {
    text-align: center;
    padding: 40px 20px;
    border: 1px dashed rgba(13,13,13,.2);
    color: var(--ink-mute);
    font-family: var(--body);
    font-size: 14px;
    margin-bottom: 40px;
}
.lv-empty strong { display: block; font-size: 16px; margin-bottom: 6px; color: var(--ink); }
</style>
{% endblock %}

{% block content %}

{# ── Section 1 : Prochains lives planifiés ─────────────────────────────────── #}
<div class="lv-section-header">
    <h2 class="lv-section-title">Prochains lives</h2>
    {% if upcomingLives|length > 0 %}
        <span class="lv-section-count">{{ upcomingLives|length }} à venir</span>
    {% endif %}
</div>

{% if upcomingLives is empty %}
    {# Message affiché quand aucun live n'est planifié #}
    <div class="lv-empty">
        <strong>Aucun live planifié pour l'instant</strong>
        Revenez bientôt — de nouveaux lives sont régulièrement programmés.
    </div>
{% else %}
    <div class="lv-grid">
        {% for live in upcomingLives %}
        {#
            Chaque carte est un lien vers la page de détail du live.
            <a href="..."> entoure la carte entière pour faciliter le clic.
        #}
        <a href="{{ path('app_live_show', {id: live.id}) }}" class="lv-card">

            {# Image de couverture ou placeholder avec les initiales du titre #}
            {% if live.coverImageUrl %}
                <img src="{{ live.coverImageUrl|e }}"
                     alt="Couverture de {{ live.title|e }}"
                     class="lv-card__cover">
            {% else %}
                {# Placeholder Street : fond noir, 2 premières lettres en vert acide #}
                <div class="lv-card__cover-placeholder" aria-hidden="true">
                    <span class="lv-card__cover-placeholder-text">
                        {{ live.title|upper|slice(0, 2) }}
                    </span>
                </div>
            {% endif %}

            <div class="lv-card__body">

                {# Badge de statut — utilise la méthode badgeClass() de l'enum LiveStatus #}
                <span class="{{ live.status.badgeClass() }} lv-badge">
                    {{ live.status.label() }}
                </span>

                <h3 class="lv-card__title">{{ live.title|e }}</h3>

                {# Date et heure du live, formatées en français #}
                <div class="lv-card__date">
                    {# Icône calendrier SVG #}
                    <svg class="lv-card__date-icon" viewBox="0 0 24 24" aria-hidden="true"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="0" ry="0"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    {# Twig date() avec locale FR — affiche "lundi 2 juin 2026 à 19h00" #}
                    {{ live.scheduledAt|date('d/m/Y à H\\hi') }}
                </div>

                {# Hôte du live #}
                <div class="lv-card__host">
                    Animé par <strong>{{ live.hostedBy.email|split('@')|first|e }}</strong>
                </div>

            </div>

            <div class="lv-card__footer">
                <span class="lv-btn">Voir le live</span>
                {# Compteur d'inscrits — info rapide sans ouvrir la page de détail #}
                <span style="font-family: var(--mono); font-size: 11px; color: var(--ink-mute);">
                    {{ live.attendees|length }} inscrit(s)
                </span>
            </div>

        </a>
        {% endfor %}
    </div>
{% endif %}

{# ── Section 2 : Replays disponibles ──────────────────────────────────────── #}
<div class="lv-section-header">
    <h2 class="lv-section-title">Replays</h2>
    {% if pastLives|length > 0 %}
        <span class="lv-section-count">{{ pastLives|length }} disponible(s)</span>
    {% endif %}
</div>

{% if pastLives is empty %}
    <div class="lv-empty">
        <strong>Aucun replay disponible pour le moment</strong>
        Les replays des lives seront publiés ici après chaque diffusion.
    </div>
{% else %}
    <div class="lv-grid">
        {% for live in pastLives %}
        <div class="lv-card" style="text-decoration:none; color:inherit;">

            {% if live.coverImageUrl %}
                <img src="{{ live.coverImageUrl|e }}"
                     alt="Couverture de {{ live.title|e }}"
                     class="lv-card__cover">
            {% else %}
                <div class="lv-card__cover-placeholder" aria-hidden="true">
                    <span class="lv-card__cover-placeholder-text">
                        {{ live.title|upper|slice(0, 2) }}
                    </span>
                </div>
            {% endif %}

            <div class="lv-card__body">
                <span class="{{ live.status.badgeClass() }} lv-badge">Replay</span>
                <h3 class="lv-card__title">{{ live.title|e }}</h3>
                <div class="lv-card__date">
                    <svg class="lv-card__date-icon" viewBox="0 0 24 24" aria-hidden="true"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    Diffusé le {{ live.scheduledAt|date('d/m/Y') }}
                </div>
            </div>

            <div class="lv-card__footer">
                {#
                    Lien direct vers le replay externe.
                    target="_blank" + rel="noopener noreferrer" : sécurité (évite tabnapping).
                #}
                <a href="{{ live.replayUrl|e }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="lv-btn"
                   aria-label="Voir le replay de {{ live.title|e }}">
                    Voir le replay
                </a>
                <a href="{{ path('app_live_show', {id: live.id}) }}"
                   class="lv-btn lv-btn--secondary">
                    Détail
                </a>
            </div>

        </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
