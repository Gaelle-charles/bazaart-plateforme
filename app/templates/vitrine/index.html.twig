{# Overlay affiché quand l'utilisateur clique sur "Faire un don" #}
<div id="haWidgetModal" style="
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(15px) brightness(0.5);
  z-index: 2147483647;
">
  {# Bouton de fermeture #}
  <button id="closeHaWidgetBtn" style="
    position: absolute;
    top: 20px;
    right: 24px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 1.6rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  " aria-label="Fermer">✕</button>

  {# Iframe HelloAsso #}
  <div style="
    width: min(680px, 95vw);
    height: min(750px, 90vh);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
  ">
    <iframe
      id="haWidget"
      src="https://www.helloasso.com/associations/bazaart/formulaires/2/widget?view=overlay"
      style="width: 100%; height: 100%; border: none;"
      title="Faire un don à BazaArt via HelloAsso"
    ></iframe>
  </div>
</div>

<script>
  // Ouvrir le modal don HelloAsso
  document.getElementById('openHaOverlay').addEventListener('click', function () {
    var modal = document.getElementById('haWidgetModal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden'; // empêche le scroll derrière
  });

  // Fermer le modal via le bouton ✕
  document.getElementById('closeHaWidgetBtn').addEventListener('click', function () {
    document.getElementById('haWidgetModal').style.display = 'none';
    document.body.style.overflow = '';
  });

  // Fermer le modal en cliquant sur l'overlay (hors iframe)
  document.getElementById('haWidgetModal').addEventListener('click', function (e) {
    if (e.target === this) {
      this.style.display = 'none';
      document.body.style.overflow = '';
    }
  });

  // Fermer le modal avec la touche Echap
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.getElementById('haWidgetModal').style.display = 'none';
      document.body.style.overflow = '';
    }
  });
</script>

