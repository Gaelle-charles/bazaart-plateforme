                </div>
            </div>

        </section>{# /.lp-hero #}


        {# ════════════════════════════════════════════════════════════════
           4. SECTION HUBS — Les 3 pôles de l'association
           Grille 3 colonnes avec bordures partagées (style grille d'affiche).
           Données statiques — fidèles au prototype LandingManifesto.
        ════════════════════════════════════════════════════════════════ #}
        <section class="lp-hubs lp-container" aria-labelledby="lp-hubs-title">

            {# Section header avec index, titre, sous-titre #}
            <div class="lp-section-header">
                <div class="lp-section-header__left">
                    <span class="lp-section-header__index" aria-hidden="true">01</span>
                    <h2 class="lp-section-header__title" id="lp-hubs-title">
                        Les trois hubs de l'asso
                    </h2>
                    <span class="lp-section-header__sub">événement · ingénierie · transmission</span>
                </div>
            </div>

            {# Grille des 3 hubs #}
            <div class="lp-hubs__grid">

                {# ── Hub 01 : EVENT ── #}
                <article class="lp-hub lp-hub--bordered" aria-labelledby="lp-hub-event-title">
                    <div class="lp-hub__header">
