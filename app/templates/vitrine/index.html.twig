        {# ════════════════════════════════════════════════════════════════
           8. SECTION CTA — Inscription gratuite
           Fond --accent (lime). Adapté V1 : pas de pricing.
           La plateforme est gratuite en V1 — on propose l'inscription directe.

           POURQUOI ne pas reproduire le pricing du prototype ?
           → Le CDC V3 (section 4) confirme : "V1 = pas de Stripe, pas de tarifs".
             Le prototype avait un pricing 9,90€ qui n'est pas V1. On le remplace
             par un CTA d'inscription simple + formulaire email inline.
        ════════════════════════════════════════════════════════════════ #}
        <section class="lp-cta" id="section-cta" aria-labelledby="lp-cta-title">
            <div class="lp-container">
                <div class="lp-cta__grid">

                    {# ── Colonne gauche : titre + message ── #}
                    <div>
                        {# Eyebrow adapté — couleur ink sur fond lime #}
                        <span class="lp-eyebrow lp-cta__eyebrow">
                            Gratuit en 2026
                        </span>
                        {#
                            H2 géant — message simple et direct.
                            "Rejoindre gratuitement." = clair sur la gratuité V1.
                        #}
                        <h2 class="lp-cta__h2" id="lp-cta-title">
                            Rejoindre<br>
                            gratuitement.
                        </h2>
                    </div>

                    {# ── Colonne droite : formulaire email + bouton ── #}
                    <div>
                        {#
                            Formulaire : action → page d'inscription (app_register).
                            Le formulaire Symfony complet est sur cette page.
                            Ici on pré-remplit juste l'email pour fluidifier le parcours.
                            BACK : le contrôleur app_register peut récupérer le param
                            "email" en GET pour pré-remplir le champ email du formulaire.
                        #}
                        <form class="lp-cta__form" action="{{ path('app_register') }}" method="get" aria-label="Formulaire d'inscription rapide">
                            <label for="lp-email-input" class="sr-only">Votre adresse email</label>
                            <input
                                type="email"
                                id="lp-email-input"
                                name="email"
                                class="lp-cta__input"
                                placeholder="ton@email.fr"
                                autocomplete="email"
                            >
                            <button type="submit" class="lp-btn lp-btn--dark" style="width:100%;justify-content:center;font-size:13px;padding:14px 20px;">
                                Créer mon compte
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M5 12h14M13 5l7 7-7 7"/>
                                </svg>
                            </button>
                        </form>
                        {# Lien "Déjà membre" discret #}
                        <p class="lp-cta__legal" style="margin-top:12px;">
                            Déjà membre ?
                            <a href="{{ path('app_login') }}" style="color:var(--ink);text-decoration:underline;text-underline-offset:3px;">
                                Se connecter
                            </a>
                            · Aucun paiement requis.
                        </p>
                    </div>

                </div>{# /.lp-cta__grid #}
            </div>{# /.lp-container #}
        </section>

    </main>


    {# ════════════════════════════════════════════════════════════════════════
       9. FOOTER
       Reproduit fidèlement le Footer du prototype JSX.
       Logo géant en lime, 2 colonnes de liens (Plateforme + Légal).
       Note : les routes /confidentialite, /cgu, /mentions-legales n'existent
       pas encore.
       BACK : créer les pages statiques via un StaticController avec ces routes.
    ════════════════════════════════════════════════════════════════════════ #}
    <footer class="lp-footer" role="contentinfo">
        <div class="lp-container">

            {# Logo géant — style affiche, opacité réduite #}
            <span class="lp-footer__logo" aria-label="BazaArt">BAZAART.</span>

            {# Grille : description + 2 colonnes de liens #}
            <div class="lp-footer__grid">

                {# Colonne description #}
                <div>
                    <span class="lp-eyebrow lp-eyebrow--nodot" style="color:rgba(242,239,230,.4);">
                        L'asso
                    </span>
                    <p class="lp-footer__about">
                        Association loi 1901 basée à Paris, opérant la plateforme BazaArt
                        et trois hubs : événementiel, ingénierie culturelle et formation.
                    </p>
                    <p class="lp-footer__address">
                        PARIS, FRANCE<br>
                        ASSOCIATION LOI 1901
                    </p>
                </div>

                {# Colonne Plateforme #}
                <nav aria-label="Liens plateforme">
                    <p class="lp-footer__col-title">Plateforme</p>
                    <ul class="lp-footer__links" role="list">
                        <li><a href="{{ path('app_resource_index') }}">Ressources</a></li>
                        {# BACK : route app_forum_index → /forum #}
                        <li><a href="#">Forum</a></li>
                        {# BACK : route app_dashboard (artiste) #}
                        <li><a href="#">Dashboard</a></li>
                    </ul>
                </nav>

                {# Colonne Légal #}
                <nav aria-label="Liens légaux">
                    <p class="lp-footer__col-title">Légal</p>
                    <ul class="lp-footer__links" role="list">
                        {# BACK : route app_privacy → /confidentialite (StaticController) #}
                        <li><a href="/confidentialite">Confidentialité</a></li>
                        {# BACK : route app_cgu → /cgu (StaticController) #}
                        <li><a href="/cgu">CGU</a></li>
                        {# BACK : route app_mentions_legales → /mentions-legales #}
                        <li><a href="/mentions-legales">Mentions légales</a></li>
                    </ul>
                </nav>

            </div>{# /.lp-footer__grid #}

            {# Barre de copyright #}
            <div class="lp-footer__copy">
                <span>© 2026 BAZAART — ASSOCIATION LOI 1901</span>
                <span>v1.0 · PARIS, FRANCE</span>
            </div>

        </div>{# /.lp-container #}
    </footer>

</div>{# /.lp-root #}
