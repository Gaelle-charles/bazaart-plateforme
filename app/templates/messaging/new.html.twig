{% extends 'base_dashboard.html.twig' %}

{% block sidebar %}
    {# Sidebar commune à toutes les pages du dashboard artiste — voir _partials/sidebar_artiste.html.twig #}
    {% include '_partials/sidebar_artiste.html.twig' %}
{% endblock %}

{% block title %}Démarrer une conversation avec {{ otherUser.email|split('@')|first }} — BazaArt{% endblock %}
{% block page_title %}Messages{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

/* ================================================================
   MESSAGERIE — Nouvelle conversation (thème Street)
   Préfixe : .new-conv- pour éviter toute collision

   Migration des tokens : ancien système → thème Street
     --color-text        → var(--ink, #0D0D0D)
     --color-text-light  → rgba(13, 13, 13, .38)
     --color-white       → var(--bg, #F2EFE6)
     --color-border      → var(--line, rgba(13, 13, 13, .18))
     --color-red         → var(--accent-2, #FF6B2C) pour le focus
     --color-orange      → var(--accent-2, #FF6B2C)
     --font-heading      → var(--display, 'Archivo Black', sans-serif)
     --radius-sm/md      → 0  (Street : bords francs, jamais de coins ronds)
     --shadow-card       → supprimé (Street : pas d'ombres, bordures suffisent)
================================================================ */

/* ── En-tête de section ─────────────────────────────────────────
   Ligne avec bouton retour | avatar carré | titre + sous-titre
----------------------------------------------------------------- */
.new-conv-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
}

.new-conv-header__back {
    /* Bouton "←" — texte muted, sans fond par défaut */
    color: rgba(13, 13, 13, .38); /* remplace --color-text-light */
    text-decoration: none;
    font-size: 20px;
    padding: 4px;
    border-radius: 0; /* Street : bords francs, on supprime le radius: 4px */
    transition: background var(--transition-fast, 0.12s);
}

.new-conv-header__back:hover {
    background: var(--bg-alt, #E8E5DC); /* remplace #f0f0f0 */
    color: var(--ink, #0D0D0D);         /* remplace --color-text */
}

.new-conv-header__avatar {
    width: 44px;
    height: 44px;
    /* Street : avatar CARRÉ — border-radius: 0, pas de cercle */
    border-radius: 0;
    /* Fond accent-2 (orange) à la place de l'ancien --color-orange */
    background: var(--accent, #C6F24E);
    color: var(--ink, #0D0D0D);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
    border: 1px solid var(--ink, #0D0D0D);
}

.new-conv-header__info { }

.new-conv-header__title {
    /* Archivo Black remplace --font-heading */
    font-family: var(--display, 'Archivo Black', sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--ink, #0D0D0D); /* remplace --color-text */
    text-transform: uppercase;
    letter-spacing: .02em;
}

.new-conv-header__subtitle {
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    letter-spacing: .04em;
    color: rgba(13, 13, 13, .38); /* remplace --color-text-light */
    margin-top: 4px;
}

/* ── Carte formulaire ───────────────────────────────────────────
   Street : fond sable (--bg), bordure --ink, ZÉRO radius, ZÉRO ombre
----------------------------------------------------------------- */
.new-conv-card {
    background: var(--bg, #F2EFE6);        /* remplace --color-white */
    border: 1px solid var(--ink, #0D0D0D); /* remplace --color-border + renforce le contraste */
    border-radius: 0;                       /* remplace --radius-md */
    /* box-shadow supprimé — thème Street n'utilise pas d'ombres */
    padding: 28px;
    max-width: 640px;
}

.new-conv-card__label {
    display: block;
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink, #0D0D0D); /* remplace --color-text */
    margin-bottom: 8px;
}

.new-conv-card__textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--line, rgba(13, 13, 13, .18)); /* remplace --color-border */
    border-radius: 0;                                      /* remplace --radius-sm */
    background: var(--bg, #F2EFE6);
    font-size: 14px;
    font-family: var(--body, 'Space Grotesk', sans-serif);
    color: var(--ink, #0D0D0D);  /* remplace --color-text */
    resize: vertical;
    min-height: 120px;
    transition: border-color var(--transition-fast, 0.15s);
    box-sizing: border-box;
}

.new-conv-card__textarea:focus {
    outline: none;
    /* Focus : bordure accent-2 (orange) remplace --color-red */
    border-color: var(--accent-2, #FF6B2C);
    border-width: 2px;
    /* box-shadow de focus supprimé — Street préfère un feedback par épaisseur de bordure */
}

.new-conv-card__textarea::placeholder {
    color: rgba(13, 13, 13, .38); /* remplace --color-text-light */
}

.new-conv-card__hint {
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    letter-spacing: .03em;
    color: rgba(13, 13, 13, .55); /* légèrement plus lisible que .38 pour une note */
    margin-top: 6px;
}

/* ── Actions du formulaire ──────────────────────────────────────
   Bouton principal : fond --ink, hover lime (accent)
   Bouton annuler   : texte muted, hover bg-alt
----------------------------------------------------------------- */
.new-conv-card__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
}

.btn-send {
    padding: 10px 22px;
    /* Street : bouton CTA = fond sombre --ink, texte --bg */
    background: var(--ink, #0D0D0D);
    color: var(--bg, #F2EFE6);
    border: 1px solid var(--ink, #0D0D0D);
    border-radius: 0; /* remplace --radius-sm */
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--transition-fast, 0.15s), color var(--transition-fast, 0.15s);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.btn-send:hover {
    /* Hover : lime (accent) avec texte --ink — cohérent avec msg-btn-new dans index.html.twig */
    background: var(--accent, #C6F24E);
    color: var(--ink, #0D0D0D);
}

.btn-cancel {
    font-family: var(--mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: rgba(13, 13, 13, .38); /* remplace --color-text-light */
    text-decoration: none;
    padding: 10px;
    border-radius: 0;  /* remplace --radius-sm */
    transition: background var(--transition-fast, 0.12s);
}

.btn-cancel:hover {
    background: var(--bg-alt, #E8E5DC); /* remplace #f0f0f0 */
    color: var(--ink, #0D0D0D);         /* remplace --color-text */
}

</style>
{% endblock %}

{% block content %}

{# ── En-tête ──────────────────────────────────────────────────────────────────── #}
<div class="new-conv-header">
    {# Retour vers la liste des messages (ou vers l'annuaire) #}
    <a href="{{ path('app_messaging_index') }}" class="new-conv-header__back" title="Retour aux messages">
        ←
    </a>

    {# Avatar de l'interlocuteur #}
    <div class="new-conv-header__avatar">
        {{ otherUser.email|split('@')|first|slice(0, 2)|upper }}
    </div>

    <div class="new-conv-header__info">
        <div class="new-conv-header__title">
            Démarrer une conversation avec {{ otherUser.email|split('@')|first }}
        </div>
        <div class="new-conv-header__subtitle">
            Votre message sera privé et visible uniquement par vous deux.
        </div>
    </div>
</div>

{# ── Formulaire du premier message ────────────────────────────────────────────── #}
<div class="new-conv-card">

    <form method="POST"
          action="{{ path('app_messaging_new', { userId: otherUser.id }) }}">

        {#
            Token CSRF pour la création d'une nouvelle conversation.
            Un token unique par formulaire — valide 1 heure par défaut dans Symfony.
        #}
        <input type="hidden" name="_token" value="{{ csrf_token('messaging_new') }}">

        <label for="message-content" class="new-conv-card__label">
            Votre message
        </label>

        <textarea
            id="message-content"
            name="content"
            class="new-conv-card__textarea"
            placeholder="Écrivez votre premier message à {{ otherUser.email|split('@')|first }}..."
            rows="5"
            maxlength="5000"
            required
            autofocus></textarea>

        <p class="new-conv-card__hint">
            Maximum 5 000 caractères. Le contenu est en texte brut (pas de mise en forme).
        </p>

        <div class="new-conv-card__actions">
            <button type="submit" class="btn-send">
                Envoyer le message
            </button>
            <a href="{{ path('app_messaging_index') }}" class="btn-cancel">
                Annuler
            </a>
        </div>

    </form>

</div>

{% endblock %}
