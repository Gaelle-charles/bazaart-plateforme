{% extends 'base_app.html.twig' %}

{% block title %}Conversation avec {{ otherUser ? otherUser.email|split('@')|first : 'quelqu\'un' }} — BazaArt{% endblock %}
{% block page_title %}Messages{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ── Layout de la page conversation ── */
    .conversation-page {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 56px - 56px); /* viewport - topbar - padding */
        max-height: 800px;
    }

    /* ── En-tête de la conversation ── */
    .conv-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 0 16px;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 0;
        flex-shrink: 0;
    }
    .conv-header__back {
        color: var(--color-text-light);
        text-decoration: none;
        font-size: 18px;
        line-height: 1;
        padding: 4px;
        border-radius: 4px;
        transition: background 0.12s;
    }
    .conv-header__back:hover {
        background: #f0f0f0;
        color: var(--color-text);
    }
    .conv-header__avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--color-orange, #E07A3A);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }
    .conv-header__name {
        font-family: var(--font-heading);
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text);
    }

    /* ── Fil des messages ── */
    .messages-thread {
        flex: 1;
        overflow-y: auto;
        padding: 20px 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
        /* Scroll automatique vers le bas (vers les plus récents) */
        scroll-behavior: smooth;
    }

    /* Bulle de message générique */
    .message-bubble {
        display: flex;
        flex-direction: column;
        max-width: 70%; /* limite la largeur pour les messages longs */
    }

    /* Messages de l'utilisateur courant — alignés à droite */
    .message-bubble--mine {
        align-self: flex-end;
        align-items: flex-end;
    }

    /* Messages de l'autre participant — alignés à gauche */
    .message-bubble--theirs {
        align-self: flex-start;
        align-items: flex-start;
    }

    /* Auteur affiché au-dessus du message (pour les messages reçus) */
    .message-bubble__author {
        font-size: 11px;
        color: var(--color-text-light);
        margin-bottom: 3px;
        font-weight: 600;
    }

    /* Corps du message (texte dans la bulle) */
    .message-bubble__content {
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.5;
        /* Préserve les retours à la ligne (le contenu est du texte brut) */
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* Style bulle envoyée (fond rouge clair) */
    .message-bubble--mine .message-bubble__content {
        background: #fdf0ee; /* rouge très clair, cohérent avec la charte Bazaart */
        color: var(--color-text);
        border-bottom-right-radius: 3px; /* petite "queue" de bulle */
    }

    /* Style bulle reçue (fond gris clair) */
    .message-bubble--theirs .message-bubble__content {
        background: #f0f2f1; /* gris clair neutre */
        color: var(--color-text);
        border-bottom-left-radius: 3px;
    }

    /* Date/heure sous chaque bulle */
    .message-bubble__date {
        font-size: 10px;
        color: var(--color-text-light);
        margin-top: 3px;
    }

    /* ── Zone de saisie ── */
    .message-form {
        border-top: 1px solid var(--color-border);
        padding-top: 16px;
        flex-shrink: 0;
        display: flex;
        gap: 10px;
        align-items: flex-end;
    }
    .message-form__textarea {
        flex: 1;
        padding: 10px 14px;
        border: 1px solid var(--color-border);
        border-radius: 20px; /* arrondi "bulle" pour cohérence visuelle */
        font-size: 14px;
        font-family: inherit;
        color: var(--color-text);
        resize: none;
        min-height: 44px;
        max-height: 120px;
        overflow-y: auto;
        transition: border-color 0.15s;
        background: var(--color-white);
    }
    .message-form__textarea:focus {
        outline: none;
        border-color: var(--color-red, #C8503A);
    }
    .message-form__textarea::placeholder {
        color: var(--color-text-light);
    }
    .message-form__submit {
        padding: 10px 20px;
        background: var(--color-red, #C8503A);
        color: white;
        border: none;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .message-form__submit:hover {
        background: #a84232;
    }

    /* ── Fil vide ── */
    .thread-empty {
        text-align: center;
        padding: 40px 20px;
        color: var(--color-text-light);
        font-size: 14px;
    }

    /* ── Wrapper page ── */
    .conversation-wrapper {
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-card);
        padding: 20px;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 140px);
        max-height: 750px;
    }
</style>
{% endblock %}

{% block content %}

<div class="conversation-wrapper">

    {# ── En-tête : nom de l'interlocuteur + lien retour ──────────────────────── #}
    <div class="conv-header">
        {# Flèche retour vers la liste des conversations #}
        <a href="{{ path('app_messaging_index') }}" class="conv-header__back" title="Retour aux messages">
            ←
        </a>

        {# Avatar de l'interlocuteur #}
        <div class="conv-header__avatar">
            {{ otherUser ? (otherUser.email|split('@')|first|slice(0, 2)|upper) : '?' }}
        </div>

        {# Nom d'usage (partie avant l'@ de l'email) #}
        <div>
            <div class="conv-header__name">
                {% if otherUser %}
                    {{ otherUser.email|split('@')|first }}
                {% else %}
                    Utilisateur inconnu
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Fil des messages ─────────────────────────────────────────────────────── #}
    <div class="messages-thread" id="messages-thread">

        {% if messages is empty %}

            {# Aucun message — invite à envoyer le premier #}
            <div class="thread-empty">
                Aucun message pour l'instant. Soyez le premier à écrire !
            </div>

        {% else %}

            {% for message in messages %}

                {#
                    On détermine si ce message appartient à l'utilisateur courant
                    pour l'aligner à droite (bulle "envoyée") ou à gauche (bulle "reçue").
                    Comparaison par identité d'objet (===) — garanti par Doctrine Unit of Work.
                #}
                {% set isMine = (message.author.id == currentUser.id) %}

                {#
                    L'ancre id="last-message" est placée sur le DERNIER message.
                    La redirection après envoi inclut #last-message pour que le navigateur
                    scrolle automatiquement jusqu'au bas du fil.
                #}
                <div class="message-bubble {{ isMine ? 'message-bubble--mine' : 'message-bubble--theirs' }}"
                     {% if loop.last %}id="last-message"{% endif %}>

                    {# Nom de l'auteur — affiché seulement pour les messages reçus #}
                    {% if not isMine %}
                        <div class="message-bubble__author">
                            {{ message.author.email|split('@')|first }}
                        </div>
                    {% endif %}

                    {# Contenu du message (texte brut, pas de HTML) #}
                    {#
                        nl2br() convertit les retours à la ligne (\n) en <br> HTML.
                        raw est nécessaire car nl2br retourne du HTML.
                        Sécurité : le contenu est en texte brut (pas de HTML injecté par l'utilisateur).
                        Twig échappe automatiquement le texte AVANT que nl2br() l'insère —
                        l'ordre dans le filtre pipeline est :
                        1. escape() (automatique dans Twig) → protège contre XSS
                        2. nl2br() → ajoute <br> sur le texte déjà sécurisé
                        3. raw → dit à Twig "fais confiance au résultat de nl2br"
                        Ce pipeline est sûr car escape() s'exécute toujours en premier.
                    #}
                    <div class="message-bubble__content">
                        {{ message.content|escape|nl2br|raw }}
                    </div>

                    {# Date d'envoi sous chaque bulle #}
                    <div class="message-bubble__date">
                        {{ message.createdAt|date('d/m/Y à H:i') }}
                    </div>

                </div>

            {% endfor %}

        {% endif %}

    </div>

    {# ── Formulaire d'envoi ───────────────────────────────────────────────────── #}
    <form class="message-form"
          method="POST"
          action="{{ path('app_messaging_send', { id: conversation.id }) }}">

        {#
            Token CSRF dynamique : nommé "messaging_send_{conversationId}".
            L'ID de la conversation dans le nom empêche la réutilisation d'un token
            d'une conversation sur une autre (cloisonnement par ressource).
        #}
        <input type="hidden" name="_token" value="{{ csrf_token('messaging_send_' ~ conversation.id) }}">

        {# Zone de saisie du message #}
        <textarea
            name="content"
            class="message-form__textarea"
            placeholder="Écrivez votre message..."
            rows="1"
            maxlength="5000"
            required
            aria-label="Votre message"></textarea>

        {# Bouton d'envoi #}
        <button type="submit" class="message-form__submit">
            Envoyer
        </button>

    </form>

</div>

{#
    Script de scroll automatique vers le bas du fil.
    Après chargement de la page (ou après redirect post-envoi), on scrolle
    jusqu'au dernier message pour que l'utilisateur voie immédiatement
    les messages les plus récents (comportement naturel d'une messagerie).
#}
<script>
document.addEventListener('DOMContentLoaded', function () {
    // Cible soit l'ancre #last-message, soit le bas du fil si pas de messages
    var lastMessage = document.getElementById('last-message');
    var thread = document.getElementById('messages-thread');

    if (lastMessage) {
        // Scroll vers le dernier message avec animation douce
        lastMessage.scrollIntoView({ behavior: 'smooth', block: 'end' });
    } else if (thread) {
        // Fallback : scroll jusqu'en bas du conteneur
        thread.scrollTop = thread.scrollHeight;
    }

    // Auto-resize du textarea : grandit avec le contenu, max-height contrôlé en CSS
    var textarea = document.querySelector('.message-form__textarea');
    if (textarea) {
        textarea.addEventListener('input', function () {
            // Réinitialise la hauteur pour recalculer correctement le scrollHeight
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });
    }
});
</script>

{% endblock %}
