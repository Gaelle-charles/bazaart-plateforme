{% extends 'base_dashboard.html.twig' %}

{#
 # messaging/index.html.twig — Liste des conversations (thème Street)
 #
 # Variables transmises par MessagingController :
 #   - conversations : Conversation[] — toutes les conversations de l'utilisateur
 #   - unreadCounts  : array<int, int> — [conversationId => nombre de non lus]
 #   - currentUser   : App\Entity\User — l'utilisateur connecté
 #
 # Design : thème Street
 #   Bords francs, cartes border 1px --ink, accents lime + orange
 #   Avatars : carrés (Street ≠ cercles du thème Editorial)
 #}

{% block sidebar %}
    {# Sidebar commune à toutes les pages du dashboard artiste — voir _partials/sidebar_artiste.html.twig #}
    {% include '_partials/sidebar_artiste.html.twig' %}
{% endblock %}

{% block title %}Mes messages — BazaArt{% endblock %}
{% block page_title %}Messages{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

/* ================================================================
   MESSAGERIE — Liste des conversations (thème Street)
   Préfixe : .msg- pour éviter toute collision
================================================================ */

/* ── En-tête de la page ─────────────────────────────────────────
   Titre en Archivo Black + bouton "Nouvelle conversation" à droite
----------------------------------------------------------------- */
.msg-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap; /* bascule en colonne sur mobile */
}

.msg-header__title {
    font-family: var(--display); /* Archivo Black */
    font-size: clamp(28px, 4vw, 40px);
    text-transform: uppercase;
    line-height: .9;
    color: var(--ink);
}

.msg-header__sub {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 8px;
}

/* Bouton "Nouvelle conversation +" — style dark (fond --ink) */
.msg-btn-new {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 10px 16px;
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    border: 1px solid var(--ink);
    border-radius: 0; /* Street : bords francs */
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background var(--transition-fast), color var(--transition-fast);
}

.msg-btn-new:hover {
    background: var(--accent);
    color: var(--ink);
    border-color: var(--ink);
}

/* ── Conteneur de la liste ──────────────────────────────────────
   Border 1px --ink (style carte Street), pas de shadow
----------------------------------------------------------------- */
.msg-list {
    border: 1px solid var(--ink);
}

/* ── Item de conversation ───────────────────────────────────────
   Ligne cliquable = toute la largeur est un lien
----------------------------------------------------------------- */
.msg-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--line-soft);
    transition: background var(--transition-fast);
    position: relative;
}

.msg-item:last-child {
    border-bottom: none;
}

.msg-item:hover {
    background: var(--bg-alt);
}

/* Conversation avec messages non lus :
   barre latérale accent-2 (orange) + fond très légèrement teinté */
.msg-item--unread {
    background: var(--bg);
    border-left: 3px solid var(--accent-2);
    padding-left: 15px; /* compense les 3px de la bordure */
}

.msg-item--unread:hover {
    background: var(--bg-alt);
}

/* ── Avatar carré avec initiales ────────────────────────────────
   Street : carré (border-radius: 0), pas de cercle
   Fond accent lime, texte --ink
----------------------------------------------------------------- */
.msg-avatar {
    width: 40px;
    height: 40px;
    background: var(--accent);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--ink);
    border-radius: 0; /* carré strict */
}

/* Avatar de conversation non lue : fond orange */
.msg-item--unread .msg-avatar {
    background: var(--accent-2);
    color: var(--bg);
}

/* ── Contenu textuel de la ligne ────────────────────────────────
   min-width: 0 est nécessaire pour que text-overflow ellipsis
   fonctionne à l'intérieur d'un flex container
----------------------------------------------------------------- */
.msg-body {
    flex: 1;
    min-width: 0;
}

.msg-body__name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 3px;
}

/* Nom en gras si messages non lus */
.msg-item--unread .msg-body__name {
    font-family: var(--display);
    font-size: 13px;
}

.msg-body__preview {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ── Zone droite : date + badge non lus ─────────────────────── */
.msg-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
}

.msg-meta__date {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: .04em;
}

/* Badge "N non lus" — fond orange (accent-2), style chip Street */
.msg-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .04em;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: var(--accent-2);
    color: var(--bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0; /* Street : carré */
}

/* ── État vide ──────────────────────────────────────────────────
   Affiché si conversations est vide
----------------------------------------------------------------- */
.msg-empty {
    border: 1px solid var(--ink);
    padding: 64px 24px;
    text-align: center;
}

.msg-empty__icon {
    font-family: var(--display);
    font-size: 48px;
    line-height: 1;
    color: var(--ink-mute);
    margin-bottom: 16px;
    opacity: .3;
}

.msg-empty__text {
    font-size: 14px;
    color: var(--ink-mute);
    margin-bottom: 24px;
    line-height: 1.5;
}

/* Bouton CTA état vide */
.msg-empty__cta {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 10px 20px;
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    display: inline-block;
    border-radius: 0;
    transition: background var(--transition-fast), color var(--transition-fast);
}

.msg-empty__cta:hover {
    background: var(--accent);
    color: var(--ink);
}

/* ── Responsive mobile ─────────────────────────────────────────
   La liste reste identique sur mobile — elle est déjà en colonne
----------------------------------------------------------------- */
@media (max-width: 768px) {
    .msg-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
}

</style>
{% endblock %}

{% block content %}

{# ── EN-TÊTE ──────────────────────────────────────────────────────────────────
   Titre Archivo Black + bouton "Nouvelle conversation"
#}
<div class="msg-header">
    <div>
        <h2 class="msg-header__title">Messages</h2>
        <p class="msg-header__sub">
            {{ conversations|length }} conversation{{ conversations|length != 1 ? 's' : '' }}
        </p>
    </div>

    {#
        Pour démarrer une nouvelle conversation, l'utilisateur doit d'abord
        trouver un artiste dans l'annuaire.

        La route app_messaging_new/{userId} requiert un paramètre {userId} obligatoire —
        on ne peut pas la générer sans connaître l'interlocuteur cible.
        Appeler path('app_messaging_new') sans paramètre déclencherait une
        MissingMandatoryParametersException au rendu Twig.

        Le parcours correct est donc : Annuaire → profil artiste → "Contacter" → messaging/new/{userId}.
    #}
    <a href="{{ path('app_artist_profile_directory') }}" class="msg-btn-new">
        {# Icône "+" en SVG inline — pas de dépendance externe #}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
            <path d="M12 5v14M5 12h14"/>
        </svg>
        Nouvelle conversation
    </a>
</div>

{# ── LISTE DES CONVERSATIONS ──────────────────────────────────────────────────
   Si vide → état vide avec CTA
   Sinon → liste de lignes cliquables
#}
{% if conversations is empty %}

    {# État vide : invite à démarrer une première conversation #}
    <div class="msg-empty">
        <div class="msg-empty__icon">✉</div>
        <p class="msg-empty__text">
            Vous n'avez pas encore de conversation.<br>
            Démarrez un échange avec un artiste de l'annuaire !
        </p>
        <a href="{{ path('app_artist_profile_directory') }}" class="msg-empty__cta">
            Parcourir l'annuaire →
        </a>
    </div>

{% else %}

    <div class="msg-list" role="list">

        {% for conversation in conversations %}

            {#
                Récupère l'autre participant de la conversation.
                getOtherParticipant() est une méthode de l'entité Conversation
                qui filtre les participants pour retourner celui qui n'est pas currentUser.
            #}
            {% set otherUser = conversation.getOtherParticipant(currentUser) %}

            {#
                Nombre de messages non lus pour cette conversation.
                L'opérateur ?? retourne 0 si la clé n'existe pas dans le tableau
                (null coalescing — plus sûr que conversation.id is defined in unreadCounts).
            #}
            {% set unread = unreadCounts[conversation.id] ?? 0 %}

            {# Lien englobant toute la ligne — accessibilité : title décrit la destination #}
            <a href="{{ path('app_messaging_show', { id: conversation.id }) }}"
               class="msg-item {% if unread > 0 %}msg-item--unread{% endif %}"
               role="listitem"
               title="Conversation avec {{ otherUser ? otherUser.email|split('@')|first : 'utilisateur inconnu' }}">

                {# Avatar carré avec les 2 initiales de l'interlocuteur #}
                <div class="msg-avatar" aria-hidden="true">
                    {#
                        Génère 2 lettres en majuscules depuis l'email de l'interlocuteur.
                        Si otherUser est null (conversation orpheline), on affiche "??"
                    #}
                    {{ otherUser ? (otherUser.email|split('@')|first|slice(0, 2)|upper) : '??' }}
                </div>

                {# Nom et date d'activité de la conversation #}
                <div class="msg-body">
                    <div class="msg-body__name">
                        {{ otherUser ? otherUser.email|split('@')|first : 'Utilisateur inconnu' }}
                    </div>
                    <div class="msg-body__preview">
                        {# Affiche la date d'activité — on n'a pas de lastMessageContent
                           en V1 (pas de dénormalisation). On affiche la date en mono. #}
                        {% if conversation.lastMessageAt %}
                            {{ conversation.lastMessageAt|date('d/m à H:i') }}
                        {% else %}
                            Démarrée le {{ conversation.createdAt|date('d/m/Y') }}
                        {% endif %}
                    </div>
                </div>

                {# Zone droite : date courte + badge non-lus #}
                <div class="msg-meta">
                    <span class="msg-meta__date">
                        {% if conversation.lastMessageAt %}
                            {{ conversation.lastMessageAt|date('d/m') }}
                        {% else %}
                            {{ conversation.createdAt|date('d/m') }}
                        {% endif %}
                    </span>

                    {# Badge orange — affiché uniquement si messages non lus #}
                    {% if unread > 0 %}
                        <span class="msg-badge" aria-label="{{ unread }} message(s) non lu(s)">
                            {{ unread }}
                        </span>
                    {% endif %}
                </div>

            </a>

        {% endfor %}

    </div>

{% endif %}

{% endblock %}
