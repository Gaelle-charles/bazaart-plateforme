{% extends 'base.html.twig' %}

{#
 # base_app.html.twig — Layout des pages connectées
 #
 # Ce template étend base.html.twig qui fournit désormais :
 #   - La nav unifiée (logo + onglets + Connexion/Rejoindre ou avatar)
 #   - Le skip link WCAG
 #   - Le panneau mobile + overlay
 #   - Les scripts JS hamburger + dropdown avatar
 #
 # Ce template ajoute uniquement :
 #   - La topbar secondaire (titre de la page courante, sticky sous la nav)
 #   - Le conteneur principal .app-main > .app-content
 #   - Les messages flash (succès, erreur, info)
 #
 # UTILISATION :
 #   {% extends 'base_app.html.twig' %}
 #   {% block page_title %}Mon titre{% endblock %}
 #   {% block content %}...{% endblock %}
 #}

{% block stylesheets %}
    {{- parent() -}}
    {#
        Preload des polices Street utilisées dans l'app connectée.
        Archivo Black = --display (titres), Space Grotesk = --body (corps).
        Ces polices sont aussi utilisées dans la nav (déjà chargée via base.html.twig),
        mais le preload ici accélère leur rendu pour les éléments en dessous de la nav.
    #}
    <link rel="preload" href="{{ asset('fonts/archivo-black-400.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ asset('fonts/space-grotesk-400.woff2') }}" as="font" type="font/woff2" crossorigin>

    <style>
    /*
     * Surcharge du body pour le thème Street (pages connectées).
     * base.html.twig définit body { background: var(--color-bg) } (tokens V1).
     * On force ici les tokens V2 : --bg, --ink, --body — cohérence avec la nav.
     */
    body {
        background: var(--bg, #F2EFE6);
        color: var(--ink, #0D0D0D);
        font-family: var(--body, 'Space Grotesk', sans-serif);
    }

    /*
     * ── TOPBAR SECONDAIRE ──────────────────────────────────────────────
     * Barre affichant le titre de la page courante.
     * Sticky sous la nav principale (top: 64px = hauteur de .nav).
     * Séparée du contenu par une bordure bas 1px --ink (style Street).
     */
    .topbar {
        height: 56px;
        background: var(--bg, #F2EFE6);
        border-bottom: 1px solid var(--ink, #0D0D0D);
        display: flex;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 64px;   /* hauteur exacte de .nav */
        z-index: 50; /* sous la nav (z-index: 100) mais au-dessus du contenu */
    }

    /* Titre — Archivo Black, taille modeste (titre de section, pas de H1 géant) */
    .topbar__title {
        font-family: var(--display, 'Archivo Black', sans-serif);
        font-size: 16px;
        font-weight: 400;
        color: var(--ink, #0D0D0D);
        letter-spacing: -.01em;
    }

    /*
     * ── ZONE PRINCIPALE ───────────────────────────────────────────────
     * .app-main : prend au minimum toute la hauteur restante sous la nav.
     * .app-content : wrapper centré (max 1440px), paddings confortables.
     */
    .app-main {
        min-height: calc(100vh - 64px); /* 64px = hauteur de .nav */
    }

    .app-content {
        max-width: 1440px;
        margin: 0 auto;
        padding: 28px 32px;
    }

    /* ── Responsive ── */
    @media (max-width: 767px) {
        .topbar  { padding: 0 16px; }
        .app-content { padding: 16px; }
    }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {#
        Scripts spécifiques aux pages connectées.
        {{ parent() }} injecte en premier les scripts de base.html.twig
        (hamburger + dropdown avatar). On ajoute ici les scripts app.
    #}
    <script>
    /* ── Polling badge notifications non lues ─────────────────────────────────
     * Interroge /api/notifications/unread-count toutes les 60 secondes.
     * Met à jour le badge #notif-count si la route et les éléments existent.
     * BACK: décommenter quand la route app_api_notification_unread_count
     *       et l'élément #notif-link seront présents dans la nav.
     * Pour l'instant : no-op silencieux.
     */
    (function () {
        'use strict';
        var link  = document.getElementById('notif-link');
        var badge = document.getElementById('notif-count');
        if (!link || !badge) return;
        var url = link.getAttribute('data-api');
        if (!url) return;
        function update(n) {
            if (n > 0) { badge.textContent = n > 99 ? '99+' : n; badge.style.display = 'flex'; }
            else        { badge.style.display = 'none'; }
        }
        function poll() {
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (d) { if (d && typeof d.count === 'number') update(d.count); })
                .catch(function () {}); /* erreur réseau → silencieux */
        }
        poll();
        setInterval(poll, 60000);
    }());
    </script>
{% endblock %}

{% block body %}

{# ── TOPBAR SECONDAIRE — titre de la page ──────────────────────────────── #}
{#
    {% block page_title %} est rempli par les pages enfants.
    Exemple : {% block page_title %}Ressourcerie{% endblock %}
    Si le bloc est vide, la topbar affiche une barre vide (invisible).
#}
<div class="topbar">
    <h1 class="topbar__title">{% block page_title %}{% endblock %}</h1>
</div>

{# ── CONTENU PRINCIPAL ──────────────────────────────────────────────────── #}
<main class="app-main" id="main-content">
    <div class="app-content">

        {# ── Messages flash ── #}
        {#
            Symfony stocke les messages flash en session.
            On les affiche ici, au-dessus du contenu de la page.
            Trois niveaux : success (vert), error (rouge), info (bleu).
        #}
        {% for message in app.flashes('success') %}
            <div class="flash flash--success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash--error">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="flash flash--info">{{ message }}</div>
        {% endfor %}

        {# Contenu de la page — rempli par les templates enfants #}
        {% block content %}{% endblock %}

    </div>
</main>

{% endblock %}
