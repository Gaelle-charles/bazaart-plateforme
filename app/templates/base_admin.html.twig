{% extends 'base.html.twig' %}

{#
 # base_admin.html.twig — Layout réservé aux pages d'administration
 #
 # Différent de base_app.html.twig (dashboard utilisateur) :
 # - Sidebar sombre (ardoise) avec navigation admin uniquement
 # - Badge ADMIN visible
 # - Pas de navigation utilisateur (profil, communauté, etc.)
 #
 # UTILISATION :
 # {% extends 'base_admin.html.twig' %}
 # {% block page_title %}Ma page admin{% endblock %}
 # {% block content %}...{% endblock %}
 #}

{#
    L'admin utilise sa propre sidebar de navigation (ardoise foncé).
    La nav Street globale n'est pas pertinente ici → bloc vidé.
#}
{% block navbar %}{% endblock %}

{% block stylesheets %}
<style>

{# ==========================================================================
   CSS du layout admin — thème Street V3
   Préfixe .sd-* pour le sidebar (partagé avec base_dashboard.html.twig),
   classes .app-layout / .app-main / .topbar / .app-content pour la structure admin.

   TOKENS DESIGN (design-tokens.css) :
     --bg (#F2EFE6)    --bg-alt (#EAE6D9)
     --ink (#0D0D0D)   --ink-mute (#5b584f)
     --accent (#C6F24E) — vert acide
     --accent-2 (#FF6B2C) — orange
     --line-soft : rgba(13,13,13,.14)
     --display (Archivo Black)  --body (Space Grotesk)  --mono (JetBrains Mono)
     --transition-fast (.12s ease)

   DESIGN STREET :
     border-radius: 0 PARTOUT — aucun arrondi nulle part
     Bordures 1px solid --ink
     Pas d'emojis dans le HTML rendu
   ========================================================================== #}

/* ── Layout principal : sidebar fixe + zone principale ─────────────────────
 * Même structure que base_dashboard.html.twig.
 * .sd-side est positionné en fixed (220px de large).
 * .app-main compense avec margin-left: 220px.
 */
.app-layout {
    display: flex;
    min-height: 100vh;
    background: var(--bg);
}

/* ══ SIDEBAR — classes .sd-* (identiques à base_dashboard.html.twig) ════════
 *
 * Le CSS du sidebar est copié ici car base_admin.html.twig n'étend pas
 * base_dashboard.html.twig (ils ont des structures différentes).
 * Si une refactorisation est faite, centraliser dans un fichier CSS externe.
 */

/* Sidebar fixe fond ink (#0D0D0D) */
.sd-side {
    width: 220px;
    min-height: 100vh;
    background: var(--ink);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 200;
    overflow-y: auto;
    overflow-x: hidden;
    transition: transform var(--transition-fast);
}

/* Logo + wordmark */
.sd-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid rgba(242,239,230,.1);
    flex-shrink: 0;
}

.sd-wordmark {
    font-family: var(--display);
    font-size: 17px;
    color: var(--accent);
    letter-spacing: -.01em;
    text-transform: uppercase;
}

/* Lien du logo — supprime la décoration de lien native */
.sd-wordmark-link {
    text-decoration: none;
    display: block;
}
.sd-wordmark-link:hover .sd-wordmark {
    opacity: .8;
}

/* Pill de rôle — 3 variantes : artiste (par défaut), structure (orange), admin (sable) */
.sd-role-pill {
    font-family: var(--mono);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 3px 6px;
    background: var(--accent);
    color: var(--ink);
    border: 1px solid var(--accent);
    white-space: nowrap;
}

.sd-role-pill--admin {
    background: var(--bg);
    color: var(--ink);
    border-color: var(--bg);
}

/* Labels de section nav */
.sd-section {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(242,239,230,.35);
    padding: 16px 20px 5px;
    flex-shrink: 0;
}

.sd-nav {
    display: flex;
    flex-direction: column;
}

/* Liens de navigation */
.sd-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 20px;
    font: 500 13px/1.3 var(--body);
    color: rgba(242,239,230,.65);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    border-left: 2px solid transparent;
    position: relative;
}

.sd-link:hover {
    background: rgba(242,239,230,.05);
    color: var(--bg);
    border-left-color: rgba(198,242,78,.5);
}

.sd-link--active {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: rgba(198,242,78,.07);
}

.sd-link--active:hover {
    background: rgba(198,242,78,.10);
}

/* Icônes SVG inline */
.sd-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
}

/* Badges numériques */
.sd-badge {
    margin-left: auto;
    font: 700 9px/1 var(--mono);
    letter-spacing: .04em;
    padding: 2px 6px;
    background: rgba(242,239,230,.12);
    color: rgba(242,239,230,.8);
    border: 1px solid rgba(242,239,230,.15);
    white-space: nowrap;
}

.sd-badge--warn {
    background: var(--accent-2);
    color: var(--ink);
    border-color: var(--accent-2);
}

/* Utilisateur en bas du sidebar */
.sd-user {
    margin-top: auto;
    padding: 14px 16px;
    border-top: 1px solid rgba(242,239,230,.08);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
}

.sd-avatar {
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font: 700 11px var(--mono);
    letter-spacing: .04em;
    border: 1px solid rgba(198,242,78,.5);
    flex-shrink: 0;
}

.sd-user__name {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--bg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.sd-user__role {
    display: block;
    font: 600 9px var(--mono);
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(242,239,230,.4);
    margin-top: 1px;
}

.sd-logout {
    margin-left: auto;
    display: flex;
    align-items: center;
    color: rgba(242,239,230,.35);
    text-decoration: none;
    transition: color var(--transition-fast);
    flex-shrink: 0;
}

.sd-logout:hover { color: var(--accent-2); }

/* ══ Zone principale admin ═══════════════════════════════════════════════════
 * Mêmes règles que base_dashboard mais avec les classes historiques .app-main
 * pour ne pas casser les templates enfants admin existants.
 */
.app-main {
    margin-left: 220px; /* offset = largeur sidebar */
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: var(--bg);
}

/* Topbar admin — identique à .sd-topbar pour cohérence visuelle */
.topbar {
    height: 56px;
    background: var(--bg);
    border-bottom: 1px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    position: sticky;
    top: 0;
    z-index: 50;
    flex-shrink: 0;
}

/* Titre de la page courante */
.topbar__title {
    font-family: var(--display);
    font-size: 16px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -.01em;
}

/* Lien discret dans la topbar (ex : "Voir la vitrine") */
.topbar__link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    text-decoration: none;
    letter-spacing: .04em;
    transition: color var(--transition-fast);
}

.topbar__link:hover { color: var(--ink); }

/* Zone de contenu */
.app-content {
    padding: 28px;
    flex: 1;
}

/* Flash messages — Street (bordure ink, aucun arrondi) */
.flash {
    padding: 12px 16px;
    border: 1px solid var(--ink);
    margin-bottom: 16px;
    font-size: 13px;
    font-weight: 500;
}

.flash--success { background: #d4edda; color: #155724; }
.flash--error   { background: #f8d7da; color: #721c24; }
.flash--info    { background: #d1ecf1; color: #0c5460; }

/* ── Responsive admin (< 900px) ─────────────────────────────────────────── */
@media (max-width: 900px) {
    .app-main  { margin-left: 0; }
    .sd-side   { transform: translateX(-100%); }
}

</style>
{% endblock %}

{% block body %}
<div class="app-layout">

    {# ── SIDEBAR ADMIN — thème Street V3 ──────────────────────────────────── #}
    {#
        Sidebar refontée avec les classes .sd-* (identiques aux dashboards artiste/structure).
        Les anciens styles --admin-* ont été supprimés.

        Routes vérifiées dans src/Controller/AdminController.php :
          app_admin_dashboard           → AdminController#dashboard
          app_admin_resources_pending   → AdminController#resourcesPending
          app_admin_users               → AdminController#users
          app_admin_structures_pending  → AdminController#structuresPending
          app_admin_resources_all       → AdminController#resourcesAll (sans param de route)
          app_admin_scraped_opportunities → AdminController#scrapedOpportunities
          app_article_index             → ArticleController#index
          app_home                      → HomeController#index
          app_dashboard                 → DashboardController#index
          app_logout                    → AuthController#logout

        CORRECTION par rapport à l'ancienne sidebar :
          L'ancien lien Opportunités utilisait path('app_admin_resources_all', {status: 'published'}).
          Mais "status" n'est PAS un paramètre de route — c'est un query param (?status=published).
          path() avec un paramètre non déclaré dans la route génère une erreur Symfony.
          → Corrigé : path('app_admin_resources_all') sans paramètre.
    #}
    <aside class="sd-side" aria-label="Navigation admin">

        {# ── Logo + badge ADMIN ── #}
        <div class="sd-logo">
            {#
                Même comportement que les dashboards artiste et structure :
                le logo renvoie vers l'accueil public.
                Utile pour l'admin qui navigue entre l'espace admin et le site public.
            #}
            <a href="{{ path('app_home') }}" class="sd-wordmark-link" title="Retour à l'accueil" aria-label="BazaArt — accueil">
                <span class="sd-wordmark">BazaArt</span>
            </a>
            {#
                Pill "ADMIN" — variante sable (.sd-role-pill--admin).
                Fond --bg (sable) sur fond --ink (noir) pour se distinguer des
                variantes artiste (lime) et structure (orange).
            #}
            <span class="sd-role-pill sd-role-pill--admin">Admin</span>
        </div>

        {# ── Section : Pilotage ── #}
        <div class="sd-section">Pilotage</div>
        <nav class="sd-nav" aria-label="Pilotage">

            {# Cockpit — vue d'ensemble admin #}
            <a href="{{ path('app_admin_dashboard') }}"
               class="sd-link {{ app.request.attributes.get('_route') == 'app_admin_dashboard' ? 'sd-link--active' : '' }}">
                {# Icône 4 rectangles (grille de bord) #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3"  y="3"  width="7" height="9"/>
                    <rect x="14" y="3"  width="7" height="5"/>
                    <rect x="14" y="12" width="7" height="9"/>
                    <rect x="3"  y="16" width="7" height="5"/>
                </svg>
                Cockpit
            </a>

            {# Validation des ressources en attente #}
            <a href="{{ path('app_admin_resources_pending') }}"
               class="sd-link {{ app.request.attributes.get('_route') == 'app_admin_resources_pending' ? 'sd-link--active' : '' }}">
                {# Icône coche / validation #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="m5 12 5 5L20 7"/>
                </svg>
                Validation
                {#
                    TODO V2 : ajouter un badge avec le comptage des ressources en attente.
                    Nécessite une variable globale Twig (TwigExtension ou GlobalVariable).
                    Ex : <span class="sd-badge sd-badge--warn">{{ pending_count }}</span>
                #}
            </a>

            {# Gestion des utilisateurs #}
            <a href="{{ path('app_admin_users') }}"
               class="sd-link {{ app.request.attributes.get('_route') == 'app_admin_users' ? 'sd-link--active' : '' }}">
                {# Icône groupe de personnes #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Utilisateurs
            </a>

            {#
                Structures partenaires — validation des demandes.
                Actif pour toutes les routes "app_admin_structure*"
                (structures_pending, structure_activate, structure_reject).
            #}
            <a href="{{ path('app_admin_structures_pending') }}"
               class="sd-link {{ app.request.attributes.get('_route') starts with 'app_admin_structure' ? 'sd-link--active' : '' }}">
                {# Icône colonnes / bâtiment institution #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <polyline points="1.5,4.5 14.5,4.5"/>
                    <polyline points="1.5,13.5 14.5,13.5"/>
                    <line x1="4"  y1="4.5" x2="4"  y2="13.5"/>
                    <line x1="8"  y1="4.5" x2="8"  y2="13.5"/>
                    <line x1="12" y1="4.5" x2="12" y2="13.5"/>
                </svg>
                Structures
            </a>

            {#
                Toutes les opportunités (ressources, tous statuts).
                Note : "status" est un query param, PAS un param de route.
                path('app_admin_resources_all') sans paramètre est correct.
                Pour filtrer, ajouter ?status=published dans l'URL directement.
            #}
            <a href="{{ path('app_admin_resources_all') }}"
               class="sd-link {{ app.request.attributes.get('_route') == 'app_admin_resources_all' ? 'sd-link--active' : '' }}">
                {# Icône globe #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/>
                </svg>
                Opportunités
            </a>

        </nav>

        {# ── Section : Contenu ── #}
        <div class="sd-section">Contenu</div>
        <nav class="sd-nav" aria-label="Contenu">

            {#
                Articles & Blog — actif pour toutes les routes "app_article_*".
                Lien vers la liste admin des articles (même route que la liste publique
                — les actions de création/édition sont disponibles pour les admins).
            #}
            <a href="{{ path('app_article_index') }}"
               class="sd-link {{ app.request.attributes.get('_route') starts with 'app_article_' ? 'sd-link--active' : '' }}">
                {# Icône livre ouvert #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 4h7a3 3 0 0 1 3 3v13a3 3 0 0 0-3-3H4z"/>
                    <path d="M20 4h-7a3 3 0 0 0-3 3v13a3 3 0 0 1 3-3h7z"/>
                </svg>
                Articles
            </a>

            {#
                Formations — module Formation V1.
                Actif pour toutes les routes "app_admin_course_*".
            #}
            <a href="{{ path('app_admin_course_index') }}"
               class="sd-link {{ app.request.attributes.get('_route') starts with 'app_admin_course' ? 'sd-link--active' : '' }}">
                {# Icône mortier (enseignement) #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
                Formations
            </a>

            {#
                Lives planifiés — module Communauté V1.
                Actif pour toutes les routes "app_admin_live_*".
                Seuls les admins créent et gèrent les lives en V1.
            #}
            <a href="{{ path('app_admin_live_index') }}"
               class="sd-link {{ app.request.attributes.get('_route') starts with 'app_admin_live' ? 'sd-link--active' : '' }}">
                {# Icône signal / ondes radio — évoque un live / streaming #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="2"/>
                    <path d="M8.93 6.93a5 5 0 0 0 0 10.14"/>
                    <path d="M15.07 6.93a5 5 0 0 1 0 10.14"/>
                    <path d="M5.1 3.1A11 11 0 0 0 5.1 20.9"/>
                    <path d="M18.9 3.1A11 11 0 0 1 18.9 20.9"/>
                </svg>
                Lives
            </a>

            {# Opportunités scrapées depuis Google Sheets #}
            <a href="{{ path('app_admin_scraped_opportunities') }}"
               class="sd-link {{ app.request.attributes.get('_route') == 'app_admin_scraped_opportunities' ? 'sd-link--active' : '' }}">
                {# Icône loupe (scraping / recherche) #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="11" cy="11" r="7"/>
                    <path d="m20 20-3.5-3.5"/>
                </svg>
                Scraping Sheets
            </a>

        </nav>

        {# ── Section : Liens rapides ── #}
        <div class="sd-section">Liens</div>
        <nav class="sd-nav" aria-label="Liens rapides">

            {# Voir la vitrine publique (ouvre dans un nouvel onglet) #}
            <a href="{{ path('app_home') }}" target="_blank" rel="noopener" class="sd-link">
                {# Icône lien externe #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Vitrine publique
            </a>

            {# Retour vers le dashboard utilisateur standard #}
            <a href="{{ path('app_dashboard') }}" class="sd-link">
                {# Icône maison #}
                <svg class="sd-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 11 12 4l9 7v9h-6v-6h-6v6H3z"/>
                </svg>
                App utilisateur
            </a>

        </nav>

        {# ── Utilisateur en bas ── #}
        <div class="sd-user">
            {% if app.user %}
                {#
                    Initiales : 2 premiers caractères de la partie locale de l'email.
                    |e pour protection XSS.
                    Avatar orange (--accent-2) pour distinguer l'admin des artistes (vert).
                #}
                {% set adminInitials = app.user.email|split('@')|first|slice(0,2)|upper %}
                <div class="sd-avatar"
                     style="background: var(--accent-2); border-color: var(--accent-2);"
                     aria-hidden="true">
                    {{ adminInitials|e }}
                </div>
                <div style="min-width: 0; flex: 1; overflow: hidden;">
                    <span class="sd-user__name">{{ app.user.email|split('@')|first|e }}</span>
                    <span class="sd-user__role">Administrateur</span>
                </div>
                {# Icône porte de sortie — déconnexion #}
                <a href="{{ path('app_logout') }}" class="sd-logout" title="Se déconnecter">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </a>
            {% endif %}
        </div>

    </aside>

    {# ── ZONE PRINCIPALE ───────────────────────────────────────────────────── #}
    <div class="app-main">

        {# Topbar #}
        <div class="topbar">
            <h1 class="topbar__title">{% block page_title %}{% endblock %}</h1>
            <a href="{{ path('app_home') }}" class="topbar__link" target="_blank">
                ↗ Voir la vitrine
            </a>
        </div>

        {# Contenu #}
        <div class="app-content">

            {% for message in app.flashes('success') %}
                <div class="flash flash--success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash flash--error">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('info') %}
                <div class="flash flash--info">{{ message }}</div>
            {% endfor %}

            {% block content %}{% endblock %}

        </div>
    </div>

</div>
{% endblock %}
