<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BazaArt{% endblock %}</title>

    {# ── Polices self-hostées — thème Editorial Cream (vitrine publique) ───── #}
    {#
        POURQUOI rel="preload" ?
        Le preload dit au navigateur : "charge ce fichier en priorité haute,
        même avant d'avoir analysé le CSS". Sans preload, la police n'est
        demandée qu'une fois que le CSS est parsé et la règle @font-face
        atteinte — ce qui peut causer un Flash Of Invisible Text (FOIT)
        ou Flash Of Unstyled Text (FOUT) perceptible.

        On ne preload QUE les polices "above the fold" critiques :
        - Fraunces 700 → titres hero et sections
        - DM Sans 400  → corps de texte principal

        Les graisses secondaires (300, 500, etc.) se chargent en fond.

        crossorigin : OBLIGATOIRE même pour les polices en self-hosting.
        Le navigateur charge les polices via une requête CORS anonyme
        (fetch mode) — sans cet attribut, le preload est ignoré.

        POLICES ANCIENNEMENT CHARGÉES VIA GOOGLE FONTS :
        Playfair Display et Inter ont été remplacées par Fraunces et DM Sans
        (thème Editorial Cream) ainsi que Archivo Black et Space Grotesk
        (thème Street). Ces nouvelles polices sont auto-hébergées pour
        conformité RGPD — aucune requête externe à Google.
    #}
    <link rel="preload" href="{{ asset('fonts/fraunces-700.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ asset('fonts/dm-sans-400.woff2') }}" as="font" type="font/woff2" crossorigin>

    {# ── Design tokens V2 ──────────────────────────────────────────────────── #}
    {# Ce fichier doit être chargé EN PREMIER : il déclare toutes les          #}
    {# custom properties CSS (--color-*, --font-*, etc.) utilisées partout.    #}
    {# Ne jamais écrire de valeurs CSS "en dur" dans les templates Twig :      #}
    {# utiliser toujours var(--nom-du-token) à la place.                       #}
    <link rel="stylesheet" href="{{ asset('css/design-tokens.css') }}">

    {# ── Polices self-hostées (@font-face declarations) ───────────────────── #}
    {# Chargé APRÈS design-tokens.css car les tokens de typographie (--display, #}
    {# --body, --mono, --serif) référencent les noms de famille déclarés ici.   #}
    <link rel="stylesheet" href="{{ asset('css/fonts.css') }}">

    <style>
        /* ══════════════════════════════════════════════════════════════════
         * DESIGN SYSTEM — Variables CSS (tokens du design Figma)
         * Ces variables centralisent toutes les couleurs et espacements.
         * Pour modifier une couleur, tu changes juste la variable ici !
         * ══════════════════════════════════════════════════════════════════ */
        :root {
            /* Couleurs principales */
            --color-green:       #1c3a2f;   /* vert forêt — sidebar, titres */
            --color-green-dark:  #2d4c40;   /* vert légèrement plus clair — séparateurs sidebar */
            --color-green-mid:   #718f84;   /* vert muted — textes secondaires sidebar */
            --color-green-light: #d4e6dc;   /* vert très clair — badges résidence */
            --color-red:         #c8503a;   /* terracotta — CTA, badges, accents */
            --color-red-light:   #fef0ec;   /* rouge très pâle — fond badges */
            --color-orange:      #e8a87c;   /* orange doux — avatars */
            --color-orange-light:#fef5ef;   /* orange très pâle — badge appel à projets */

            /* Couleurs neutres */
            --color-bg:          #f7f4ef;   /* beige chaud — fond global */
            --color-white:       #ffffff;
            --color-border:      #e2ddd6;   /* beige gris — bordures, séparateurs */
            --color-input-bg:    #faf9f7;   /* blanc cassé — fond des champs */
            --color-text:        #1a1a1a;   /* presque noir — texte principal */
            --color-text-muted:  #6b6860;   /* gris chaud — texte secondaire */
            --color-text-light:  #a9a6a0;   /* gris clair — texte placeholder/caption */
            --color-text-green:  #718f84;   /* vert doux — texte footer */
            --color-yellow:      #f0c040;   /* jaune ambre — liens admin sidebar */

            /*
             * Typographie — alignée sur le design system V2
             *
             * Ces tokens "compat" --font-heading / --font-body sont conservés
             * pour ne pas casser les templates existants qui les utilisent.
             * Ils sont mappés sur les nouvelles polices du design system V2 :
             *   - Thème Street (app) : titres = Archivo Black, corps = Space Grotesk
             *   - Thème Editorial (vitrine) : titres = Fraunces, corps = DM Sans
             *
             * À terme, migrer les usages de --font-heading → var(--display)
             * et --font-body → var(--body) pour utiliser directement les tokens V2.
             *
             * POLICES SUPPRIMÉES : Playfair Display, Inter (ancienne identité V1)
             * → elles n'étaient pas dans le design system V2 extrait du prototype.
             */
            --font-heading: 'Archivo Black', Impact, sans-serif; /* thème Street — titres display */
            --font-body:    'Space Grotesk', system-ui, sans-serif; /* thème Street — corps de texte */

            /*
             * OMBRES — alignées sur design-tokens.css
             *
             * Thème Street (app) : pas d'ombre douce, les bordures 1px font
             * le travail visuel (voir --card-border dans design-tokens.css).
             * → var(--shadow-card) = none dans le thème Street.
             *
             * Thème Editorial (vitrine) : var(--shadow-card) est surchargé
             * dans [data-theme="editorial"] avec une ombre douce réaliste.
             * Ce bloc hérite donc automatiquement la bonne valeur selon le thème.
             *
             * ANCIENNE VALEUR SUPPRIMÉE : "0 2px 16px rgba(0,0,0,0.06)"
             * Cette valeur surchargée ici entrait en collision avec les tokens V2
             * et ignorait le système de thème. Elle est désormais gérée par
             * design-tokens.css uniquement.
             */
            /* --shadow-card est défini dans design-tokens.css (valeur : none pour le thème Street). */
            /* On ne le redéfinit pas ici pour éviter la référence circulaire var(--x, var(--x)). */

            /*
             * BORDER-RADIUS — alignés sur design-tokens.css
             *
             * Thème Street : design très carré, --radius-sm = 2px maximum.
             * ANCIENNE VALEUR SUPPRIMÉE pour --radius-sm : 6px
             * → 6px entrait en collision avec les 2px des tokens V2 Street.
             * Le thème Editorial redéfinit ses propres rayons (8px, 14px, etc.)
             * dans [data-theme="editorial"] dans design-tokens.css.
             */
            --radius-sm:  2px;   /* Street : petits éléments, bords presque francs */
            --radius-md:  12px;  /* utilisé dans le layout vitrine / cartes */
            --radius-lg:  16px;  /* grandes cartes */
            --radius-full: 999px; /* éléments pilule (badges, avatars) */
        }

        /* ══════════════════════════════════════════════════════════════════
         * RESET & BASE
         * ══════════════════════════════════════════════════════════════════ */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-body);
            background: var(--color-bg);
            color: var(--color-text);
            min-height: 100vh;
            font-size: 14px;
            line-height: 1.5;
        }

        /* ══════════════════════════════════════════════════════════════════
         * COMPOSANTS RÉUTILISABLES
         * ══════════════════════════════════════════════════════════════════ */

        /* ── Boutons ── */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 20px;
            height: 40px;
            border-radius: var(--radius-sm);
            font-family: var(--font-body);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            border: none;
            transition: opacity 0.15s;
        }
        .btn:hover { opacity: 0.88; }

        /* Bouton principal — terracotta */
        .btn-primary {
            background: var(--color-red);
            color: var(--color-white);
        }

        /* Bouton outline — contour noir */
        .btn-outline {
            background: var(--color-white);
            color: var(--color-text);
            border: 1.5px solid var(--color-text);
        }

        /* Bouton pleine largeur */
        .btn-full { width: 100%; }

        /* ── Carte ── */
        .card {
            background: var(--color-white);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-card);
        }

        /* ── Champs de formulaire ── */
        .form-label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--color-text-light);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .form-input {
            width: 100%;
            height: 40px;
            padding: 0 12px;
            background: var(--color-input-bg);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-sm);
            font-family: var(--font-body);
            font-size: 13px;
            color: var(--color-text);
            outline: none;
            transition: border-color 0.15s;
        }
        .form-input:focus {
            border-color: var(--color-green);
        }
        .form-input::placeholder {
            color: var(--color-text-light);
        }

        .form-group { margin-bottom: 18px; }

        /* ── Badge ── */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0 10px;
            height: 22px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: 600;
        }
        .badge-red   { background: var(--color-red-light);   color: var(--color-red); }
        .badge-green { background: var(--color-green-light); color: var(--color-green); }
        .badge-orange{ background: var(--color-orange-light);color: var(--color-orange); }

        /* ── Messages flash ── */
        .flash {
            padding: 10px 16px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            margin-bottom: 12px;
        }
        .flash--success {
            background: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }
        .flash--error {
            background: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }
        /*
         * Flash info — messages neutres / informatifs.
         * Pas de token bleu dans le design system V2 actuel,
         * on utilise donc des valeurs CSS directes inspirées du
         * registre sémantique "info" (bleu neutre WCAG AA).
         * Si un token --info-bg est créé dans design-tokens.css,
         * remplacer ces valeurs par var(--info-bg), etc.
         */
        .flash--info {
            background: #dbeafe;
            border: 1px solid #93c5fd;
            color: #1e40af;
        }

        /* ── Séparateur avec texte ── */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--color-text-light);
            font-size: 12px;
        }
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--color-border);
        }

        /* ══════════════════════════════════════════════════════════════════
         * NAV STREET — commune à TOUTES les pages (vitrine + app connectée)
         *
         * CSS copié verbatim depuis le prototype Street :
         * app/public/uploads/maquette-vitrine/Bazaart-template/
         *                                     Bazaart Prototype (Street).html
         *
         * Classes identiques au prototype : .nav .nav-inner .nav-logo
         * .nav-tabs .nav-tab .nav-side
         *
         * Cette nav est rendue AVANT le bloc «body» dans le <body>,
         * donc toutes les pages qui étendent base.html.twig en héritent
         * automatiquement — sans rien à écrire dans leurs templates.
         *
         * Tokens utilisés (définis dans design-tokens.css) :
         *   --bg        : #F2EFE6  (fond sable — corps de la nav)
         *   --ink       : #0D0D0D  (quasi-noir — logo, texte, bordures)
         *   --accent    : #C6F24E  (vert lime — bouton Rejoindre, onglet actif)
         *   --line      : rgba(13,13,13,.18)  (bordure standard)
         *   --line-soft : rgba(13,13,13,.10)  (bordure douce)
         *   --bg-alt    : #E8E5DC             (fond hover onglet)
         *   --body      : 'Space Grotesk'     (police corps)
         *   --display   : 'Archivo Black'     (police titres)
         *   --mono      : 'JetBrains Mono'    (police monospace)
         *   --accent-2  : #FF6B2C             (orange — déconnexion)
         * ══════════════════════════════════════════════════════════════════ */

        /* Barre de nav : sticky en haut, fond sable, bordure bas */
        .nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--bg, #F2EFE6);
            border-bottom: 1px solid var(--line, rgba(13,13,13,.18));
        }

        /* Conteneur interne : flex, max 1440px, hauteur 64px */
        .nav-inner {
            display: flex;
            align-items: stretch;
            max-width: 1440px;
            margin: 0 auto;
            height: 64px;
        }

        /* Bloc logo — fond NOIR (--ink), texte vert lime (--accent).
           Séparé des onglets par une bordure droite — signature du prototype. */
        .nav-logo {
            display: flex;
            align-items: center;
            padding: 0 20px;
            border-right: 1px solid var(--line, rgba(13,13,13,.18));
            background: var(--ink, #0D0D0D);
            color: var(--accent, #C6F24E);
            font-family: var(--display, 'Archivo Black', sans-serif);
            font-size: 22px;
            letter-spacing: -.01em;
            text-transform: uppercase;
            flex-shrink: 0;
            text-decoration: none;
        }
        .nav-logo img { height: 20px; width: auto; display: block; }

        /* Zone des onglets : flex, prend tout l'espace disponible */
        .nav-tabs {
            display: flex;
            align-items: stretch;
            flex: 1;
            min-width: 0;
            overflow: hidden;
        }

        /* Onglet individuel — uppercase, bordure droite fine */
        .nav-tab {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0 16px;
            border: 0;
            background: transparent;
            cursor: pointer;
            border-right: 1px solid var(--line-soft, rgba(13,13,13,.10));
            font: 600 12.5px/1 var(--body, 'Space Grotesk', sans-serif);
            letter-spacing: .02em;
            color: var(--ink, #0D0D0D);
            text-transform: uppercase;
            transition: background .12s;
            white-space: nowrap;
            flex-shrink: 0;
            text-decoration: none;
        }
        .nav-tab:hover { background: var(--bg-alt, #E8E5DC); }

        /* Onglet actif : inversion (fond noir, texte lime) */
        .nav-tab[data-active="true"] {
            background: var(--ink, #0D0D0D);
            color: var(--accent, #C6F24E);
        }

        /* Point vert visible uniquement sur l'onglet actif */
        .nav-tab .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent, #C6F24E);
            display: none;
        }
        .nav-tab[data-active="true"] .dot { display: block; }

        /* Zone droite : Connexion + Rejoindre (ou avatar si connecté) */
        .nav-side {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 14px;
            border-left: 1px solid var(--line, rgba(13,13,13,.18));
        }

        /* ── Boutons Connexion / Rejoindre ── */
        .nav-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 14px;
            font: 700 12px/1 var(--body, 'Space Grotesk', sans-serif);
            letter-spacing: .05em;
            text-transform: uppercase;
            text-decoration: none;
            border: 1px solid var(--ink, #0D0D0D);
            cursor: pointer;
            white-space: nowrap;
            transition: background .12s, color .12s;
        }

        /* "Connexion" — contour transparent, texte noir */
        .nav-btn--ghost {
            background: transparent;
            color: var(--ink, #0D0D0D);
        }
        .nav-btn--ghost:hover { background: var(--bg-alt, #E8E5DC); }

        /* "Rejoindre" — fond lime, texte noir */
        .nav-btn--lime {
            background: var(--accent, #C6F24E);
            color: var(--ink, #0D0D0D);
            border-color: var(--accent, #C6F24E);
        }
        .nav-btn--lime:hover {
            background: var(--ink, #0D0D0D);
            color: var(--accent, #C6F24E);
            border-color: var(--ink, #0D0D0D);
        }

        /* ── Avatar utilisateur (carré — règle Street) ── */
        .nav-avatar {
            width: 34px;
            height: 34px;
            border-radius: 0;
            background: var(--ink, #0D0D0D);
            color: var(--accent, #C6F24E);
            display: flex;
            align-items: center;
            justify-content: center;
            font: 700 12px var(--mono, 'JetBrains Mono', monospace);
            letter-spacing: .04em;
            border: 1px solid var(--ink, #0D0D0D);
            cursor: pointer;
            flex-shrink: 0;
            transition: background .12s, color .12s;
        }
        .nav-avatar:hover {
            background: var(--accent, #C6F24E);
            color: var(--ink, #0D0D0D);
        }

        /* Dropdown utilisateur */
        .nav-user { position: relative; }
        .nav-user-menu {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            right: 0;
            min-width: 200px;
            background: var(--bg, #F2EFE6);
            border: 1px solid var(--ink, #0D0D0D);
            z-index: 200;
        }
        .nav-user-menu.is-open { display: block; }
        .nav-user-item {
            display: block;
            padding: 10px 16px;
            font: 500 13px var(--body, 'Space Grotesk', sans-serif);
            color: var(--ink, #0D0D0D);
            text-decoration: none;
            border-bottom: 1px solid var(--line-soft, rgba(13,13,13,.10));
        }
        .nav-user-item:last-child { border-bottom: 0; }
        .nav-user-item:hover { background: var(--bg-alt, #E8E5DC); }
        .nav-user-item.danger { color: var(--accent-2, #FF6B2C); }
        .nav-user-item.danger:hover { background: var(--accent-2, #FF6B2C); color: #fff; }

        /* ── Hamburger (mobile uniquement) ── */
        .nav-hamburger {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            width: 40px;
            height: 40px;
            flex-shrink: 0;
        }
        .nav-hamburger-bar {
            display: block;
            width: 22px;
            height: 2px;
            background: var(--ink, #0D0D0D);
        }

        /* ── Panneau mobile (plein écran, glisse sous la nav) ── */
        .nav-mobile {
            display: none;
            position: fixed;
            top: 64px;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--bg, #F2EFE6);
            border-top: 1px solid var(--ink, #0D0D0D);
            z-index: 99;
            overflow-y: auto;
        }
        .nav-mobile.is-open { display: block; }
        .nav-mobile-item {
            display: block;
            padding: 16px 24px;
            font: 700 14px var(--body, 'Space Grotesk', sans-serif);
            letter-spacing: .04em;
            text-transform: uppercase;
            color: var(--ink, #0D0D0D);
            text-decoration: none;
            border-bottom: 1px solid var(--line-soft, rgba(13,13,13,.10));
        }
        .nav-mobile-item:hover { background: var(--ink, #0D0D0D); color: var(--accent, #C6F24E); }
        .nav-mobile-item.danger { color: var(--accent-2, #FF6B2C); }
        .nav-mobile-sep { height: 1px; background: var(--ink, #0D0D0D); margin: 4px 0; }

        /* Overlay semi-transparent derrière le menu mobile */
        .nav-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(13,13,13,.45);
            z-index: 98;
        }
        .nav-overlay.is-open { display: block; }

        /* ── Responsive ── */
        @media (max-width: 767px) {
            /* Sur mobile, les onglets disparaissent → hamburger prend le relais */
            .nav-tabs { display: none; }
            .nav-hamburger { display: flex; }
            .nav-side { border-left: 0; padding: 0 8px; gap: 6px; }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{#
    {% block navbar %} encapsule l'intégralité de la nav (skip link, overlay,
    header.nav, nav mobile). Ce bloc est overridable par les templates enfants.

    Usage : les templates qui ont leur propre navigation (ex: base_admin.html.twig
    avec sa sidebar) écrasent ce bloc avec un bloc vide :
        {% block navbar %}{% endblock %}

    Par défaut (pages connectées, vitrine) : la nav Street est rendue.
#}
{% block navbar %}

{# ── Lien "Passer au contenu" — accessibilité WCAG 2.4.1 ──────────────────── #}
{#
    Ce lien est invisible par défaut (position: absolute, left: -9999px).
    Il devient visible quand il reçoit le focus clavier (via :focus / onfocus).
    Il permet aux utilisateurs de navigation au clavier de sauter directement
    au contenu principal sans traverser toute la nav.

    L'attribut href="#main-content" cible l'élément id="main-content" défini
    dans les templates enfants (base_app.html.twig → <main id="main-content">)
    ou directement dans vitrine/index.html.twig → <main id="main-content">.
#}
<a href="#main-content"
   style="position:absolute;left:-9999px;top:0;z-index:999;
          background:var(--ink,#0D0D0D);color:var(--accent,#C6F24E);
          padding:8px 16px;font:700 12px var(--mono,'JetBrains Mono',monospace);
          text-transform:uppercase;letter-spacing:.06em;text-decoration:none;"
   onfocus="this.style.left='0'" onblur="this.style.left='-9999px'">
    Passer au contenu principal
</a>

{# Overlay mobile — arrière-plan semi-opaque derrière le panneau hamburger #}
<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

{# ══════════════════════════════════════════════════════════════════════════════
 # NAV PRINCIPALE — commune à toutes les pages
 #
 # Structure conforme au prototype (app.jsx, composant App) :
 #   .nav > .nav-inner > [.nav-logo] [.nav-tabs] [.nav-side]
 #
 # Menu (ordre exact du prototype) :
 #   Accueil · Opportunités · Forum · Blog
 #
 # Côté droit :
 #   - Utilisateur NON connecté : Connexion + Rejoindre
 #   - Utilisateur connecté     : avatar ▾ avec dropdown (Mon espace + Déconnexion)
 #
 # ══════════════════════════════════════════════════════════════════════════ #}
{# currentRoute : nom Symfony de la route active (ex: "app_resource_index").
   Utilisé pour positionner data-active="true" sur le bon onglet.
   app.request est disponible dans tous les templates Twig via l'objet `app`. #}
{% set currentRoute = app.request.attributes.get('_route') %}

<header class="nav" role="banner">
    <div class="nav-inner">

        {# ── Logo : bloc fond NOIR à gauche, image verte ─────────────────── #}
        <a href="{{ path('app_home') }}" class="nav-logo" aria-label="BazaArt — accueil">
            <img src="{{ asset('images/logo-green.png') }}"
                 alt="BAZAART"
                 style="display:block;height:20px;width:auto;">
        </a>

        {# ── Onglets — EXACTEMENT les 4 items demandés ────────────────────── #}
        <nav class="nav-tabs" aria-label="Navigation principale">

            {# 1. Accueil #}
            <a href="{{ path('app_home') }}"
               class="nav-tab"
               data-active="{{ currentRoute == 'app_home' ? 'true' : 'false' }}"
               {% if currentRoute == 'app_home' %}aria-current="page"{% endif %}>
                <span class="dot" aria-hidden="true"></span>Accueil
            </a>

            {# 2. Opportunités (= Ressourcerie dans le CDC) #}
            <a href="{{ path('app_resource_index') }}"
               class="nav-tab"
               data-active="{{ currentRoute starts with 'app_resource' ? 'true' : 'false' }}"
               {% if currentRoute starts with 'app_resource' %}aria-current="page"{% endif %}>
                <span class="dot" aria-hidden="true"></span>Opportunités
            </a>

            {# 3. Forum (englobe aussi messagerie et posts) #}
            <a href="{{ path('app_forum_index') }}"
               class="nav-tab"
               data-active="{{ (currentRoute starts with 'app_forum' or currentRoute starts with 'app_post' or currentRoute starts with 'app_messaging') ? 'true' : 'false' }}"
               {% if currentRoute starts with 'app_forum' or currentRoute starts with 'app_post' or currentRoute starts with 'app_messaging' %}aria-current="page"{% endif %}>
                <span class="dot" aria-hidden="true"></span>Forum
            </a>

            {# 4. Blog (articles éditoriaux) #}
            <a href="{{ path('app_article_index') }}"
               class="nav-tab"
               data-active="{{ currentRoute starts with 'app_article' ? 'true' : 'false' }}"
               {% if currentRoute starts with 'app_article' %}aria-current="page"{% endif %}>
                <span class="dot" aria-hidden="true"></span>Blog
            </a>

        </nav>

        {# ── Côté droit — conditionnel selon l'état de connexion ──────────── #}
        <div class="nav-side">

            {% if app.user %}
                {#
                    Utilisateur CONNECTÉ → avatar avec dropdown.
                    Les initiales sont extraites des 2 premières lettres de l'identifiant
                    email (partie avant @). Exemple : "amara.diallo@bazaart.fr" → "AM".
                    À améliorer quand User exposera firstName/lastName.
                #}
                {% set initials = app.user.email|split('@')|first|slice(0,2)|upper %}
                <div class="nav-user">
                    <button type="button"
                            class="nav-avatar"
                            id="user-btn"
                            aria-expanded="false"
                            aria-controls="user-menu"
                            aria-label="Menu de {{ app.user.email|split('@')|first }}">
                        {{ initials }}
                    </button>
                    <div class="nav-user-menu" id="user-menu" role="menu" aria-labelledby="user-btn">
                        <a href="{{ path('app_dashboard') }}" class="nav-user-item" role="menuitem">
                            Mon espace
                        </a>
                        <a href="{{ path('app_logout') }}" class="nav-user-item danger" role="menuitem">
                            Se déconnecter
                        </a>
                    </div>
                </div>

            {% else %}
                {#
                    Utilisateur NON connecté → Connexion + Rejoindre.
                    Ordre imposé par la spec : Connexion (secondaire) puis Rejoindre (primaire).
                    "Connexion" = ghost (transparent), "Rejoindre" = lime (CTA vert).
                #}
                <a href="{{ path('app_login') }}" class="nav-btn nav-btn--ghost">
                    Connexion
                </a>
                <a href="{{ path('app_register') }}" class="nav-btn nav-btn--lime">
                    Rejoindre
                </a>
            {% endif %}

            {# Hamburger — visible uniquement sur mobile (< 768px via CSS) #}
            <button type="button"
                    class="nav-hamburger"
                    id="nav-hamburger"
                    aria-expanded="false"
                    aria-controls="nav-mobile"
                    aria-label="Ouvrir le menu">
                <span class="nav-hamburger-bar" aria-hidden="true"></span>
                <span class="nav-hamburger-bar" aria-hidden="true"></span>
                <span class="nav-hamburger-bar" aria-hidden="true"></span>
            </button>

        </div>
    </div>
</header>

{# ── NAV MOBILE (panneau plein écran, < 768px) ──────────────────────────── #}
{#
    Ce panneau est masqué par défaut (CSS display:none).
    La classe .is-open l'affiche (ajoutée/retirée par le JS ci-dessous).
    Il contient les mêmes liens que la nav desktop + les CTAs auth.
#}
<nav class="nav-mobile"
     id="nav-mobile"
     aria-label="Menu mobile"
     aria-hidden="true">

    <a href="{{ path('app_home') }}" class="nav-mobile-item">Accueil</a>
    <a href="{{ path('app_resource_index') }}" class="nav-mobile-item">Opportunités</a>
    <a href="{{ path('app_forum_index') }}" class="nav-mobile-item">Forum</a>
    <a href="{{ path('app_article_index') }}" class="nav-mobile-item">Blog</a>

    <div class="nav-mobile-sep"></div>

    {% if app.user %}
        <a href="{{ path('app_dashboard') }}" class="nav-mobile-item">Mon espace</a>
        <a href="{{ path('app_logout') }}" class="nav-mobile-item danger">Se déconnecter</a>
    {% else %}
        <a href="{{ path('app_login') }}" class="nav-mobile-item">Connexion</a>
        <a href="{{ path('app_register') }}" class="nav-mobile-item"
           style="color:var(--accent, #C6F24E);">Rejoindre</a>
    {% endif %}

</nav>

{% endblock %}{# fin du bloc navbar #}

{# ── CONTENU DE LA PAGE ─────────────────────────────────────────────────── #}
{% block body %}{% endblock %}

{# ── SCRIPTS ────────────────────────────────────────────────────────────── #}
{#
    Les scripts nav sont ici plutôt que dans un fichier externe pour éviter
    une dépendance supplémentaire (pas de bundler configuré en V1).
    Chaque IIFE (Immediately Invoked Function Expression) est autonome :
    il vérifie l'existence de ses éléments avant d'agir → aucune erreur
    si la page ne contient pas les éléments attendus.

    {{ parent() }} dans les templates enfants ajoutera leurs propres scripts
    APRÈS ces scripts nav — ordre garanti.
#}
{% block javascripts %}
<script>
/* ── Hamburger mobile ────────────────────────────────────────────────────── */
(function () {
    'use strict';
    var btn = document.getElementById('nav-hamburger');
    var mob = document.getElementById('nav-mobile');
    var ovl = document.getElementById('nav-overlay');
    if (!btn || !mob || !ovl) return;

    function open() {
        mob.classList.add('is-open');
        ovl.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        mob.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden'; /* bloque le scroll du body */
    }
    function close() {
        mob.classList.remove('is-open');
        ovl.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        mob.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    btn.addEventListener('click', function () {
        mob.classList.contains('is-open') ? close() : open();
    });
    ovl.addEventListener('click', close);
    /* Fermeture sur clic d'un lien (navigation) */
    mob.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', close);
    });
    /* Fermeture sur touche Échap — accessibilité clavier */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && mob.classList.contains('is-open')) {
            close();
            btn.focus(); /* remet le focus sur le bouton hamburger */
        }
    });
}());

/* ── Dropdown avatar (utilisateur connecté) ─────────────────────────────── */
(function () {
    'use strict';
    var btn  = document.getElementById('user-btn');
    var menu = document.getElementById('user-menu');
    if (!btn || !menu) return; /* non connecté → éléments absents du DOM */

    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', menu.classList.contains('is-open') ? 'true' : 'false');
    });
    /* Clic en dehors → fermeture */
    document.addEventListener('click', function (e) {
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
            menu.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
        }
    });
    /* Touche Échap → fermeture + focus bouton */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && menu.classList.contains('is-open')) {
            menu.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
            btn.focus();
        }
    });
}());
</script>
{% endblock %}

{# ── BANNIÈRE DE CONSENTEMENT COOKIES (RGPD) ──────────────────────────────── #}
{#
    Implémentation légère sans bibliothèque externe (pas de tarteaucitron en V1).

    Fonctionnement :
    1. Le script vérifie si le cookie "cookie_consent" existe.
    2. Si absent → la bannière est affichée (display: flex).
    3. Au clic sur "Accepter" → cookie posé (max-age: 1 an), bannière masquée.
    4. Au clic sur "Refuser" → cookie posé (max-age: 1 an), bannière masquée.

    Pourquoi un cookie et pas localStorage ?
    - Les cookies peuvent être lus côté serveur (pour décider d'injecter des scripts
      analytiques ou non côté Twig à terme).
    - localStorage est bloqué par certains modes de navigation privée.
    - La durée de vie explicite (1 an) est lisible et configurable.

    SameSite=Lax :
    - Valeur recommandée par défaut (depuis Chrome 80+).
    - Empêche l'envoi du cookie dans les requêtes cross-site de type POST.
    - Plus permissif que SameSite=Strict (permet le suivi de liens entre sites).

    Design : fond --ink (noir), texte --bg (sable), boutons cohérents avec la nav.
    Position : fixed en bas (bottom: 0), z-index 1000 (au-dessus de tout).
#}
<div id="cookie-banner"
     role="alertdialog"
     aria-labelledby="cookie-banner-title"
     aria-describedby="cookie-banner-desc"
     style="
        display: none;         /* caché par défaut, affiché par JS si pas de consentement */
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: var(--ink, #0D0D0D);
        color: var(--bg, #F2EFE6);
        border-top: 2px solid var(--accent, #C6F24E);
        padding: 16px 24px;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        font-family: var(--body, 'Space Grotesk', sans-serif);
     ">

    {# Texte informatif #}
    <div style="flex: 1; min-width: 280px;">
        <span id="cookie-banner-title"
              style="font-family: var(--mono, 'JetBrains Mono', monospace);
                     font-size: 10px;
                     font-weight: 700;
                     letter-spacing: .1em;
                     text-transform: uppercase;
                     color: var(--accent, #C6F24E);
                     display: block;
                     margin-bottom: 4px;">
            Cookies
        </span>
        <p id="cookie-banner-desc"
           style="font-size: 13px; line-height: 1.5; margin: 0; opacity: .85;">
            Ce site utilise des cookies nécessaires à son fonctionnement (session, authentification).
            <a href="{{ path('app_legal_privacy') }}"
               style="color: var(--accent, #C6F24E); text-decoration: underline;">
                En savoir plus
            </a>
        </p>
    </div>

    {# Boutons de choix #}
    <div style="display: flex; gap: 10px; flex-shrink: 0;">

        {# Bouton "Refuser" — outline discret #}
        <button id="cookie-refuse"
                type="button"
                onclick="cookieConsent('refused')"
                style="
                    padding: 8px 16px;
                    font: 700 11px/1 var(--body, 'Space Grotesk', sans-serif);
                    letter-spacing: .05em;
                    text-transform: uppercase;
                    background: transparent;
                    color: var(--bg, #F2EFE6);
                    border: 1px solid rgba(242,239,230,.4);
                    cursor: pointer;
                    transition: border-color .12s, background .12s;
                "
                onmouseover="this.style.borderColor='var(--bg)'"
                onmouseout="this.style.borderColor='rgba(242,239,230,.4)'">
            Refuser
        </button>

        {# Bouton "Accepter" — fond vert acide (CTA) #}
        <button id="cookie-accept"
                type="button"
                onclick="cookieConsent('accepted')"
                style="
                    padding: 8px 16px;
                    font: 700 11px/1 var(--body, 'Space Grotesk', sans-serif);
                    letter-spacing: .05em;
                    text-transform: uppercase;
                    background: var(--accent, #C6F24E);
                    color: var(--ink, #0D0D0D);
                    border: 1px solid var(--accent, #C6F24E);
                    cursor: pointer;
                    transition: background .12s, color .12s;
                "
                onmouseover="this.style.background='var(--bg)'; this.style.color='var(--ink)'"
                onmouseout="this.style.background='var(--accent)'; this.style.color='var(--ink)'">
            Accepter
        </button>

    </div>

</div>

<script>
/*
 * Gestion du consentement cookies — bannière RGPD.
 *
 * Convention IIFE : portée isolée pour ne pas polluer le scope global.
 *
 * Lecture/écriture des cookies :
 *   - document.cookie est une string spéciale : lire retourne TOUS les cookies
 *     concaténés, écrire ajoute ou modifie UN SEUL cookie.
 *   - Pour lire un cookie spécifique, on split et on cherche par nom.
 *
 * maxAge : 31536000 secondes = 365 jours.
 * Path=/ : le cookie est valide sur tout le domaine (pas seulement /profil/rgpd).
 * SameSite=Lax : protection CSRF standard (Chrome 80+ l'impose de toute façon).
 */
(function () {
    'use strict';

    var COOKIE_NAME = 'cookie_consent';
    var COOKIE_MAX_AGE = 31536000; /* 1 an en secondes */
    var banner = document.getElementById('cookie-banner');

    /**
     * Lit la valeur d'un cookie par son nom.
     * Retourne null si le cookie n'existe pas.
     *
     * @param {string} name - Nom du cookie à lire
     * @return {string|null}
     */
    function getCookie(name) {
        var cookies = document.cookie.split('; ');
        for (var i = 0; i < cookies.length; i++) {
            var parts = cookies[i].split('=');
            if (parts[0] === name) {
                return decodeURIComponent(parts[1]);
            }
        }
        return null;
    }

    /**
     * Pose le cookie de consentement et masque la bannière.
     * Appelée par les boutons "Accepter" et "Refuser".
     *
     * @param {string} value - 'accepted' ou 'refused'
     */
    window.cookieConsent = function (value) {
        /* Écriture du cookie : un seul cookie à la fois avec document.cookie */
        document.cookie = COOKIE_NAME + '=' + value
            + '; max-age=' + COOKIE_MAX_AGE
            + '; path=/'
            + '; SameSite=Lax'
            /* Secure : ajouté uniquement en HTTPS (production).
             * En HTTP (dev sur localhost:8080), les navigateurs ignorent silencieusement
             * un cookie Secure → la bannière réapparaîtrait à chaque rechargement.
             * location.protocol === 'https:' évite ce problème sans changer le code serveur. */
            + (location.protocol === 'https:' ? '; Secure' : '');

        /* Masque la bannière sans la supprimer du DOM */
        if (banner) {
            banner.style.display = 'none';
        }
    };

    /* Au chargement de la page : afficher la bannière si pas encore de consentement */
    if (banner && getCookie(COOKIE_NAME) === null) {
        /* display: flex car la bannière utilise flexbox */
        banner.style.display = 'flex';
    }

}());
</script>

</body>
</html>
