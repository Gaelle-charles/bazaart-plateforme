{% extends 'base_admin.html.twig' %}

{#
 # admin/structures_pending.html.twig — Candidatures Structure en attente d'activation
 #
 # Thème : Street
 # Layout parent : base_admin.html.twig
 #
 # Variables disponibles (AdminController::structuresPending()) :
 #   - pendingApplications : OrganizationProfile[]
 #     Critère : structureApplicationAt IS NOT NULL AND isStructurePartner = false
 #     Triées FIFO par date ASC (les plus anciennes d'abord)
 #
 # Actions disponibles :
 #   - Activer : POST /admin/structures/{id}/activate (CSRF : 'structure_activate_{id}')
 #   - Rejeter  : POST /admin/structures/{id}/reject  (CSRF : 'structure_reject_{id}')
 #}

{% block title %}Candidatures Structure — Admin BazaArt{% endblock %}
{% block page_title %}Structures partenaires{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

    /* ── Zone de contenu fond sable ─────────────────────────────────────────── */
    .app-content {
        background: var(--bg);
        font-family: var(--body);
    }

    /* ── Retour dashboard ───────────────────────────────────────────────────── */
    .adm-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .06em;
        color: var(--ink-mute);
        text-decoration: none;
        margin-bottom: 20px;
        transition: color var(--transition-fast);
    }
    .adm-back:hover { color: var(--ink); }

    /* ── En-tête de section ─────────────────────────────────────────────────── */
    .adm-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 24px;
    }
    .adm-section-title {
        font-family: var(--display);
        font-size: 24px;
        text-transform: uppercase;
        letter-spacing: -.01em;
        color: var(--ink);
    }
    /* Badge compteur — orange si en attente */
    .adm-count-badge {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        padding: 5px 12px;
        background: var(--accent-2);
        color: var(--ink);
        border: 1px solid var(--ink);
    }

    /* ── Carte de candidature Structure — style Street ───────────────────────── */
    .adm-struct-card {
        border: 1px solid var(--ink);
        background: var(--bg);
        margin-bottom: 20px;
    }

    /* En-tête de carte : nom organisation + date candidature */
    .adm-struct-card__head {
        padding: 14px 18px;
        background: var(--ink);         /* fond noir — affiche l'importance de la décision */
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }
    .adm-struct-card__name {
        font-family: var(--display);
        font-size: 20px;
        text-transform: uppercase;
        letter-spacing: -.01em;
        color: var(--bg);              /* texte sable sur fond noir */
        margin-bottom: 4px;
    }
    /* Email du compte lié — chip mono sur fond noir */
    .adm-struct-card__user {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: .06em;
        color: var(--accent);          /* vert acide */
        font-weight: 700;
    }
    /* Date de candidature à droite */
    .adm-struct-card__date {
        font-family: var(--mono);
        font-size: 10px;
        color: rgba(242,239,230,.55);  /* sable transparent */
        letter-spacing: .06em;
        text-align: right;
    }
    .adm-struct-card__date strong {
        color: var(--accent-2);         /* orange — alerte temporelle */
        font-weight: 700;
        display: block;
        font-size: 12px;
        margin-top: 2px;
    }

    /* Corps de la carte */
    .adm-struct-card__body {
        padding: 18px;
    }

    /* Grille d'informations : email, SIRET, localisation, site */
    .adm-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 14px;
        margin-bottom: 16px;
    }
    .adm-info-item__label {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--ink-mute);
        margin-bottom: 3px;
    }
    .adm-info-item__value {
        font-size: 13px;
        color: var(--ink);
        font-weight: 500;
        word-break: break-word;
    }
    .adm-info-item__value a {
        color: var(--accent-2);
        text-decoration: none;
        font-weight: 700;
    }
    .adm-info-item__value a:hover { text-decoration: underline; }
    /* Valeur non renseignée */
    .adm-info-item__empty {
        color: var(--ink-mute);
        font-style: italic;
        font-size: 12px;
    }

    /* Description de l'organisation (texte long) */
    .adm-struct-desc {
        font-size: 13px;
        line-height: 1.7;
        color: var(--ink-mute);
        padding: 12px 14px;
        background: var(--bg-alt);
        border-left: 3px solid var(--accent);  /* accent vert — marque éditoriale Street */
        margin-bottom: 18px;
    }

    /* Barre d'actions : Activer / Rejeter */
    .adm-struct-card__actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding-top: 16px;
        border-top: 1px solid var(--line-soft);
    }

    /* Bouton Activer — fond vert acide (vert = action positive) */
    .adm-btn-activate {
        height: 38px;
        padding: 0 24px;
        background: var(--accent);
        color: var(--ink);
        border: 2px solid var(--ink);
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        cursor: pointer;
        transition: box-shadow var(--transition-fast);
    }
    .adm-btn-activate:hover { box-shadow: var(--shadow-offset-sm); }

    /* Bouton Refuser — fond blanc avec bordure ink (action irréversible) */
    .adm-btn-reject {
        height: 38px;
        padding: 0 24px;
        background: var(--bg);
        color: var(--danger);
        border: 2px solid var(--danger);
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        cursor: pointer;
        transition: box-shadow var(--transition-fast), background var(--transition-fast);
    }
    .adm-btn-reject:hover {
        background: var(--danger);
        color: #fff;
        box-shadow: 4px 4px 0 var(--danger);
    }

    /* Note explicative (texte discret) */
    .adm-note {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--ink-mute);
        letter-spacing: .04em;
        margin-left: auto;             /* pousse la note à droite de la barre */
    }

    /* ── État vide ──────────────────────────────────────────────────────────── */
    .adm-empty-state {
        border: 1px solid var(--ink);
        background: var(--bg);
        padding: 56px 48px;
        text-align: center;
    }
    .adm-empty-state__icon {
        font-family: var(--display);
        font-size: 48px;
        color: var(--accent);
        display: block;
        margin-bottom: 12px;
    }
    .adm-empty-state__msg {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--ink-mute);
    }
    .adm-empty-state__sub {
        font-size: 12px;
        color: var(--ink-mute);
        margin-top: 10px;
    }
    .adm-empty-state__sub code {
        background: var(--bg-alt);
        border: 1px solid var(--line-soft);
        padding: 1px 5px;
        font-family: var(--mono);
        font-size: 11px;
    }

</style>
{% endblock %}

{% block content %}

{# ── Retour + en-tête ─────────────────────────────────────────────────────── #}
<a href="{{ path('app_admin_dashboard') }}" class="adm-back">← Tableau de bord</a>

<div class="adm-section-header">
    <h2 class="adm-section-title">Candidatures Structure</h2>
    <span class="adm-count-badge">
        {{ pendingApplications|length }} candidature{{ pendingApplications|length > 1 ? 's' : '' }} en attente
    </span>
</div>

{% if pendingApplications is empty %}

    {# ── File vide — aucune candidature en attente ────────────────────────── #}
    <div class="adm-empty-state">
        <span class="adm-empty-state__icon">✓</span>
        <p class="adm-empty-state__msg">Aucune candidature en attente.</p>
        <p class="adm-empty-state__sub">
            Les nouvelles demandes apparaîtront ici dès qu'une organisation déposera<br>
            sa candidature via <code>/structure/register</code>.
        </p>
    </div>

{% else %}

    {#
      ── Liste des candidatures (triées FIFO — les plus anciennes en premier) ──
      L'ordre est garanti par OrganizationProfileRepository::findPendingStructureApplications()
    #}
    {% for orgProfile in pendingApplications %}
        <article class="adm-struct-card">

            {# En-tête sombre : nom organisation + email du compte + date de candidature #}
            <div class="adm-struct-card__head">
                <div>
                    <div class="adm-struct-card__name">{{ orgProfile.name }}</div>
                    {# Email du compte utilisateur associé au profil organisation #}
                    <div class="adm-struct-card__user">{{ orgProfile.user.email }}</div>
                </div>
                <div class="adm-struct-card__date">
                    Candidature soumise le
                    <strong>{{ orgProfile.structureApplicationAt|date('d/m/Y') }}</strong>
                    à {{ orgProfile.structureApplicationAt|date('H:i') }}
                </div>
            </div>

            <div class="adm-struct-card__body">

                {# Grille d'informations : 4 champs clés de l'organisation #}
                <div class="adm-info-grid">

                    {# Email de contact (peut différer de l'email du compte) #}
                    <div>
                        <div class="adm-info-item__label">Email de contact</div>
                        <div class="adm-info-item__value">
                            {% if orgProfile.contactEmail %}
                                {# Lien mailto direct pour faciliter le travail de l'admin #}
                                <a href="mailto:{{ orgProfile.contactEmail }}">{{ orgProfile.contactEmail }}</a>
                            {% else %}
                                <span class="adm-info-item__empty">Non renseigné</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Numéro SIRET — identifiant légal de l'organisation #}
                    <div>
                        <div class="adm-info-item__label">SIRET</div>
                        <div class="adm-info-item__value">
                            {% if orgProfile.siret %}
                                {# Le SIRET est affiché en mono pour lisibilité des chiffres #}
                                <span style="font-family:var(--mono); font-size:13px;">{{ orgProfile.siret }}</span>
                            {% else %}
                                <span class="adm-info-item__empty">Non renseigné</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Localisation géographique #}
                    <div>
                        <div class="adm-info-item__label">Localisation</div>
                        <div class="adm-info-item__value">{{ orgProfile.location ?? '—' }}</div>
                    </div>

                    {# Site web officiel #}
                    <div>
                        <div class="adm-info-item__label">Site web</div>
                        <div class="adm-info-item__value">
                            {% if orgProfile.websiteUrl %}
                                <a href="{{ orgProfile.websiteUrl }}" target="_blank" rel="noopener noreferrer">
                                    {{ orgProfile.websiteUrl|slice(0, 40) }}{{ orgProfile.websiteUrl|length > 40 ? '…' : '' }}
                                </a>
                            {% else %}
                                <span class="adm-info-item__empty">Non renseigné</span>
                            {% endif %}
                        </div>
                    </div>

                </div>

                {# Description de l'organisation (si renseignée) #}
                {% if orgProfile.description %}
                    <div class="adm-struct-desc">
                        {# Tronquée à 400 chars pour la vue liste — la description complète est sur le profil #}
                        {{ orgProfile.description|slice(0, 400) }}{{ orgProfile.description|length > 400 ? '…' : '' }}
                    </div>
                {% endif %}

                {# ── Boutons d'action : Activer / Refuser ──────────────────────── #}
                {#
                  Chaque action est dans son propre formulaire POST indépendant.
                  Les tokens CSRF sont distincts pour chaque action et chaque organisation :
                    - 'structure_activate_{id}' pour l'activation
                    - 'structure_reject_{id}' pour le rejet
                  Ces noms sont vérifiés côté PHP dans AdminController.
                #}
                <div class="adm-struct-card__actions">

                    {# Formulaire ACTIVATION — confirmation obligatoire côté JS #}
                    <form method="POST" action="{{ path('app_admin_structure_activate', {id: orgProfile.id}) }}"
                          onsubmit="return confirm('Activer le compte Structure pour « {{ orgProfile.name|e('js') }} » ?\nCette organisation pourra publier ses opportunités directement.')">
                        <input type="hidden" name="_token" value="{{ csrf_token('structure_activate_' ~ orgProfile.id) }}">
                        <button type="submit" class="adm-btn-activate">✓ Activer</button>
                    </form>

                    {# Formulaire REJET — confirmation avec rappel que l'org peut re-candidater #}
                    <form method="POST" action="{{ path('app_admin_structure_reject', {id: orgProfile.id}) }}"
                          onsubmit="return confirm('Refuser la candidature de « {{ orgProfile.name|e('js') }} » ?\nL\'organisation pourra re-candidater ultérieurement.')">
                        <input type="hidden" name="_token" value="{{ csrf_token('structure_reject_' ~ orgProfile.id) }}">
                        <button type="submit" class="adm-btn-reject">✗ Refuser</button>
                    </form>

                    {# Note discrète à droite de la barre #}
                    <span class="adm-note">Le refus est réversible — l'org peut re-candidater</span>

                </div>

            </div>
        </article>
    {% endfor %}

{% endif %}

{% endblock %}
