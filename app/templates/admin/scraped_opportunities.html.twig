{% extends 'base_admin.html.twig' %}

{#
 # admin/scraped_opportunities.html.twig — Opportunités scrapées (Google Sheets)
 #
 # Thème : Street
 # Layout parent : base_admin.html.twig
 #
 # Variables disponibles (AdminController::scrapedOpportunities()) :
 #   - pending  : ScrapedResource[] — statut "À vérifier" triés par score desc
 #   - verified : ScrapedResource[] — statut "Vérifié" (archives)
 #
 # Actions disponibles :
 #   - Vérifier : POST /admin/scraped-opportunities/{id}/verify (CSRF : 'verify_scraped_{id}')
 #                → change le statut ScrapedResource à "verified" ET crée une Resource publiée
 #}

{% block title %}Scraping — Admin BazaArt{% endblock %}
{% block page_title %}Scraping Sheets{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

    /* ── Zone de contenu fond sable ─────────────────────────────────────────── */
    .app-content {
        background: var(--bg);
        font-family: var(--body);
    }

    /* ── Retour dashboard ───────────────────────────────────────────────────── */
    .adm-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .06em;
        color: var(--ink-mute);
        text-decoration: none;
        margin-bottom: 14px;
        transition: color var(--transition-fast);
    }
    .adm-back:hover { color: var(--ink); }

    /* ── Hint commande scraping ─────────────────────────────────────────────── */
    .adm-hint {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        margin-bottom: 20px;
        letter-spacing: .04em;
    }
    .adm-hint code {
        background: var(--ink);
        color: var(--accent);
        padding: 2px 8px;
        font-size: 11px;
        font-family: var(--mono);
        display: inline-block;
        margin-left: 4px;
    }

    /* ── Onglets Street (À vérifier / Vérifié) ──────────────────────────────── */
    /*
      Style : bandeau horizontal, l'onglet actif a un fond ink et un texte accent.
      Les onglets inactifs ont fond bg-alt. Bords francs (pas de border-radius).
    */
    .adm-tabs {
        display: flex;
        border: 1px solid var(--ink);
        margin-bottom: 20px;
        width: fit-content;
    }
    .adm-tab-btn {
        padding: 10px 20px;
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        border: none;
        border-right: 1px solid var(--ink);
        background: var(--bg-alt);
        color: var(--ink);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background var(--transition-fast);
    }
    .adm-tab-btn:last-child { border-right: none; }
    /* Onglet actif : fond noir, texte vert */
    .adm-tab-btn.active {
        background: var(--ink);
        color: var(--accent);
    }
    .adm-tab-btn:hover:not(.active) { background: var(--bg); }

    /* Compteur dans l'onglet */
    .adm-tab-count {
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        font-size: 10px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    /* Compteur en attente : fond orange */
    .adm-tab-count--pending  { background: var(--accent-2); color: var(--ink); }
    /* Compteur vérifié : fond vert acide */
    .adm-tab-count--verified { background: var(--accent); color: var(--ink); }

    /* Panneaux d'onglets (affichés/masqués via JS) */
    .adm-tab-panel { display: none; }
    .adm-tab-panel.active { display: block; }

    /* ── Tableau Street — en-tête noir + corps sable ─────────────────────────── */
    .adm-table-wrap {
        border: 1px solid var(--ink);
        background: var(--bg);
        overflow-x: auto;             /* scroll horizontal sur mobile */
        -webkit-overflow-scrolling: touch;
    }
    .adm-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 680px;
    }
    .adm-table thead tr { background: var(--ink); }
    .adm-table th {
        padding: 11px 14px;
        text-align: left;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--accent);
        border-right: 1px solid rgba(198,242,78,.15);
        white-space: nowrap;
    }
    .adm-table th:last-child { border-right: none; }
    .adm-table td {
        padding: 11px 14px;
        border-bottom: 1px solid var(--line-soft);
        font-size: 13px;
        color: var(--ink);
        vertical-align: top;
    }
    .adm-table tbody tr:last-child td { border-bottom: none; }
    .adm-table tbody tr:nth-child(even) { background: var(--bg-alt); }
    .adm-table tbody tr:hover { background: rgba(13,13,13,.04); }

    /* Colonne titre : lien externe vers la source */
    .adm-opp-title {
        font-weight: 600;
        line-height: 1.4;
        max-width: 300px;
    }
    .adm-opp-title a {
        color: inherit;
        text-decoration: none;
    }
    .adm-opp-title a:hover { color: var(--accent-2); text-decoration: underline; }

    /* Description tronquée sous le titre */
    .adm-opp-desc {
        font-size: 12px;
        color: var(--ink-mute);
        margin-top: 4px;
        line-height: 1.5;
    }

    /* Chip de type de ressource */
    .adm-chip {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        border: 1px solid var(--ink);
        background: var(--bg-alt);
        color: var(--ink);
        white-space: nowrap;
    }

    /* Badge "Vérifié" — fond vert acide */
    .adm-badge-verified {
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--accent);
        color: var(--ink);
    }

    /* Étoiles de score afro-pertinence */
    .adm-stars {
        color: var(--accent-2);   /* orange pour les étoiles pleines */
        font-size: 13px;
        letter-spacing: 1px;
        white-space: nowrap;
    }
    .adm-stars .star-empty { color: var(--line-soft); }

    /* Bouton Vérifier — action principale */
    .adm-btn-verify {
        height: 30px;
        padding: 0 14px;
        background: var(--accent);
        color: var(--ink);
        border: 1px solid var(--ink);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        cursor: pointer;
        white-space: nowrap;
        transition: box-shadow var(--transition-fast);
    }
    .adm-btn-verify:hover { box-shadow: var(--shadow-offset-sm); }

    /* Date de scraping — mono compact */
    .adm-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        white-space: nowrap;
    }

    /* ── État vide ──────────────────────────────────────────────────────────── */
    .adm-empty-state {
        border: 1px solid var(--ink);
        background: var(--bg);
        padding: 48px;
        text-align: center;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--ink-mute);
        letter-spacing: .06em;
        text-transform: uppercase;
    }

</style>
{% endblock %}

{% block content %}

{# ── Retour dashboard ─────────────────────────────────────────────────────── #}
<a href="{{ path('app_admin_dashboard') }}" class="adm-back">← Tableau de bord</a>

{# Rappel de la commande pour lancer le scraping manuellement #}
<p class="adm-hint">
    Lancer le scraping :
    <code>docker compose exec app php bin/console app:scrape-opportunities</code>
</p>

{# ── Onglets À vérifier / Vérifié ─────────────────────────────────────────── #}
{# role="tablist" + aria-selected pour l'accessibilité clavier #}
<div class="adm-tabs" role="tablist">
    <button class="adm-tab-btn active"
            role="tab"
            aria-selected="true"
            aria-controls="tab-pending"
            onclick="showTab('pending', this)">
        À vérifier
        <span class="adm-tab-count adm-tab-count--pending">{{ pending|length }}</span>
    </button>
    <button class="adm-tab-btn"
            role="tab"
            aria-selected="false"
            aria-controls="tab-verified"
            onclick="showTab('verified', this)">
        Vérifié
        <span class="adm-tab-count adm-tab-count--verified">{{ verified|length }}</span>
    </button>
</div>

{# ── Panneau : À VÉRIFIER ─────────────────────────────────────────────────── #}
<div id="tab-pending" class="adm-tab-panel active" role="tabpanel">

    {% if pending is empty %}
        <div class="adm-empty-state">
            Aucune opportunité en attente de validation.<br>
            Lancez le scraping pour en collecter de nouvelles.
        </div>
    {% else %}
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre / Description</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in pending %}
                        <tr>
                            {# Titre avec lien externe vers la source originale #}
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        {# rel="noopener noreferrer" : sécurité pour les liens vers des sites tiers #}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">
                                            {{ opp.title }}
                                        </a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                                {% if opp.description %}
                                    <div class="adm-opp-desc">
                                        {{ opp.description|slice(0, 140) }}{{ opp.description|length > 140 ? '…' : '' }}
                                    </div>
                                {% endif %}
                            </td>

                            {# Type de ressource détecté par le scraper #}
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% else %}
                                    <span style="color:var(--ink-mute);">—</span>
                                {% endif %}
                            </td>

                            {# Site source #}
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>

                            {# Date limite de candidature #}
                            <td class="adm-date">{{ opp.deadline ?: '—' }}</td>

                            {# Score de pertinence afro-atlantique (1 à 5 étoiles) #}
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>

                            {# Date de scraping #}
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>

                            {#
                              Bouton Vérifier → appelle verifyScrapedOpportunity() dans AdminController :
                                1. Passe ScrapedResource.status à "verified"
                                2. Crée une Resource publiée dans la table Opportunités
                              Token CSRF : 'verify_scraped_{id}' (vérifié côté PHP)
                            #}
                            <td>
                                <form method="post"
                                      action="{{ path('app_admin_scraped_opportunity_verify', {id: opp.id}) }}"
                                      onsubmit="return confirm('Vérifier et ajouter « {{ opp.title|e('js') }} » aux Opportunités ?')">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('verify_scraped_' ~ opp.id) }}">
                                    <button type="submit" class="adm-btn-verify">✓ Vérifier</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{# ── Panneau : VÉRIFIÉ (archives) ─────────────────────────────────────────── #}
<div id="tab-verified" class="adm-tab-panel" role="tabpanel">

    {% if verified is empty %}
        <div class="adm-empty-state">Aucune opportunité validée pour l'instant.</div>
    {% else %}
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in verified %}
                        <tr>
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">{{ opp.title }}</a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% endif %}
                            </td>
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>
                            <td class="adm-date">{{ opp.deadline ?: '—' }}</td>
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>
                            {# Badge "Vérifié" — fond vert acide : action accomplie #}
                            <td><span class="adm-badge-verified">✓ Vérifié</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{#
  Script de gestion des onglets (vanilla JS — pas de dépendance externe).
  Très simple : on masque tous les panneaux, on affiche le bon, on met à jour les boutons.
#}
<script>
/**
 * Affiche l'onglet demandé et masque les autres.
 * @param {string} name - Nom de l'onglet ('pending' ou 'verified')
 * @param {HTMLButtonElement} btn - Bouton cliqué
 */
function showTab(name, btn) {
    /* Mise à jour des boutons d'onglet */
    document.querySelectorAll('.adm-tab-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    /* Affichage du panneau correspondant */
    document.querySelectorAll('.adm-tab-panel').forEach(function(p) {
        p.classList.remove('active');
    });
    document.getElementById('tab-' + name).classList.add('active');
}
</script>

{% endblock %}
