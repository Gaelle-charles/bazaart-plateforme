{% extends 'base_admin.html.twig' %}

{#
 # admin/scraped_opportunities.html.twig — Opportunités scrapées (Google Sheets)
 #
 # Thème : Street
 # Layout parent : base_admin.html.twig
 #
 # Variables disponibles (AdminController::scrapedOpportunities()) :
 #   - pending  : ScrapedResource[] — statut "À vérifier" triés par score desc
 #   - verified : ScrapedResource[] — statut "Vérifié" (archives)
 #
 # Actions disponibles :
 #   - Vérifier : POST /admin/scraped-opportunities/{id}/verify (CSRF : 'verify_scraped_{id}')
 #                → change le statut ScrapedResource à "verified" ET crée une Resource publiée
 #}

{% block title %}Scraping — Admin BazaArt{% endblock %}
{% block page_title %}Scraping Sheets{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

    /* ── Zone de contenu fond sable ─────────────────────────────────────────── */
    .app-content {
        background: var(--bg);
        font-family: var(--body);
    }

    /* ── Retour dashboard ───────────────────────────────────────────────────── */
    .adm-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: .06em;
        color: var(--ink-mute);
        text-decoration: none;
        margin-bottom: 14px;
        transition: color var(--transition-fast);
    }
    .adm-back:hover { color: var(--ink); }

    /* ── Hint commande scraping ─────────────────────────────────────────────── */
    .adm-hint {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        margin-bottom: 20px;
        letter-spacing: .04em;
    }
    .adm-hint code {
        background: var(--ink);
        color: var(--accent);
        padding: 2px 8px;
        font-size: 11px;
        font-family: var(--mono);
        display: inline-block;
        margin-left: 4px;
    }

    /* ── Onglets Street (À vérifier / Vérifié) ──────────────────────────────── */
    /*
      Style : bandeau horizontal, l'onglet actif a un fond ink et un texte accent.
      Les onglets inactifs ont fond bg-alt. Bords francs (pas de border-radius).
    */
    .adm-tabs {
        display: flex;
        border: 1px solid var(--ink);
        margin-bottom: 20px;
        width: fit-content;
    }
    .adm-tab-btn {
        padding: 10px 20px;
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        border: none;
        border-right: 1px solid var(--ink);
        background: var(--bg-alt);
        color: var(--ink);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background var(--transition-fast);
    }
    .adm-tab-btn:last-child { border-right: none; }
    /* Onglet actif : fond noir, texte vert */
    .adm-tab-btn.active {
        background: var(--ink);
        color: var(--accent);
    }
    .adm-tab-btn:hover:not(.active) { background: var(--bg); }

    /* Compteur dans l'onglet */
    .adm-tab-count {
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        font-size: 10px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    /* Compteur en attente : fond orange */
    .adm-tab-count--pending  { background: var(--accent-2); color: var(--ink); }
    /* Compteur vérifié : fond vert acide */
    .adm-tab-count--verified { background: var(--accent); color: var(--ink); }

    /* Panneaux d'onglets (affichés/masqués via JS) */
    .adm-tab-panel { display: none; }
    .adm-tab-panel.active { display: block; }

    /* ── Tableau Street — en-tête noir + corps sable ─────────────────────────── */
    .adm-table-wrap {
        border: 1px solid var(--ink);
        background: var(--bg);
        overflow-x: auto;             /* scroll horizontal sur mobile */
        -webkit-overflow-scrolling: touch;
    }
    .adm-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 680px;
    }
    .adm-table thead tr { background: var(--ink); }
    .adm-table th {
        padding: 11px 14px;
        text-align: left;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--accent);
        border-right: 1px solid rgba(198,242,78,.15);
        white-space: nowrap;
    }
    .adm-table th:last-child { border-right: none; }
    .adm-table td {
        padding: 11px 14px;
        border-bottom: 1px solid var(--line-soft);
        font-size: 13px;
        color: var(--ink);
        vertical-align: top;
    }
    .adm-table tbody tr:last-child td { border-bottom: none; }
    .adm-table tbody tr:nth-child(even) { background: var(--bg-alt); }
    .adm-table tbody tr:hover { background: rgba(13,13,13,.04); }

    /* Colonne titre : lien externe vers la source */
    .adm-opp-title {
        font-weight: 600;
        line-height: 1.4;
        max-width: 300px;
    }
    .adm-opp-title a {
        color: inherit;
        text-decoration: none;
    }
    .adm-opp-title a:hover { color: var(--accent-2); text-decoration: underline; }

    /* Description tronquée sous le titre */
    .adm-opp-desc {
        font-size: 12px;
        color: var(--ink-mute);
        margin-top: 4px;
        line-height: 1.5;
    }

    /* Chip de type de ressource */
    .adm-chip {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        border: 1px solid var(--ink);
        background: var(--bg-alt);
        color: var(--ink);
        white-space: nowrap;
    }

    /* Badge "Vérifié" — fond vert acide */
    .adm-badge-verified {
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--accent);
        color: var(--ink);
    }

    /* Étoiles de score afro-pertinence */
    .adm-stars {
        color: var(--accent-2);   /* orange pour les étoiles pleines */
        font-size: 13px;
        letter-spacing: 1px;
        white-space: nowrap;
    }
    .adm-stars .star-empty { color: var(--line-soft); }

    /* Bouton Vérifier — action principale */
    .adm-btn-verify {
        height: 30px;
        padding: 0 14px;
        background: var(--accent);
        color: var(--ink);
        border: 1px solid var(--ink);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        cursor: pointer;
        white-space: nowrap;
        transition: box-shadow var(--transition-fast);
    }
    .adm-btn-verify:hover { box-shadow: var(--shadow-offset-sm); }

    /* Date de scraping — mono compact */
    .adm-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        white-space: nowrap;
    }

    /* ── État vide ──────────────────────────────────────────────────────────── */
    .adm-empty-state {
        border: 1px solid var(--ink);
        background: var(--bg);
        padding: 48px;
        text-align: center;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--ink-mute);
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    /* ── Bandeau de contrôle du scraping (bouton Lancer + date dernier run) ─── */
    /*
      Flex horizontal : info à gauche, bouton à droite.
      Séparé du reste par un trait sous le bandeau.
    */
    .adm-scraping-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--ink);
        padding-bottom: 16px;
        margin-bottom: 20px;
    }
    .adm-scraping-info {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-mute);
        letter-spacing: .04em;
    }

    /* Bouton "Lancer le scraping" — fond encre (inverse du thème sable) */
    .adm-btn-run {
        background: var(--ink);
        color: var(--accent);     /* vert acide sur fond noir — contraste maximal */
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        padding: 8px 16px;
        border: none;
        border-radius: 0;         /* design Street : bords francs */
        cursor: pointer;
        transition: opacity var(--transition-fast);
    }
    .adm-btn-run:hover { opacity: .85; }

    /* Bouton "Rejeter" — identique à adm-btn-verify mais fond pâle + texte encre */
    .adm-btn-reject {
        height: 30px;
        padding: 0 14px;
        background: var(--bg-alt);
        color: var(--ink);
        border: 1px solid var(--ink);
        border-radius: 0; /* design Street : bords francs obligatoires */
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        cursor: pointer;
        white-space: nowrap;
        transition: box-shadow var(--transition-fast);
    }
    .adm-btn-reject:hover { box-shadow: var(--shadow-offset-sm); }

    /* Groupe d'actions — place les boutons côte à côte avec un petit espace */
    .adm-action-group {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    /* Badge "Rejeté" — fond muted (gris encre atténué), texte clair */
    .adm-badge-rejected {
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--ink-mute);
        color: var(--bg);
    }

    /* Badge "Archivé" — fond ink-mute (même ton que Rejeté, neutre)
       Distinct visuellement du rejet : police italique + icône horloge dans le Twig */
    .adm-badge-archived {
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--ink-mute);
        color: var(--bg);
        opacity: .75; /* légèrement plus transparent que "Rejeté" pour différencier visuellement */
    }

</style>
{% endblock %}

{% block content %}

{# ── Retour dashboard ─────────────────────────────────────────────────────── #}
<a href="{{ path('app_admin_dashboard') }}" class="adm-back">← Tableau de bord</a>

{#
  ── Contrôles du scraping ──────────────────────────────────────────────────
  Affiche la date du dernier scraping et un bouton pour en lancer un nouveau.
  Le bouton déclenche une commande Symfony en arrière-plan (non-bloquant).
#}
<div class="adm-scraping-controls">
    <div class="adm-scraping-info">
        {# Dernier scraping : date formatée ou "jamais lancé" si table vide #}
        Dernier scraping :
        <strong>{{ latestScrapedAt ? latestScrapedAt|date('d/m/Y à H:i') : 'jamais lancé' }}</strong>
        <br>
        {# Rappel de la commande shell pour lancement manuel (hors interface) #}
        Ou via terminal :
        <code style="background:var(--ink);color:var(--accent);padding:2px 8px;font-size:11px;font-family:var(--mono);display:inline-block;margin-left:4px;">
            docker compose exec app php bin/console app:scrape-opportunities
        </code>
    </div>

    {#
      Formulaire POST → runScraping() dans AdminController.
      Le submit est intercepté en JS pour afficher la card de statut.
      Token CSRF 'run_scraping' vérifié côté PHP.
    #}
    <form method="post"
          id="scraping-form"
          action="{{ path('app_admin_scraping_run') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('run_scraping') }}">
        <button type="submit" id="scraping-btn" class="adm-btn-run">▶ Lancer le scraping</button>
    </form>
</div>

{#
  Card de statut du scraping — masquée par défaut, affichée par JS au clic.
  États possibles :
    - "Lancement…"      → dès le clic (avant que le serveur réponde)
    - "En cours… Xs"    → pendant l'exécution, avec timer qui compte
    - "✅ Terminé"       → sur JSON success (reload automatique dans 4s)
    - "❌ Erreur"        → sur JSON error ou échec réseau
#}
<div id="scraping-card" style="
    display: none;
    align-items: flex-start;
    gap: 14px;
    margin-top: 18px;
    padding: 18px 22px;
    background: var(--bg);
    border: 1.5px solid var(--ink);
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.5;
">
    {# Icône d'état (spinner, coche, croix) — mis à jour par JS #}
    <div id="scraping-card-icon" style="font-size:22px;flex-shrink:0;margin-top:1px;">⏳</div>

    <div style="flex:1;min-width:0;">
        {# Ligne principale : état courant #}
        <div id="scraping-card-text" style="font-weight:700;color:var(--ink);margin-bottom:4px;">
            Lancement…
        </div>

        {# Timer et note d'aide — cachés jusqu'au début du scraping #}
        <div id="scraping-card-sub" style="display:none;color:var(--ink-mute);font-size:11px;">
            Temps écoulé : <span id="scraping-timer">0 s</span>
            &nbsp;·&nbsp; La page se rafraîchira automatiquement à la fin.
        </div>

        {# Barre de progression indéterminée (animation CSS pure) #}
        <div id="scraping-progress-wrap" style="display:none;margin-top:10px;height:3px;background:var(--ink-mute, #ccc);overflow:hidden;">
            <div id="scraping-progress-bar" style="
                height:100%;
                width:30%;
                background:var(--accent, #111);
                animation: scraping-slide 1.4s ease-in-out infinite;
            "></div>
        </div>
    </div>
</div>

{# Animation de la barre de progression (CSS keyframes) #}
<style>
@keyframes scraping-slide {
    0%   { transform: translateX(-100%); }
    50%  { transform: translateX(250%); }
    100% { transform: translateX(250%); }
}
</style>

<script>
/**
 * Gestion de la card de statut pour le lancement du scraping.
 *
 * Flux :
 *   1. Clic → confirmation → afficher card "Lancement…"
 *   2. fetch() POST vers /admin/scraping/run (header XMLHttpRequest pour JSON)
 *   3. Timer démarre, barre de progression animée
 *   4. Sur réponse JSON success → card verte, rechargement auto dans 4s
 *   5. Sur erreur → card rouge avec message d'erreur
 */
document.addEventListener('DOMContentLoaded', function () {
    const form   = document.getElementById('scraping-form');
    const btn    = document.getElementById('scraping-btn');
    const card   = document.getElementById('scraping-card');
    const icon   = document.getElementById('scraping-card-icon');
    const text   = document.getElementById('scraping-card-text');
    const sub    = document.getElementById('scraping-card-sub');
    const timer  = document.getElementById('scraping-timer');
    const prog   = document.getElementById('scraping-progress-wrap');

    if (!form) return; // Sécurité : ne rien faire si le formulaire n'existe pas

    form.addEventListener('submit', function (e) {
        e.preventDefault(); // Empêche le submit classique (redirect bloquant)

        // Confirmation de sécurité (remplace le onsubmit="return confirm(...)" précédent)
        if (!confirm('Lancer le scraping maintenant ? Cela peut prendre 1 à 2 minutes.')) {
            return;
        }

        // ── Afficher la card en état "Lancement…" ────────────────────────────
        btn.disabled    = true;
        btn.textContent = '⏳ En cours…';
        card.style.display = 'flex';

        // ── Démarrer le timer ────────────────────────────────────────────────
        // Affiche combien de secondes se sont écoulées depuis le lancement.
        let seconds = 0;
        const interval = setInterval(function () {
            seconds++;
            timer.textContent = seconds + ' s';
        }, 1000);

        // Afficher le sous-titre et la barre après 1s (pas trop tôt pour éviter le flash)
        setTimeout(function () {
            text.textContent = 'Scraping en cours…';
            sub.style.display  = 'block';
            prog.style.display = 'block';
        }, 800);

        // ── Lancer le scraping via fetch() ───────────────────────────────────
        // On envoie le FormData (incluant le token CSRF) avec le header XMLHttpRequest
        // pour que le controller PHP retourne du JSON au lieu d'une redirect.
        const formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                // Ce header indique au controller que c'est une requête AJAX
                // → il retournera du JSON au lieu de faire une redirect
                'X-Requested-With': 'XMLHttpRequest',
            },
        })
        .then(function (response) {
            clearInterval(interval);
            if (!response.ok) {
                // Erreur HTTP (500, 403...) → on essaie de lire le message JSON
                return response.json().then(function (data) {
                    throw new Error(data.error || 'Erreur serveur (code ' + response.status + ')');
                }).catch(function () {
                    throw new Error('Erreur serveur (code ' + response.status + ')');
                });
            }
            return response.json();
        })
        .then(function (data) {
            // ── Succès ───────────────────────────────────────────────────────
            prog.style.display = 'none';
            icon.textContent   = '✅';
            icon.style.filter  = 'none';

            // Message de bilan
            let msg = 'Terminé en ' + seconds + ' s';
            if (data.inserted > 0) {
                msg += ' · ' + data.inserted + ' nouvelle' + (data.inserted > 1 ? 's' : '');
            }
            if (data.updated > 0) {
                msg += ' · ' + data.updated + ' mise' + (data.updated > 1 ? 's' : '') + ' à jour';
            }
            if (data.skipped > 0) {
                msg += ' · ' + data.skipped + ' ignorée' + (data.skipped > 1 ? 's' : '');
            }
            text.textContent  = msg;

            // Sous-titre : rechargement auto
            sub.style.display  = 'block';
            timer.textContent  = seconds + ' s';
            sub.innerHTML      = 'Rechargement de la liste dans <span id="countdown">4</span> s…';

            // Compte à rebours avant rechargement
            let countdown = 4;
            const countdownSpan = document.getElementById('countdown');
            const countdownInterval = setInterval(function () {
                countdown--;
                if (countdownSpan) countdownSpan.textContent = countdown;
                if (countdown <= 0) {
                    clearInterval(countdownInterval);
                    window.location.reload();
                }
            }, 1000);

            btn.disabled    = false;
            btn.textContent = '▶ Lancer le scraping';
        })
        .catch(function (err) {
            // ── Erreur ───────────────────────────────────────────────────────
            clearInterval(interval);
            prog.style.display = 'none';
            icon.textContent   = '❌';
            text.textContent   = 'Erreur : ' + err.message;
            text.style.color   = '#c0392b';
            sub.style.display  = 'block';
            sub.innerHTML      = 'Vérifiez les logs Symfony ou relancez manuellement.';

            btn.disabled    = false;
            btn.textContent = '▶ Lancer le scraping';
        });
    });
});
</script>

{# ── Onglets À vérifier / Vérifié / Rejeté ───────────────────────────────── #}
{# role="tablist" + aria-selected pour l'accessibilité clavier #}
<div class="adm-tabs" role="tablist">
    <button class="adm-tab-btn active"
            role="tab"
            aria-selected="true"
            aria-controls="tab-pending"
            onclick="showTab('pending', this)">
        À vérifier
        <span class="adm-tab-count adm-tab-count--pending">{{ pending|length }}</span>
    </button>
    <button class="adm-tab-btn"
            role="tab"
            aria-selected="false"
            aria-controls="tab-verified"
            onclick="showTab('verified', this)">
        Vérifié
        <span class="adm-tab-count adm-tab-count--verified">{{ verified|length }}</span>
    </button>
    {# 3ème onglet : opportunités rejetées par l'admin — fond muted (gris atténué) #}
    <button class="adm-tab-btn"
            role="tab"
            aria-selected="false"
            aria-controls="tab-rejected"
            onclick="showTab('rejected', this)">
        Rejeté
        <span class="adm-tab-count" style="background:var(--ink-mute);color:var(--bg);">
            {{ rejected|length }}
        </span>
    </button>
    {#
      4ème onglet : opportunités archivées (deadline passée, détectée automatiquement).
      Pas d'action disponible — consultation uniquement.
      La couleur du compteur suit var(--ink-mute) pour indiquer que ces items sont "dormants".
    #}
    <button class="adm-tab-btn"
            role="tab"
            aria-selected="false"
            aria-controls="tab-archived"
            onclick="showTab('archived', this)">
        Archivé
        <span class="adm-tab-count" style="background:var(--ink-mute);color:var(--bg);opacity:.75;">
            {{ archived|length }}
        </span>
    </button>
</div>

{# ── Panneau : À VÉRIFIER ─────────────────────────────────────────────────── #}
<div id="tab-pending" class="adm-tab-panel active" role="tabpanel">

    {% if pending is empty %}
        <div class="adm-empty-state">
            Aucune opportunité en attente de validation.<br>
            Lancez le scraping pour en collecter de nouvelles.
        </div>
    {% else %}
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre / Description</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in pending %}
                        <tr>
                            {# Titre avec lien externe vers la source originale #}
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        {# rel="noopener noreferrer" : sécurité pour les liens vers des sites tiers #}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">
                                            {{ opp.title }}
                                        </a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                                {% if opp.description %}
                                    <div class="adm-opp-desc">
                                        {{ opp.description|slice(0, 140) }}{{ opp.description|length > 140 ? '…' : '' }}
                                    </div>
                                {% endif %}
                            </td>

                            {# Type de ressource détecté par le scraper #}
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% else %}
                                    <span style="color:var(--ink-mute);">—</span>
                                {% endif %}
                            </td>

                            {# Site source #}
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>

                            {# Date limite de candidature #}
                            <td class="adm-date">{{ opp.deadline ?: '—' }}</td>

                            {# Score de pertinence afro-atlantique (1 à 5 étoiles) #}
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>

                            {# Date de scraping #}
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>

                            {#
                              Colonne Action : trois boutons côte à côte.
                              - Modifier → editScrapedOpportunity() : édition du titre, type, description, etc.
                              - Vérifier → verifyScrapedOpportunity() : passe à "verified" + crée une Resource publiée
                              - Rejeter  → rejectScrapedOpportunity()  : passe à "rejected" (hors sujet / doublon)
                              Les deux actions POST utilisent un token CSRF distinct pour chaque action et chaque ID.
                            #}
                            <td>
                                <div class="adm-action-group">
                                    {#
                                      Lien "Modifier" — simple lien GET vers le formulaire d'édition.
                                      Pas de formulaire POST ici car c'est une navigation, pas une action.
                                      Affichage : fond sable (neutre), cohérent avec adm-btn-reject mais sans danger.
                                    #}
                                    <a href="{{ path('app_admin_scraped_opportunity_edit', {id: opp.id}) }}"
                                       class="adm-btn-reject"
                                       style="display:inline-flex; align-items:center; text-decoration:none; background:var(--bg); color:var(--ink); border-color:var(--ink);">
                                        ✎ Modifier
                                    </a>

                                    {# Bouton principal : valider et publier l'opportunité #}
                                    <form method="post"
                                          action="{{ path('app_admin_scraped_opportunity_verify', {id: opp.id}) }}"
                                          onsubmit="return confirm('Vérifier et ajouter « {{ opp.title|e('js') }} » aux Opportunités ?')">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('verify_scraped_' ~ opp.id) }}">
                                        <button type="submit" class="adm-btn-verify">✓ Vérifier</button>
                                    </form>

                                    {# Bouton secondaire : rejeter (hors sujet, doublon, non pertinent) #}
                                    <form method="post"
                                          action="{{ path('app_admin_scraped_opportunity_reject', {id: opp.id}) }}"
                                          onsubmit="return confirm('Rejeter « {{ opp.title|e('js') }} » ?')"
                                          style="display:inline;">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('reject_scraped_' ~ opp.id) }}">
                                        <button type="submit" class="adm-btn-reject">✗ Rejeter</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{# ── Panneau : VÉRIFIÉ (archives) ─────────────────────────────────────────── #}
<div id="tab-verified" class="adm-tab-panel" role="tabpanel">

    {% if verified is empty %}
        <div class="adm-empty-state">Aucune opportunité validée pour l'instant.</div>
    {% else %}
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in verified %}
                        <tr>
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">{{ opp.title }}</a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% endif %}
                            </td>
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>
                            <td class="adm-date">{{ opp.deadline ?: '—' }}</td>
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>
                            {# Badge "Vérifié" — fond vert acide : action accomplie #}
                            <td><span class="adm-badge-verified">✓ Vérifié</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{# ── Panneau : REJETÉ ─────────────────────────────────────────────────────── #}
{#
  Ce panneau liste les opportunités rejetées par un admin.
  Pas d'action disponible ici : le rejet est définitif dans l'interface (l'URL restera
  en BDD pour éviter de la rescaper, mais l'admin peut techniquement modifier le statut
  via Doctrine si besoin de corriger une erreur).
#}
<div id="tab-rejected" class="adm-tab-panel" role="tabpanel">

    {% if rejected is empty %}
        <div class="adm-empty-state">Aucune opportunité rejetée.</div>
    {% else %}
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in rejected %}
                        <tr>
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">{{ opp.title }}</a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% endif %}
                            </td>
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>
                            <td class="adm-date">{{ opp.deadline ?: '—' }}</td>
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>
                            {# Badge "Rejeté" — fond ink-mute (gris), texte bg (clair) #}
                            <td><span class="adm-badge-rejected">✗ Rejeté</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{# ── Panneau : ARCHIVÉ (deadline passée) ─────────────────────────────────── #}
{#
  Ce panneau liste les opportunités dont la deadline a été détectée comme passée.
  L'archivage est automatique : effectué à chaque run du scraper par archiveExpired().
  Aucune action n'est disponible ici — c'est un historique en lecture seule.
  L'admin peut cependant constater quels types d'opportunités récurrentes reviennent :
  utile pour anticiper et configurer des alertes avant les prochaines sessions.
#}
<div id="tab-archived" class="adm-tab-panel" role="tabpanel">

    {% if archived is empty %}
        <div class="adm-empty-state">
            Aucune opportunité archivée.<br>
            Les opportunités avec une deadline dépassée seront automatiquement archivées lors du prochain scraping.
        </div>
    {% else %}
        {# Note informative : explique à l'admin d'où viennent ces entrées #}
        <p style="font-family:var(--mono);font-size:11px;color:var(--ink-mute);margin-bottom:14px;letter-spacing:.04em;">
            Ces opportunités ont été archivées automatiquement car leur deadline est passée.
            Elles restent consultables pour référence. Aucune action disponible.
        </p>
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Source</th>
                        <th>Deadline</th>
                        <th>Score Afro</th>
                        <th>Scrapé le</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in archived %}
                        <tr>
                            <td style="max-width:320px;">
                                <div class="adm-opp-title">
                                    {% if opp.url %}
                                        <a href="{{ opp.url }}" target="_blank" rel="noopener noreferrer">{{ opp.title }}</a>
                                    {% else %}
                                        {{ opp.title }}
                                    {% endif %}
                                </div>
                                {# Affiche la description si disponible — utile pour se souvenir du contenu #}
                                {% if opp.description %}
                                    <div class="adm-opp-desc">
                                        {{ opp.description|slice(0, 100) }}{{ opp.description|length > 100 ? '…' : '' }}
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                {% if opp.type %}
                                    <span class="adm-chip">{{ opp.type }}</span>
                                {% else %}
                                    <span style="color:var(--ink-mute);">—</span>
                                {% endif %}
                            </td>
                            <td class="adm-date">{{ opp.sourceSite ?: '—' }}</td>
                            {# Deadline : mise en évidence visuelle pour rappeler que c'est passé #}
                            <td class="adm-date" style="color:var(--ink-mute);text-decoration:line-through;">
                                {{ opp.deadline ?: '—' }}
                            </td>
                            <td>
                                <span class="adm-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= opp.relevanceScore %}★{% else %}<span class="star-empty">☆</span>{% endif %}
                                    {% endfor %}
                                </span>
                            </td>
                            <td class="adm-date">{{ opp.scrapedAt|date('d/m/Y') }}</td>
                            {# Badge "Archivé" — ton neutre (muted), légèrement transparent #}
                            <td><span class="adm-badge-archived">⏱ Archivé</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{#
  Script de gestion des onglets (vanilla JS — pas de dépendance externe).
  Très simple : on masque tous les panneaux, on affiche le bon, on met à jour les boutons.
#}
<script>
/**
 * Affiche l'onglet demandé et masque les autres.
 * @param {string} name - Nom de l'onglet ('pending' ou 'verified')
 * @param {HTMLButtonElement} btn - Bouton cliqué
 */
function showTab(name, btn) {
    /* Mise à jour des boutons d'onglet */
    document.querySelectorAll('.adm-tab-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    /* Affichage du panneau correspondant */
    document.querySelectorAll('.adm-tab-panel').forEach(function(p) {
        p.classList.remove('active');
    });
    document.getElementById('tab-' + name).classList.add('active');
}
</script>

{% endblock %}
