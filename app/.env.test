# ──────────────────────────────────────────────────────────────────────────────
# .env.test — Variables d'environnement pour l'environnement de TEST
#
# Ce fichier est chargé automatiquement par Symfony quand APP_ENV=test.
# Il surcharge les valeurs de .env (mais PAS de .env.local).
#
# Règle de priorité Symfony : .env < .env.test < .env.test.local
#
# ⚠️ NE PAS mettre de secrets réels ici — ce fichier est versionné.
# ──────────────────────────────────────────────────────────────────────────────

KERNEL_CLASS='App\Kernel'
APP_ENV=test

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Secret non-réel utilisé uniquement pour les CSRF tokens en test
APP_SECRET='test_secret_for_phpunit_only'

# ── Base de données de test ───────────────────────────────────────────────────
# Base dédiée aux tests, séparée de la base de développement pour éviter
# tout risque de corruption des données de dev lors des fixtures de test.
# On utilise "bazaart_test" sur le même serveur PostgreSQL Docker.
# Note : Doctrine ajoute automatiquement le suffixe "_test" grâce au when@test
# dans doctrine.yaml (dbname_suffix: '_test'). Donc la base résultante est "bazaart_test".
# Ne PAS mettre "bazaart_test" ici sinon la base serait "bazaart_test_test".
DATABASE_URL="postgresql://bazaart_user:bazaart_pass@postgres:5432/bazaart?serverVersion=16&charset=utf8"

# ── Email : transport null ────────────────────────────────────────────────────
# En test, on ne veut PAS envoyer d'emails réels.
# "null://null" = transport Symfony qui accepte tous les emails sans les envoyer.
MAILER_DSN=null://null

# ── Redis ─────────────────────────────────────────────────────────────────────
# On réutilise Redis Docker pour le cache/sessions en test.
REDIS_URL=redis://redis:6379

# ── Clés API externes — valeurs factices pour les tests ──────────────────────
# Ces services ne sont PAS appelés en test (pas de vraies requêtes HTTP sortantes).
ANTHROPIC_API_KEY=test_key_not_used
N8N_WEBHOOK_BASE_URL=http://localhost
SENTRY_DSN=
BUNNY_STREAM_API_KEY=test
BUNNY_STREAM_LIBRARY_ID=test

# ── Variables Google OAuth (non utilisées en test, mais requises par le container) ──
GOOGLE_CLIENT_ID=test_google_client_id
GOOGLE_CLIENT_SECRET=test_google_client_secret
